---
import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import FormResult from "~/components/form/form-result.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import { createActionResult } from "~/lib/form-result";
import {
	COMPLAINT_STATUS_BADGES,
	COMPLAINT_STATUS_BORDERS,
	COMPLAINT_STATUS_LABELS,
	complaintQuerySchema,
	fetchComplaints,
	getComplaintStats,
} from "./_data";

const params = Astro.locals.parseQuery(complaintQuerySchema);
const filteredComplaints = await fetchComplaints(params);
const complaintStats = getComplaintStats(filteredComplaints).map((s) => ({
	title: s.label,
	value: String(s.value),
	icon: "line-md:document-list",
}));
---

<FormResult
	actionResults={[
		createActionResult(
			actions.manage.complaints.resolve,
			"Selesaikan komplain",
			(d) => `Berhasil menyelesaikan komplain! (ID: ${d.id})`,
		),
	]}
/>

<DashboardLayout
	title="Daftar Komplain"
	description="Monitor pengaduan kerusakan dan keluhan sarana dari penghuni indekos"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/manage/complaints/report/download${Astro.url.search}`}
			download
		>
			<Icon name="line-md:download" /> PDF
		</a>
	</Fragment>

	<Stats items={complaintStats} />

	<FilterToolbar name="complaints" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="complaints"
				groups={[
					{
						title: "Status",
						name: "status",
						options: [
							{
								value: "open",
								label: "Terbuka",
								checked: params.status === "open",
							},
							{
								value: "in_progress",
								label: "Proses",
								checked: params.status === "in_progress",
							},
							{
								value: "resolved",
								label: "Selesai",
								checked: params.status === "resolved",
							},
						],
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-complaints"
				placeholder="Cari isi komplain/penghuni..."
			/>
		</Fragment>
	</FilterToolbar>

	<div class="flex flex-col gap-4" id="complaints-content-wrapper">
		{
			filteredComplaints.map(
				({
					id,
					description,
					status,
					createdAt,
					tenantName,
					roomNumber,
					resolvedByUserName,
					resolveNotes,
					resolvedAt,
				}) => {
					const isResolvable = status !== "resolved";
					return (
						<div
							class:list={[
								"card border border-l-4 border-base-200 bg-base-100 shadow-sm transition-all hover:shadow-md",
								COMPLAINT_STATUS_BORDERS[
									status as keyof typeof COMPLAINT_STATUS_BORDERS
								],
								{ "opacity-65": !isResolvable },
							]}
						>
							<div class="card-body justify-between gap-4 p-5 md:flex-row md:items-center">
								<div class="flex flex-1 flex-col gap-2">
									<div class="flex flex-wrap items-center gap-2">
										<span class="text-mono text-xs font-bold text-base-content/40">
											KMP-{id}
										</span>
										<span
											class:list={[
												"badge badge-sm font-bold",
												COMPLAINT_STATUS_BADGES[
													status as keyof typeof COMPLAINT_STATUS_BADGES
												],
											]}
										>
											{
												COMPLAINT_STATUS_LABELS[
													status as keyof typeof COMPLAINT_STATUS_LABELS
												]
											}
										</span>
										<span class="badge font-mono font-bold badge-neutral">
											{roomNumber || "-"}
										</span>
										<span class="text-xs text-base-content/50">•</span>
										<span class="text-xs font-semibold text-base-content/60">
											{tenantName}
										</span>
									</div>
									<p class="text-base font-bold text-base-content">
										{description}
									</p>
									{resolveNotes && (
										<div class="mt-2 max-w-xl rounded border border-success/20 bg-success/5 p-2.5 text-xs">
											<span class="mb-0.5 block font-bold text-success">
												Catatan Penyelesaian:
											</span>
											<p class="wrap-break-word whitespace-pre-wrap text-base-content/85">
												{resolveNotes}
											</p>
										</div>
									)}
									<div class="mt-1 flex items-center gap-2 text-xs text-base-content/50">
										<Icon name="line-md:calendar" size="size-3.5" />
										<span>Dilaporkan pada: {formatDate(createdAt)}</span>
										{resolvedByUserName && (
											<>
												<span>•</span>
												<span class="flex items-center gap-1 font-semibold text-success">
													<Icon name="line-md:circle-to-confirm-circle-transition" />
													Ditangani oleh: {resolvedByUserName}
												</span>
											</>
										)}
										{resolvedAt && (
											<>
												<span>•</span>
												<span class="flex items-center gap-1">
													<Icon name="line-md:calendar-check" size="size-3.5" />
													Selesai: {formatDate(resolvedAt)}
												</span>
											</>
										)}
									</div>
								</div>

								<div class="flex shrink-0 items-center gap-2 self-end md:self-center">
									{isResolvable ? (
										<button
											hx-get={`/dashboard/manage/complaints/modal/resolve/${id}`}
											class="btn btn-outline btn-sm btn-success"
										>
											<Icon name="line-md:circle-to-confirm-circle-transition" />
											Tandai Selesai
										</button>
									) : (
										<span class="flex items-center gap-1 text-xs font-bold text-success">
											<Icon
												name="line-md:circle-to-confirm-circle-transition"
												size="size-4"
											/>
											Selesai
										</span>
									)}
								</div>
							</div>
						</div>
					);
				},
			)
		}
	</div>
</DashboardLayout>
