---
import { db, eq } from "@e-kos/database";
import { leases, rooms } from "@e-kos/database/schema";

import Icon from "~/components/icon.astro";
import { formatDate } from "~/lib/date";

export const partial = true;

const tenant = await db.query.tenants.findFirst({
	where: { id: Number(Astro.params.id) },
});

const tenantLeases = tenant
	? await db
			.select({
				id: leases.id,
				startDate: leases.startDate,
				endDate: leases.endDate,
				isActive: leases.isActive,
				roomNumber: rooms.roomNumber,
				roomType: rooms.roomType,
				monthlyPrice: rooms.monthlyPrice,
			})
			.from(leases)
			.innerJoin(rooms, eq(rooms.id, leases.roomId))
			.where(eq(leases.tenantId, tenant.id))
	: [];


if (!tenant) Astro.response.status = 404;
---

<dialog class="modal" id="detail_tenant_modal">
	{
		tenant ? (
			<div class="modal-box border-base-300 max-w-lg border">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>

				<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
					<Icon
						class="text-primary"
						name="line-md:account-twotone"
						size="size-6"
					/>
					Detail Penghuni
				</h3>

				<div class="grid grid-cols-2 gap-x-4 gap-y-2 border-b border-base-200 pb-4 text-sm">
					<span class="text-base-content/60 font-semibold">Nama Lengkap:</span>
					<span class="font-bold">{tenant.fullName}</span>

					<span class="text-base-content/60 font-semibold">
						No. HP (WhatsApp):
					</span>
					<span class="font-mono">{tenant.phoneNumber}</span>

					<span class="text-base-content/60 font-semibold">Daerah Asal:</span>
					<span>{tenant.originRegion ?? "-"}</span>

					<span class="text-base-content/60 font-semibold">Terdaftar Pada:</span>
					<span>{formatDate(tenant.createdAt)}</span>
				</div>

				<div class="mt-4">
					<h4 class="text-base-content/80 mb-2 flex items-center gap-1.5 text-sm font-bold">
						<Icon name="line-md:document-list-twotone" size="size-4" />
						Riwayat Kontrak Sewa
					</h4>
					{tenantLeases.length === 0 ? (
						<p class="text-base-content/50 py-2 text-xs italic">
							Belum ada riwayat kontrak.
						</p>
					) : (
						<div class="divide-base-200 max-h-48 overflow-y-auto divide-y">
							{tenantLeases.map(
								({
									id,
									startDate,
									endDate,
									isActive,
									roomNumber,
									roomType,
									monthlyPrice,
								}) => (
									<div class="flex items-center justify-between py-2.5 text-xs" data-id={id}>
										<div class="flex flex-col gap-0.5">
											<div class="flex items-center gap-2">
												<span class="bg-neutral text-neutral-content rounded px-1.5 py-0.5 font-mono text-sm font-bold">
													{roomNumber}
												</span>
												<span class="text-base-content/50 font-semibold">
													{roomType}
												</span>
											</div>
											<span class="text-base-content/60">
												{formatDate(startDate)} s/d {formatDate(endDate)}
											</span>
										</div>
										<div class="flex flex-col items-end gap-1">
											<span class="font-mono font-bold">
												Rp {monthlyPrice.toLocaleString("id-ID")}/Bln
											</span>
											<span
												class:list={[
													"badge badge-xs font-bold",
													isActive
														? "badge-success"
														: "badge-neutral opacity-60",
												]}
											>
												{isActive ? "Aktif" : "Selesai"}
											</span>
										</div>
									</div>
								),
							)}
						</div>
					)}
				</div>

				<div class="modal-action">
					<form method="dialog">
						<button class="btn btn-neutral btn-sm">Tutup</button>
					</form>
				</div>
			</div>
		) : (
			<div class="modal-box border-base-300 border">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>
				<h3 class="mb-4 text-xl font-bold">Detail Penghuni</h3>
				<p class="py-4">
					Penghuni dengan ID: {Astro.params.id} tidak ditemukan.
				</p>
			</div>
		)
	}
	<form class="modal-backdrop" method="dialog">
		<button>close</button>
	</form>
</dialog>
