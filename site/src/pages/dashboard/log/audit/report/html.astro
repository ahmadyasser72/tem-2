---
import { formatDate } from "@indekos/utilities/date";

import ReportStats from "~/components/data/report-stats.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import {
	AUDIT_ACTION_LABELS,
	auditQuerySchema,
	fetchAuditLogs,
	getAuditStats,
} from "../_data";

const params = Astro.locals.parseQuery(auditQuerySchema.omit({ query: true }));

const auditLogs = await fetchAuditLogs(params);
const auditStats = getAuditStats(auditLogs);

const filterParts: string[] = [];
if (params.action) {
	filterParts.push(`Aksi: ${AUDIT_ACTION_LABELS[params.action]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Aktivitas Pengguna" subtitle={subtitle}>
	<ReportStats stats={auditStats} />

	<table>
		<thead>
			<tr>
				<th class="w-[5%] text-center">No.</th>
				<th class="w-[20%]">Waktu Kejadian</th>
				<th class="w-[18%]">Pengguna</th>
				<th class="w-[14%]">Jenis Aksi</th>
				<th class="w-[28%]">Tabel Target</th>
				<th class="w-[15%]">ID Record</th>
			</tr>
		</thead>
		<tbody>
			{
				auditLogs.map((row, idx) => (
					<>
						<tr>
							<td class="text-center text-[10px]" rowspan="2">
								{idx + 1}
							</td>
							<td class="font-mono text-[10px]" rowspan="2">
								{formatDate(row.createdAt, "DD MMM YYYY HH:mm")}
							</td>
							<td rowspan="2">{row.displayName}</td>
							<td class="text-center font-bold uppercase" rowspan="2">
								{row.action}
							</td>
							<td class="font-mono text-[10px]">{row.tableName}</td>
							<td class="text-center font-mono text-[10px]">
								{row.recordId ?? "-"}
							</td>
						</tr>
						<tr>
							<td colspan="2">{row.details?.description ?? "-"}</td>
						</tr>
					</>
				))
			}
		</tbody>
	</table>
</ReportLayout>
