---
import { db } from "@e-kos/database";

import DetailModal from "~/components/modal/detail-modal.astro";
import Icon from "~/components/ui/icon.astro";
import NotFound from "~/components/ui/not-found.astro";
import { formatDate } from "~/lib/date";
import { formatCurrency } from "~/lib/transforms";

export const partial = true;

const tenant = await db.query.tenants.findFirst({
	columns: {
		id: true,
		fullName: true,
		phoneNumber: true,
		originRegion: true,
	},
	where: { id: Number(Astro.params.id) },
});

const tenantLeases = tenant
	? await db.query.leases.findMany({
			where: { tenantId: tenant.id },
			with: { room: true },
			orderBy: { startDate: "desc" },
		})
	: [];

const activeLease = tenantLeases.find((lease) => lease.isActive) ?? null;

if (!tenant) Astro.response.status = 404;
---

<DetailModal
	id="detail_tenant"
	title={`Detail ${tenant?.fullName ?? ""}`}
	icon="line-md:account"
	modalClass="max-w-lg"
>
	{
		tenant ? (
			<>
				<div class="border-base-200 grid grid-cols-2 gap-x-4 gap-y-2.5 border-b pb-4 text-sm">
					<span class="text-base-content/60 font-semibold">Nama Lengkap:</span>
					<span class="font-bold">{tenant.fullName}</span>

					<span class="text-base-content/60 font-semibold">No. HP:</span>
					<span class="font-mono">+{tenant.phoneNumber ?? "-"}</span>

					<span class="text-base-content/60 font-semibold">Daerah Asal:</span>
					<span>{tenant.originRegion ?? "-"}</span>

					<span class="text-base-content/60 font-semibold">Kamar:</span>
					<span class="font-mono font-bold">
						{activeLease?.room?.roomNumber ?? (
							<span class="text-base-content/40 italic">Tidak ada</span>
						)}
					</span>

					<span class="text-base-content/60 font-semibold">
						Tanggal Mulai Sewa:
					</span>
					<span>{activeLease ? formatDate(activeLease.startDate) : "-"}</span>

					<span class="text-base-content/60 font-semibold">
						Tanggal Selesai Sewa:
					</span>
					<span>
						{activeLease?.endDate ? formatDate(activeLease.endDate) : "-"}
					</span>
				</div>

				<div class="mt-4">
					<h4 class="text-base-content/80 mb-2 flex items-center gap-1.5 text-sm font-bold">
						<Icon name="line-md:document-list-twotone" size="size-4" />
						Riwayat Sewa
					</h4>
					{tenantLeases.length === 0 ? (
						<p class="text-base-content/50 py-2 text-xs italic">
							Belum ada riwayat sewa.
						</p>
					) : (
						<div class="divide-base-200 max-h-48 divide-y overflow-y-auto">
							{tenantLeases
								.filter((lease) => !lease.isActive)
								.map((lease) => (
									<div class="flex items-center justify-between py-2.5 text-xs">
										<div class="flex flex-col gap-0.5">
											<div class="flex items-center gap-2">
												<span class="badge badge-neutral badge-xs font-mono">
													{lease.room?.roomNumber ?? "—"}
												</span>
												<span class="font-mono text-xs">
													{formatCurrency(lease.room?.monthlyPrice ?? 0)}
												</span>
											</div>
											<span class="text-base-content/60">
												{formatDate(lease.startDate)} s/d{" "}
												{formatDate(lease.endDate)}
											</span>
										</div>
										<div class="flex flex-col items-end gap-1">
											<span
												class:list={[
													"badge badge-xs font-bold",
													lease.isActive
														? "badge-success"
														: "badge-neutral opacity-60",
												]}
											>
												{lease.isActive ? "Aktif" : "Selesai"}
											</span>
										</div>
									</div>
								))}
						</div>
					)}
				</div>
			</>
		) : (
			<NotFound label="Penghuni" />
		)
	}
</DetailModal>
