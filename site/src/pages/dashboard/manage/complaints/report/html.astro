---
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import {
	COMPLAINT_STATUS_LABELS,
	complaintQuerySchema,
	fetchComplaints,
	getComplaintStats,
} from "../_data";

const params = Astro.locals.parseQuery(complaintQuerySchema);

const complaints = await fetchComplaints(params);
const stats = getComplaintStats(complaints);

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${COMPLAINT_STATUS_LABELS[params.status]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Komplain Penghuni" subtitle={subtitle}>
	<div
		style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px;"
	>
		{
			stats.map((stat) => (
				<div style="border:1px solid black;padding:8px 12px;text-align:center;">
					<p style="font-size:10px;font-weight:400;margin-bottom:4px;">
						{stat.title}
					</p>
					<p style="font-size:18px;font-weight:700;">{stat.value}</p>
				</div>
			))
		}
	</div>

	<p style="font-size:12px;font-weight:700;margin-bottom:8px;">
		Daftar Komplain
	</p>

	<table>
		<thead>
			<tr>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>No.</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Penghuni</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Kamar</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Deskripsi</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Status</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Tanggal Lapor</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Ditangani Oleh</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Tanggal Selesai</th
				>
			</tr>
		</thead>
		<tbody>
			{
				complaints.map(
					(
						{
							tenantName,
							roomNumber,
							description,
							status,
							createdAt,
							resolvedAt,
							resolvedByUserName,
						},
						idx,
					) => (
						<tr>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
								{idx + 1}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;">
								{tenantName}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
								{roomNumber}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;">
								{description}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
								{COMPLAINT_STATUS_LABELS[status]}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
								{formatDate(createdAt)}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;">
								{resolvedByUserName}
							</td>
							<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
								{resolvedAt ? formatDate(resolvedAt) : "-"}
							</td>
						</tr>
					),
				)
			}
		</tbody>
	</table>
</ReportLayout>
