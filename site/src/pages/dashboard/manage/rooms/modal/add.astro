---
import { actions } from "astro:actions";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import { ROOM_TYPE_LABELS, ROOM_TYPES } from "../_data";

export const partial = true;
---

<Modal id="add_room" title="Tambah Kamar Baru" icon="lucide:plus-circle">
	<ModalForm
		action={actions.manage.rooms.add}
		modalId="add_room"
		submitLabel="Simpan Kamar"
		target="#form_result, #rooms-content-wrapper"
	>
		<FormField label="Nomor Kamar">
			<input
				class="input w-full"
				name="room_number"
				type="text"
				placeholder="Contoh: C05, A12..."
				required
			/>
		</FormField>
		<FormField label="Jenis Kamar">
			<select class="select w-full" name="room_type" required>
				{
					ROOM_TYPES.map((t) => (
						<option value={t}>{ROOM_TYPE_LABELS[t]}</option>
					))
				}
			</select>
		</FormField>
		<FormField label="Harga Sewa / Bulan (Rp)">
			<input
				class="input w-full"
				name="monthly_price"
				type="number"
				placeholder="800000"
				required
			/>
		</FormField>
		<div
			class="flex items-center gap-3 rounded-lg border border-base-200 bg-base-200/40 p-3"
		>
			<input
				class="toggle toggle-success"
				id="kamar-aktif"
				name="is_active"
				type="checkbox"
				checked
			/>
			<label class="cursor-pointer text-sm font-semibold" for="kamar-aktif"
				>Kamar langsung diaktifkan (siap huni)</label
			>
		</div>
	</ModalForm>
</Modal>
