---
import { formatDate } from "@e-kos/utilities/date";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	chatbotQuerySchema,
	DIRECTION_LABELS,
	fetchChatbotLogs,
} from "../_data";

const params = Astro.locals.parseQuery(chatbotQuerySchema);

const chatbotLogs = await fetchChatbotLogs(params);

const filterParts: string[] = [];
if (params.direction) {
	filterParts.push(`Arah: ${DIRECTION_LABELS[params.direction]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}

const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Percakapan Chatbot" subtitle={subtitle}>
	<table>
		<thead>
			<tr>
				<th class="w-[18%]">Waktu</th>
				<th class="w-[18%]">Penghuni</th>
				<th class="w-[10%]">Kamar</th>
				<th class="w-[10%]">Arah</th>
				<th class="w-[44%]">Isi Pesan</th>
			</tr>
		</thead>
		<tbody>
			{
				chatbotLogs.map((row) => (
					<tr>
						<td class="font-mono text-[10px] whitespace-nowrap">
							{formatDate(row.sentAt, "DD MMM YYYY HH:mm")}
						</td>
						<td class="font-semibold">{row.tenantName}</td>
						<td class="text-center font-mono">{row.roomNumber}</td>
						<td class="text-center">{DIRECTION_LABELS[row.direction]}</td>
						<td class="max-w-[300px] break-words">{row.message}</td>
					</tr>
				))
			}
		</tbody>
	</table>
</ReportLayout>
