---
import { NOTIFICATION_TYPES } from "@e-kos/database";

import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import FormResult from "~/components/form/form-result.astro";
import Alert from "~/components/ui/alert.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import {
	fetchNotifications,
	NOTIFICATION_STATUS_BADGES,
	NOTIFICATION_TYPE_BADGES,
	NOTIFICATION_TYPE_LABELS,
	notificationQuerySchema,
} from "./_data";

const params = Astro.locals.parseQuery(notificationQuerySchema);

const filteredNotifications = await fetchNotifications(params, {
	useQuery: true,
});
---

<FormResult
	actionResults={[
		{
			action: actions.manage.notifications.send,
			title: "Kirim Notifikasi",
			getDescription: () => "Notifikasi berhasil dikirimkan via WhatsApp!",
		},
	]}
/>

<DashboardLayout
	title="Manajemen Notifikasi"
	description="Riwayat dan pengiriman notifikasi (tagihan, pengingat, komplain) via WhatsApp Chatbot"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/report/notifications/report/download${Astro.url.search}`}
			download
		>
			<Icon name="lucide:download" /> PDF
		</a>
	</Fragment>
	<Alert
		type="info"
		title="Sistem Otomatisasi Aktif"
		description="Sistem mengirimkan pesan pengingat tagihan (WhatsApp) otomatis setiap hari pukul 07.00 WIB untuk penyewa yang memiliki tagihan belum lunas mendekati H-3 jatuh tempo."
	/>

	<FilterToolbar name="notifications" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="notifications"
				groups={[
					{
						title: "Tipe Notifikasi",
						name: "type",
						options: NOTIFICATION_TYPES.map((type) => ({
							value: type,
							label: NOTIFICATION_TYPE_LABELS[type],
							checked: params.type === type,
						})),
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-notifications"
				placeholder="Cari nama penghuni..."
			/>
		</Fragment>
	</FilterToolbar>

	<!-- Content Wrapper for HTMX -->
	<div
		class="overflow-x-auto rounded-box border border-base-300 shadow-sm"
		id="notifications-content-wrapper"
	>
		<table class="table w-full table-sm">
			<thead>
				<tr>
					<th>Waktu Kirim</th>
					<th>Penghuni</th>
					<th>Invoice</th>
					<th>Tipe</th>
					<th>Status</th>
				</tr>
			</thead>
			<tbody id="notifications-table-body">
				{
					filteredNotifications.map(
						({ time, tenantName, roomNumber, invoiceNumber, type, status }) => (
							<tr>
								<td class="font-mono text-xs">
									{formatDate(time, "DD MMM YYYY HH:mm")}
								</td>
								<td class="flex items-center gap-2 text-sm font-semibold">
									{tenantName}
									<span class="badge font-mono badge-xs badge-neutral">
										{roomNumber}
									</span>
								</td>
								<td class="font-mono text-xs font-semibold">{invoiceNumber}</td>
								<td>
									<span
										class:list={[
											"badge badge-sm font-bold",
											NOTIFICATION_TYPE_BADGES[
												type as keyof typeof NOTIFICATION_TYPE_BADGES
											],
										]}
									>
										{
											NOTIFICATION_TYPE_LABELS[
												type as keyof typeof NOTIFICATION_TYPE_LABELS
											]
										}
									</span>
								</td>
								<td>
									<span
										class:list={[
											"badge badge-sm font-bold",
											NOTIFICATION_STATUS_BADGES[
												status as keyof typeof NOTIFICATION_STATUS_BADGES
											],
										]}
									>
										{status}
									</span>
								</td>
							</tr>
						),
					)
				}
			</tbody>
		</table>
	</div>
</DashboardLayout>
