---
import { db } from "@e-kos/database";

import DetailModal from "~/components/modal/detail-modal.astro";
import Icon from "~/components/ui/icon.astro";
import NotFound from "~/components/ui/not-found.astro";
import { formatDate } from "~/lib/date";
import { formatCurrency } from "~/lib/transforms";

export const partial = true;

const tenant = await db.query.tenants.findFirst({
	columns: {
		id: true,
		fullName: true,
		phoneNumber: true,
		originRegion: true,
	},
	where: { id: Number(Astro.params.id) },
});

const tenantLeases = tenant
	? await db.query.leases.findMany({
			where: { tenantId: tenant.id },
			with: { room: true },
			orderBy: { startDate: "desc" },
		})
	: [];

const activeLease = tenantLeases.find((lease) => lease.isActive) ?? null;
const pastLeases = tenantLeases.filter((lease) => !lease.isActive);

if (!tenant) Astro.response.status = 404;
---

<DetailModal
	id="detail_tenant"
	title={`Detail ${tenant?.fullName ?? ""}`}
	icon="lucide:user"
	modalClass="max-w-lg"
>
	{
		tenant ? (
			<>
				<div class="grid grid-cols-2 gap-x-4 gap-y-2.5 border-b border-base-200 pb-4 text-sm">
					<span class="font-semibold text-base-content/60">Nama Lengkap:</span>
					<span class="font-bold">{tenant.fullName}</span>

					<span class="font-semibold text-base-content/60">No. HP:</span>
					<span class="font-mono">+{tenant.phoneNumber ?? "-"}</span>

					<span class="font-semibold text-base-content/60">Daerah Asal:</span>
					<span>{tenant.originRegion ?? "-"}</span>

					<span class="font-semibold text-base-content/60">Kamar:</span>
					<span class="font-mono font-bold">
						{activeLease?.room?.roomNumber ?? (
							<span class="text-base-content/40 italic">Tidak ada</span>
						)}
					</span>

					<span class="font-semibold text-base-content/60">
						Tanggal Mulai Sewa:
					</span>
					<span>{activeLease ? formatDate(activeLease.startDate) : "-"}</span>

					<span class="font-semibold text-base-content/60">
						Tanggal Selesai Sewa:
					</span>
					<span>
						{activeLease?.endDate ? formatDate(activeLease.endDate) : "-"}
					</span>
				</div>

				{pastLeases.length > 0 && (
					<div class="mt-4">
						<h4 class="mb-2 flex items-center gap-1.5 text-sm font-bold text-base-content/80">
							<Icon name="lucide:file-text" size="size-4" />
							Riwayat Sewa
						</h4>
						<div class="max-h-48 divide-y divide-base-200 overflow-y-auto">
							{pastLeases.map((lease) => (
								<div class="flex items-center justify-between py-2.5 text-xs">
									<div class="flex flex-col gap-0.5">
										<div class="flex items-center gap-2">
											<span class="badge font-mono badge-xs badge-neutral">
												{lease.room?.roomNumber ?? "—"}
											</span>
											<span class="font-mono text-xs">
												{formatCurrency(lease.room?.monthlyPrice ?? 0)}
											</span>
										</div>
										<span class="text-base-content/60">
											{formatDate(lease.startDate)} s/d{" "}
											{formatDate(lease.endDate)}
										</span>
									</div>
									<div class="flex flex-col items-end gap-1">
										<span class="badge badge-xs font-bold opacity-60 badge-neutral">
											Selesai
										</span>
									</div>
								</div>
							))}
						</div>
					</div>
				)}
			</>
		) : (
			<NotFound label="Penghuni" />
		)
	}
</DetailModal>
