---
import { formatDate } from "@indekos/utilities/date";
import { formatCurrency } from "@indekos/utilities/transforms";

import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import ActionsMenu from "~/components/ui/actions-menu.astro";
import IconLoader from "~/components/ui/icon-loader.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { createActionResult } from "~/lib/form-result";
import { paginateArray } from "~/lib/query";
import Pagination from "~/components/data/pagination.astro";
import {
	fetchTransactions,
	getTransactionStats,
	INVOICE_STATUS,
	INVOICE_STATUS_BADGES,
	INVOICE_STATUS_LABELS,
	transactionQuerySchema,
} from "./_data";

Astro.locals.actionResults.push(
	createActionResult(
		actions.manage.invoices.generatePaymentLink,
		"Buat link bayar",
		(d) =>
			`Link pembayaran berhasil dibuat! <a href="${d.paymentUrl}" class="link link-primary" target="_blank">Buka Pembayaran</a>`,
	),
	createActionResult(
		actions.manage.invoices.markAsPaid,
		"Tandai Lunas",
		() => "Berhasil menandai invoice sebagai lunas!",
	),
);

const params = Astro.locals.parseQuery(transactionQuerySchema);

const allInvoices = await fetchTransactions(params);
const transactionStats = getTransactionStats(allInvoices);
const { items: invoices, ...pagination } = paginateArray(
	allInvoices,
	params.page,
	params.pageSize,
);
---

<DashboardLayout
	title="Laporan Transaksi"
	description="Rekapitulasi tagihan dan riwayat pembayaran sewa bulanan penghuni"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			id="transactions-print"
			href={`/dashboard/report/transactions/report/download${Astro.url.search}`}
			hx-swap-oob="true"
			download
		>
			<Icon name="lucide:download" /> PDF
		</a>
	</Fragment>

	<FilterToolbar name="transactions" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="transactions"
				groups={[
					{
						title: "Status",
						name: "status",
						options: INVOICE_STATUS.map((status) => ({
							value: status,
							label: INVOICE_STATUS_LABELS[status],
							checked: params.status === status,
						})),
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-transactions"
				placeholder="Cari nama/No. Kamar..."
			/>
		</Fragment>
	</FilterToolbar>

	<Stats stats={transactionStats} />

	<div class="contents" id="transactions-content-wrapper">
		<div class="overflow-x-auto rounded-box border border-base-300 shadow-sm">
			<table class="table w-full table-zebra table-sm">
				<thead>
					<tr>
						<th>No. Invoice</th>
						<th>Penghuni</th>
						<th>Kamar</th>
						<th>Nominal</th>
						<th>Jatuh Tempo</th>
						<th>Status</th>
						<th>Ref. Gateway</th>
						<th>Aksi</th>
					</tr>
				</thead>
				<tbody>
					{
						invoices.map(
							({
								id,
								invoiceNumber,
								tenantName,
								roomNumber,
								amount,
								dueDate,
								status,
								duitkuReference,
								paymentUrl,
							}) => (
								<tr id={`invoice-${id}`}>
									<td class="font-mono text-xs">{invoiceNumber}</td>
									<td>{tenantName}</td>
									<td>
										<span class="badge font-mono badge-neutral">
											{roomNumber}
										</span>
									</td>
									<td class="font-mono">{formatCurrency(amount)}</td>
									<td class="font-mono text-xs">{formatDate(dueDate)}</td>
									<td>
										<span
											class:list={[
												"badge badge-sm font-bold",
												INVOICE_STATUS_BADGES[status],
											]}
										>
											{INVOICE_STATUS_LABELS[status]}
										</span>
									</td>
									<td
										class="max-w-32 truncate font-mono text-xs"
										title={duitkuReference ?? undefined}
									>
										{duitkuReference ?? "-"}
									</td>
									<td>
										{duitkuReference || status === "paid" ? (
											<div class="flex items-center gap-1">
												<a
													class="btn w-24 btn-outline btn-success btn-xs"
													href={`/invoice/${id}`}
													target="_blank"
												>
													<Icon name="lucide:external-link" size="size-3.5" />{" "}
													Invoice
												</a>

												{Astro.locals.user?.allowEdit && status !== "paid" && (
													<ActionsMenu id={id} menuClass="w-36">
														<li>
															<button
																onclick={`navigator.clipboard.writeText("${paymentUrl}")`}
															>
																<Icon
																	name="lucide:clipboard-list"
																	size="size-3.5"
																/>
																Salin
															</button>
														</li>
														<li>
															<form
																hx-post={actions.manage.invoices.markAsPaid}
																class="hidden"
																id={`mark_as_paid_${id}`}
																hx-indicator="next button"
																hx-select={`#invoice-${id}`}
																hx-swap="outerHTML transition:true"
																hx-target={`#invoice-${id}`}
																action={actions.manage.invoices.markAsPaid}
																method="post"
															>
																<input
																	name="invoice_id"
																	type="hidden"
																	value={id}
																/>
															</form>

															<button type="submit" form={`mark_as_paid_${id}`}>
																<IconLoader name="lucide:circle-check" />
																Tandai Lunas
															</button>
														</li>
													</ActionsMenu>
												)}
											</div>
										) : (
											<div class="flex items-center gap-1">
												{Astro.locals.user?.allowEdit && (
													<>
														<form
															hx-post={
																actions.manage.invoices.generatePaymentLink
															}
															class="hidden"
															id={`generate_link_${id}`}
															hx-indicator="next button"
															hx-select={`#invoice-${id}`}
															hx-swap="outerHTML transition:true"
															hx-target={`#invoice-${id}`}
															action={
																actions.manage.invoices.generatePaymentLink
															}
															method="post"
														>
															<input
																name="invoice_id"
																type="hidden"
																value={id}
															/>
														</form>

														<button
															class="btn w-24 btn-outline btn-primary btn-xs"
															type="submit"
															form={`generate_link_${id}`}
														>
															<IconLoader name="lucide:link" size="size-3.5" />
															Generate
														</button>
													</>
												)}

												{Astro.locals.user?.allowEdit && (
													<ActionsMenu id={id} menuClass="w-36">
														<li>
															<form
																hx-post={actions.manage.invoices.markAsPaid}
																class="contents"
																id={`mark_as_paid_${id}`}
																hx-select={`#invoice-${id}`}
																hx-swap="outerHTML transition:true"
																hx-target={`#invoice-${id}`}
																action={actions.manage.invoices.markAsPaid}
																method="post"
															>
																<li>
																	<input
																		name="invoice_id"
																		type="hidden"
																		value={id}
																	/>
																</li>
															</form>

															<button type="submit" form={`mark_as_paid_${id}`}>
																<Icon name="lucide:circle-check" />
																Tandai Lunas
															</button>
														</li>
													</ActionsMenu>
												)}
											</div>
										)}
									</td>
								</tr>
							),
						)
					}
				</tbody>
			</table>
		</div>

		<Pagination
			baseUrl="/dashboard/report/transactions"
			filterClass="filter-transactions"
			{...pagination}
		/>
	</div>
</DashboardLayout>
