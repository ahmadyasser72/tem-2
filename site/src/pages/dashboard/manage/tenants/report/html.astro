---
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import { fetchTenants, tenantsQuerySchema } from "../_data";

const params = Astro.locals.parseQuery(
	tenantsQuerySchema.omit({ query: true }),
);

const tenants = await fetchTenants(params);

let subtitle = "Semua penghuni";
if (params.status === "active") subtitle = "Status: Aktif";
else if (params.status === "completed") subtitle = "Status: Selesai";
---

<ReportLayout title="Daftar Penghuni Aktif" subtitle={subtitle}>
	<table>
		<thead>
			<tr>
				<th style="width: 5%; text-align: center;">No</th>
				<th style="width: 22%;">Nama Lengkap</th>
				<th style="width: 15%;">No. HP</th>
				<th style="width: 10%;">Kamar</th>
				<th style="width: 15%;">Awal Sewa</th>
				<th style="width: 15%;">Akhir Sewa</th>
				<th style="width: 10%;">Status</th>
			</tr>
		</thead>
		<tbody>
			{
				tenants.map(
					(
						{ fullName, phoneNumber, roomNumber, startDate, endDate, isActive },
						idx,
					) => (
						<tr>
							<td style="text-align: center; font-family: 'Courier New', monospace;">
								{idx + 1}
							</td>
							<td>{fullName}</td>
							<td style="font-family: 'Courier New', monospace;">
								+{phoneNumber}
							</td>
							<td style="text-align: center; font-family: 'Courier New', monospace;">
								{roomNumber}
							</td>
							<td style="font-family: 'Courier New', monospace;">
								{formatDate(startDate)}
							</td>
							<td style="font-family: 'Courier New', monospace;">
								{formatDate(endDate)}
							</td>
							<td style="text-align: center;">
								{isActive ? "Aktif" : "Selesai"}
							</td>
						</tr>
					),
				)
			}
		</tbody>
		<tfoot>
			<tr>
				<td
					colspan="7"
					style="border: 1px solid black; padding: 8px; font-weight: 700; background: #f3f4f6;"
				>
					Total penghuni: {tenants.length}
				</td>
			</tr>
		</tfoot>
	</table>
</ReportLayout>
