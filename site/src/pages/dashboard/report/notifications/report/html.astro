---
import { formatDate } from "@e-kos/utilities/date";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	fetchNotifications,
	NOTIFICATION_TYPE_LABELS,
	notificationQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(
	notificationQuerySchema.omit({ query: true }),
);

const notifications = await fetchNotifications(params);

const filterParts: string[] = [];
if (params.type) {
	filterParts.push(`Jenis: ${NOTIFICATION_TYPE_LABELS[params.type]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Riwayat Notifikasi" subtitle={subtitle}>
	<table>
		<thead>
			<tr>
				<th style="width: 22%;">Waktu Kirim</th>
				<th style="width: 28%;">Penghuni</th>
				<th style="width: 18%;">No. Invoice</th>
				<th style="width: 16%;">Jenis</th>
				<th style="width: 16%;">Status</th>
			</tr>
		</thead>
		<tbody>
			{
				notifications.map(
					({
						createdAt,
						tenantName,
						roomNumber,
						invoiceNumber,
						type,
						status,
					}) => (
						<tr>
							<td style="font-family: 'Courier New', monospace; font-size: 10px;">
								{formatDate(createdAt, "DD MMM YYYY HH:mm")}
							</td>
							<td>
								{tenantName}
								<span style="font-family: 'Courier New', monospace; font-size: 10px; opacity: 0.6; margin-left: 4px;">
									({roomNumber})
								</span>
							</td>
							<td style="font-family: 'Courier New', monospace; font-weight: 600;">
								{invoiceNumber}
							</td>
							<td>{NOTIFICATION_TYPE_LABELS[type]}</td>
							<td style="font-weight: 600;">{status}</td>
						</tr>
					),
				)
			}
		</tbody>
		<tfoot>
			<tr>
				<td
					colspan="5"
					style="border: 1px solid black; padding: 8px; font-weight: 700; background: #f3f4f6;"
				>
					Total notifikasi: {notifications.length}
				</td>
			</tr>
		</tfoot>
	</table>
</ReportLayout>
