---
import { db } from "@e-kos/database";

import ReportTableEmpty from "~/components/data/report-table-empty.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import {
	AUDIT_ACTION_LABELS,
	auditQuerySchema,
	fetchAuditLogs,
} from "../_data";

const params = Astro.locals.parseQuery(auditQuerySchema);

const rawUserId = Astro.url.searchParams.get("userId");
const userId = rawUserId ? Number(rawUserId) : undefined;

const targetUser =
	userId != null && !Number.isNaN(userId)
		? await db.query.users.findFirst({ where: { id: userId } })
		: null;

const rows = await fetchAuditLogs(params, { userId, showSystem: true });

const filterParts: string[] = [];
if (targetUser) {
	filterParts.push(
		`Pengguna: ${targetUser.displayName ?? targetUser.username}`,
	);
}
if (params.action) {
	filterParts.push(`Aksi: ${AUDIT_ACTION_LABELS[params.action]}`);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Aktivitas Pengguna" subtitle={subtitle}>
	{
		targetUser && (
			<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-bottom: 16px; font-size: 11px; padding: 8px; border: 1px solid black; background: #fafafa;">
				<div>
					<span style="font-weight: 700; opacity: 0.6;">Nama</span>
					<div style="font-weight: 700; margin-top: 2px;">
						{targetUser.displayName ?? targetUser.username}
					</div>
				</div>
				<div>
					<span style="font-weight: 700; opacity: 0.6;">Peran</span>
					<div style="font-weight: 700; margin-top: 2px; text-transform: capitalize;">
						{targetUser.role}
					</div>
				</div>
			</div>
		)
	}

	<table>
		<thead>
			<tr>
				<th style="width: 5%; text-align: center;">No.</th>
				<th style="width: 20%;">Waktu Kejadian</th>
				<th style="width: 18%;">Pengguna</th>
				<th style="width: 14%;">Jenis Aksi</th>
				<th style="width: 28%;">Tabel Target</th>
				<th style="width: 15%;">ID Record</th>
			</tr>
		</thead>
		<tbody>
			{
				rows.length === 0 ? (
					<ReportTableEmpty
						colspan={6}
						message="Tidak ada data audit log untuk filter yang dipilih."
					/>
				) : (
					rows.map((row, idx) => (
						<tr>
							<td style="text-align: center; font-size: 10px;">{idx + 1}</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px;">
								{formatDate(row.time, "DD MMM YYYY HH:mm")}
							</td>
							<td>{row.displayName}</td>
							<td style="font-weight: 700; text-transform: uppercase;">
								{row.action}
							</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px;">
								{row.table}
							</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px; text-align: center;">
								{row.recordId ?? "-"}
							</td>
						</tr>
					))
				)
			}
		</tbody>
	</table>
</ReportLayout>
