---
import { formatCurrency } from "@e-kos/utilities/transforms";

import { sumBy } from "es-toolkit";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	fetchRooms,
	ROOM_STATUS_LABELS,
	ROOM_TYPE_LABELS,
	roomQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(roomQuerySchema.omit({ query: true }));

const rooms = await fetchRooms(params);
const total = rooms.length;
const occupied = sumBy(rooms, ({ isActive, tenantName }) =>
	isActive && tenantName ? 1 : 0,
);
const vacant = sumBy(rooms, ({ isActive, tenantName }) =>
	isActive && !tenantName ? 1 : 0,
);
const inactive = sumBy(rooms, ({ isActive }) => (!isActive ? 1 : 0));

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${ROOM_STATUS_LABELS[params.status]}`);
}
if (params.type) {
	filterParts.push(`Tipe: ${ROOM_TYPE_LABELS[params.type]}`);
}
const subtitle =
	filterParts.length > 0 ? filterParts.join(" | ") : "Semua kamar";
---

<ReportLayout title="Rekap Status Kamar" subtitle={subtitle}>
	<div class="mb-6 grid grid-cols-4 gap-3">
		<div class="border border-black p-3 text-center">
			<div class="text-[10px] font-bold tracking-[0.5px] uppercase opacity-60">
				Total Kamar
			</div>
			<div class="mt-1 text-xl font-bold">
				{total}
			</div>
		</div>
		<div class="border border-black p-3 text-center">
			<div class="text-[10px] font-bold tracking-[0.5px] uppercase opacity-60">
				Terisi
			</div>
			<div class="mt-1 text-xl font-bold">
				{occupied}
			</div>
		</div>
		<div class="border border-black p-3 text-center">
			<div class="text-[10px] font-bold tracking-[0.5px] uppercase opacity-60">
				Tersedia
			</div>
			<div class="mt-1 text-xl font-bold">
				{vacant}
			</div>
		</div>
		<div class="border border-black p-3 text-center">
			<div class="text-[10px] font-bold tracking-[0.5px] uppercase opacity-60">
				Nonaktif
			</div>
			<div class="mt-1 text-xl font-bold">
				{inactive}
			</div>
		</div>
	</div>

	<table>
		<thead>
			<tr>
				<th class="w-[20%]">No. Kamar</th>
				<th class="w-[15%]">Jenis</th>
				<th class="w-[22%]">Harga/Bulan</th>
				<th class="w-[15%]">Status</th>
				<th class="w-[28%]">Penghuni</th>
			</tr>
		</thead>
		<tbody>
			{
				rooms.map(
					({ roomNumber, roomType, monthlyPrice, isActive, tenantName }) => {
						const status = !isActive
							? "Nonaktif"
							: tenantName
								? "Terisi"
								: "Kosong";
						return (
							<tr>
								<td class="font-mono">{roomNumber}</td>
								<td>{ROOM_TYPE_LABELS[roomType]}</td>
								<td class="text-right font-mono">
									{formatCurrency(monthlyPrice)}
								</td>
								<td>{status}</td>
								<td>{tenantName ?? "-"}</td>
							</tr>
						);
					},
				)
			}
		</tbody>
	</table>
</ReportLayout>
