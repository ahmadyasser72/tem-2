---
import { db } from "@indekos/database";
import { formatDate } from "@indekos/utilities/date";

import Modal from "~/components/modal/modal.astro";
import Icon from "~/components/ui/icon.astro";
import NotFound from "~/components/ui/not-found.astro";
import { formatMessageMarkdown } from "../../../../log/chatbot/_data";

export const partial = true;

const tenantId = Number(Astro.params.id);

const tenant = await db.query.tenants.findFirst({
	where: { id: tenantId },
	with: {
		lease: { with: { room: true } },
		chatbotLogs: true,
	},
});

if (!tenant) {
	Astro.response.status = 404;
}
---

<Modal
	id="chat"
	title={`Chat ${tenant?.fullName ?? "Penghuni"}`}
	icon="lucide:message-square"
>
	{
		tenant ? (
			<div class="space-y-4">
				<div class="mb-4 border-b border-base-200 pb-3 text-sm">
					<span class="font-bold">Kamar:</span>
					<span class="ml-2">{tenant.lease?.room?.roomNumber ?? "-"}</span>
				</div>

				<div class="chat-container max-h-96 space-y-2 overflow-y-auto">
					{tenant.chatbotLogs.length > 0 ? (
						tenant.chatbotLogs.map(({ direction, message, sentAt }) => (
							<div
								class:list={[
									"chat",
									direction === "incoming" ? "chat-start" : "chat-end",
								]}
							>
								<div class="avatar chat-image">
									<div class="size-8 rounded-full">
										{direction === "incoming" ? (
											<div class="flex size-full items-center justify-center bg-base-300">
												<Icon
													class="opacity-70"
													name="lucide:user"
													size="size-5"
												/>
											</div>
										) : (
											<div class="flex size-full items-center justify-center bg-primary text-primary-content">
												<span class="text-xs font-bold">KU</span>
											</div>
										)}
									</div>
								</div>
								<div class="chat-header">
									{direction === "incoming" ? tenant.fullName : "Chatbot"}
									<time class="text-xs opacity-50">
										{formatDate(sentAt, "HH:mm")}
									</time>
								</div>
								<div
									class:list={[
										"chat-bubble max-w-xs text-sm",
										direction === "incoming"
											? "chat-bubble-info"
											: "chat-bubble-primary",
									]}
									set:html={formatMessageMarkdown(message)}
								/>
							</div>
						))
					) : (
						<div class="py-8 text-center text-sm opacity-50">
							Tidak ada pesan
						</div>
					)}
				</div>
			</div>
		) : (
			<NotFound label="Penghuni" />
		)
	}
</Modal>
