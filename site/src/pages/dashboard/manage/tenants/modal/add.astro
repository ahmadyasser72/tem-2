---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import { ROOM_TYPE_LABELS } from "../../rooms/_data";

export const partial = true;

const availableRooms = await db.query.rooms.findMany({
	columns: { id: true, roomNumber: true, roomType: true, isActive: true },
	with: { lease: true },
	where: { isActive: true, lease: { isActive: false } },
});
---

<Modal id="add_tenant" title="Tambah Kontrak Sewa" icon="lucide:user-plus">
	<ModalForm
		action={actions.manage.tenants.add}
		modalId="add_tenant"
		submitLabel="Simpan Kontrak"
		target="#form_result, #tenants-content-wrapper"
	>
		<FormField label="Nama Lengkap">
			<input
				class="input w-full"
				name="full_name"
				type="text"
				placeholder="Nama sesuai KTP..."
				required
			/>
		</FormField>
		<FormField label="Nomor HP (WhatsApp)">
			<label class="input w-full">
				<span class="label">+62</span>
				<input
					name="phone_number"
					type="text"
					placeholder="81234567890..."
					required
				/>
			</label>
		</FormField>
		<FormField label="Daerah Asal">
			<input
				class="input w-full"
				name="origin_region"
				type="text"
				placeholder="Opsional (misal: Bandung, Surabaya...)"
			/>
		</FormField>

		<div class="divider text-xs tracking-wider uppercase opacity-60">
			Kontrak Sewa
		</div>

		<FormField
			helperText="Hanya menampilkan kamar dengan status kosong/tersedia"
			label="Pilih Kamar Tersedia"
		>
			<select class="select w-full" name="room_id" required>
				<option value="" disabled selected>Pilih nomor kamar...</option>
				{
					availableRooms.map(({ id, roomNumber, roomType }) => (
						<option value={id}>
							{roomNumber} – {ROOM_TYPE_LABELS[roomType]} (Tersedia)
						</option>
					))
				}
			</select>
		</FormField>

		<div class="grid grid-cols-2 gap-3">
			<FormField label="Tanggal Mulai">
				<input class="input w-full" name="start_date" type="date" required />
			</FormField>
			<FormField label="Tanggal Selesai">
				<input class="input w-full" name="end_date" type="date" />
			</FormField>
		</div>
	</ModalForm>
</Modal>
