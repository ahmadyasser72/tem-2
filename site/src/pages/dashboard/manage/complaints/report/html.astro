---
import ReportTableEmpty from "~/components/data/report-table-empty.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import {
	COMPLAINT_STATUS_LABELS,
	complaintQuerySchema,
	fetchComplaints,
	getComplaintStats,
} from "../_data";

const params = Astro.locals.parseQuery(complaintQuerySchema);

// Stats from all complaints (no filter)
const allComplaints = await fetchComplaints(params);
const stats = getComplaintStats(allComplaints);

// Filtered data with period
const rowsData = await fetchComplaints(params, { usePeriod: true });

const rows = rowsData.map((c, idx) => ({
	no: idx + 1,
	tenantName: c.tenantName,
	roomNumber: c.roomNumber,
	description: c.description,
	statusLabel:
		COMPLAINT_STATUS_LABELS[c.status as keyof typeof COMPLAINT_STATUS_LABELS] ??
		c.status,
	createdAt: c.createdAt,
	resolvedByUserName: c.resolvedByUserName ?? "-",
}));

// Build subtitle
const subtitleParts: string[] = [];
if (params.status) {
	subtitleParts.push(
		`Status: ${COMPLAINT_STATUS_LABELS[params.status as keyof typeof COMPLAINT_STATUS_LABELS]}`,
	);
}
if (params.from) subtitleParts.push(`Dari: ${formatDate(params.from)}`);
if (params.to) subtitleParts.push(`Sampai: ${formatDate(params.to)}`);
const subtitle =
	subtitleParts.length > 0 ? subtitleParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Komplain Penghuni" subtitle={subtitle}>
	<!-- Stats -->
	<div
		style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-bottom:16px;"
	>
		{
			stats.map((s) => (
				<div style="border:1px solid black;padding:8px 12px;text-align:center;">
					<p style="font-size:10px;font-weight:400;margin-bottom:4px;">
						{s.label}
					</p>
					<p style="font-size:18px;font-weight:700;">{s.value}</p>
				</div>
			))
		}
	</div>

	<!-- Section title -->
	<p style="font-size:12px;font-weight:700;margin-bottom:8px;">
		Daftar Komplain
	</p>

	<!-- Table -->
	<table>
		<thead>
			<tr>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>No.</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Penghuni</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Kamar</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Deskripsi</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Status</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Tanggal Lapor</th
				>
				<th
					style="background:#f3f4f6;border:1px solid black;padding:6px 8px;font-size:10px;font-weight:700;text-align:left;"
					>Ditangani Oleh</th
				>
			</tr>
		</thead>
		<tbody>
			{
				rows.length === 0 && (
					<ReportTableEmpty colspan={7} message="Tidak ada data komplain." />
				)
			}
			{
				rows.map((row) => (
					<tr>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
							{row.no}
						</td>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;">
							{row.tenantName}
						</td>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
							{row.roomNumber}
						</td>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;">
							{row.description}
						</td>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
							{row.statusLabel}
						</td>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;text-align:center;">
							{formatDate(row.createdAt)}
						</td>
						<td style="border:1px solid black;padding:6px 8px;font-size:10px;">
							{row.resolvedByUserName}
						</td>
					</tr>
				))
			}
		</tbody>
	</table>
</ReportLayout>
