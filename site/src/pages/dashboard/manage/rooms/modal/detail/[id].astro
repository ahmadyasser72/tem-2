---
import { db } from "@indekos/database";
import { formatDate } from "@indekos/utilities/date";
import { formatCurrency } from "@indekos/utilities/transforms";

import DetailModal from "~/components/modal/detail-modal.astro";
import Icon from "~/components/ui/icon.astro";
import NotFound from "~/components/ui/not-found.astro";
import { ROOM_FACILITIES, ROOM_TYPE_LABELS } from "../../_data";

export const partial = true;

const room = await db.query.rooms.findFirst({
	columns: {
		id: true,
		roomNumber: true,
		roomType: true,
		monthlyPrice: true,
		isActive: true,
	},
	where: { id: Number(Astro.params.id) },
	with: {
		lease: {
			with: { tenant: true },
		},
		leaseHistory: {
			with: { tenant: true },
			orderBy: { startDate: "desc" },
		},
	},
});

if (!room) Astro.response.status = 404;
---

<DetailModal
	id="detail_room"
	title={`Detail Kamar ${room?.roomNumber ?? ""}`}
	icon="lucide:house"
	modalClass="max-w-lg"
>
	{
		room ? (
			<>
				<div class="grid grid-cols-2 gap-x-4 gap-y-2.5 border-b border-base-200 pb-4 text-sm">
					<span class="font-semibold text-base-content/60">Nomor Kamar:</span>
					<span class="font-bold">{room.roomNumber}</span>

					<span class="font-semibold text-base-content/60">Jenis Kamar:</span>
					<span>{ROOM_TYPE_LABELS[room.roomType]}</span>

					<span class="font-semibold text-base-content/60">Fasilitas:</span>
					<div class="flex flex-wrap gap-1">
						{(ROOM_FACILITIES[room.roomType] ?? []).map((f) => (
							<span class="badge badge-outline badge-sm">{f}</span>
						))}
					</div>

					<span class="font-semibold text-base-content/60">Harga/Bulan:</span>
					<span class="font-mono font-bold">
						{formatCurrency(room.monthlyPrice)}
					</span>

					<span class="font-semibold text-base-content/60">Status:</span>
					<span
						class:list={[
							"badge badge-sm",
							room.isActive ? "badge-success" : "badge-ghost",
						]}
					>
						{room.isActive ? "Aktif" : "Tidak Aktif"}
					</span>

					<span class="font-semibold text-base-content/60">Penghuni:</span>
					<span>
						{room.lease?.tenant?.fullName ?? (
							<span class="text-base-content/40 italic">Kosong</span>
						)}
					</span>

					{room.lease && (
						<>
							<span />
							<span class="-mt-2 text-xs text-base-content/60">
								{formatDate(room.lease.startDate)} s/d{" "}
								{room.lease.endDate
									? formatDate(room.lease.endDate)
									: "sekarang"}
							</span>
						</>
					)}
				</div>

				<div class="mt-4">
					<h4 class="mb-2 flex items-center gap-1.5 text-sm font-bold text-base-content/80">
						<Icon name="lucide:file-text" />
						Riwayat Sewa
					</h4>
					{room.leaseHistory.length === 0 ? (
						<p class="py-2 text-xs text-base-content/50 italic">
							Belum ada riwayat sewa.
						</p>
					) : (
						<div class="max-h-48 divide-y divide-base-200 overflow-y-auto">
							{room.leaseHistory.map((lease) => (
								<div class="flex items-center justify-between py-2.5 text-xs">
									<div class="flex flex-col gap-0.5">
										<div class="flex items-center gap-2">
											<span class="font-semibold">
												{lease.tenant?.fullName ?? "—"}
											</span>
										</div>
										<span class="text-base-content/60">
											{formatDate(lease.startDate)} s/d{" "}
											{formatDate(lease.endDate)}
										</span>
									</div>
									<div class="flex flex-col items-end gap-1">
										<span
											class:list={[
												"badge badge-xs font-bold",
												lease.isActive
													? "badge-success"
													: "opacity-60 badge-neutral",
											]}
										>
											{lease.isActive ? "Aktif" : "Selesai"}
										</span>
									</div>
								</div>
							))}
						</div>
					)}
				</div>
			</>
		) : (
			<NotFound label="Kamar" />
		)
	}
</DetailModal>
