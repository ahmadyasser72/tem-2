---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import Icon from "~/components/icon.astro";
import { formatDate } from "~/lib/date";

export const partial = true;

const log = await db.query.chatbotMessages.findFirst({
	where: { id: Number(Astro.params.id) },
	with: {
		tenant: {
			with: {
				leases: {
					where: { isActive: true },
					with: {
						room: true,
					},
				},
			},
		},
	},
});

const activeLease = log?.tenant?.leases?.[0];
const chatbotLog = log
	? {
			id: log.id,
			time: log.sentAt,
			tenantName: log.tenant?.fullName ?? "-",
			roomNumber: activeLease?.room?.roomNumber ?? "-",
			direction: log.direction === "incoming" ? "Masuk" : "Keluar",
			message: log.message,
		}
	: null;

if (!log) Astro.response.status = 404;
---

<dialog class="modal" id="delete_chatbot_modal">
	{
		chatbotLog ? (
			<div class="modal-box">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>

				<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
					<Icon class="text-primary" name="line-md:chat" size="size-6" />
					Hapus log chat berikut?
				</h3>

				<div class="border-base-200 grid grid-cols-2 gap-2 border-b pb-4 text-sm">
					<span class="font-bold">Penghuni:</span>
					<span>
						{chatbotLog.tenantName} (Kamar {chatbotLog.roomNumber})
					</span>
					<span class="font-bold">Arah:</span>
					<span>{chatbotLog.direction}</span>
					<span class="font-bold">Waktu:</span>
					<span>{formatDate(chatbotLog.time, "DD MMM YYYY HH:mm:ss")}</span>
				</div>

				<div class="mt-4 text-sm">
					<span class="mb-1 block font-bold">Isi Pesan:</span>
					<p class="bg-base-200 border-base-300 max-h-32 overflow-y-auto rounded border p-3 text-xs leading-relaxed wrap-break-word whitespace-pre-wrap">
						{chatbotLog.message}
					</p>
				</div>

				<form
					hx-post={actions.manage.chatbot.remove}
					class="hidden"
					id="delete_chatbot_form"
					hx-on--after-request="event.detail.successful && delete_chatbot_modal.close()"
					hx-select-oob="#form_result, #chatbot-table-body"
					hx-swap="none transition:true"
					action={actions.manage.chatbot.remove}
					method="post"
				>
					<input name="id" type="hidden" value={chatbotLog.id} />
				</form>

				<p id="form_error" />

				<div class="modal-action">
					<form class="flex gap-2" method="dialog">
						<button class="btn btn-outline btn-sm">Batal</button>
						<button
							class="btn btn-error btn-sm"
							type="submit"
							form="delete_chatbot_form"
						>
							Hapus
						</button>
					</form>
				</div>
			</div>
		) : (
			<div class="modal-box">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>

				<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
					<Icon class="text-primary" name="line-md:chat" size="size-6" />
					Hapus Log Chat
				</h3>

				<p class="py-4">
					Log chat dengan ID: {Astro.params.id} tidak ditemukan.
				</p>
			</div>
		)
	}
	<form class="modal-backdrop" method="dialog">
		<button>close</button>
	</form>
</dialog>
