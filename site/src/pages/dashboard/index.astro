---
import { db } from "@e-kos/database";

import { sumBy } from "es-toolkit";

import Stats from "~/components/data/stats.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import { formatCurrency } from "~/lib/transforms";
import {
	COMPLAINT_STATUS_BADGES,
	COMPLAINT_STATUS_LABELS,
} from "~/pages/dashboard/manage/complaints/_data";

const now = new Date();

const allRooms = await db.query.rooms.findMany({
	with: {
		leases: {
			where: { isActive: true },
		},
	},
});
const totalRooms = allRooms.length;
const occupiedRooms = sumBy(allRooms, ({ leases }) =>
	leases.length > 0 ? 1 : 0,
);
const vacantRooms = sumBy(allRooms, ({ isActive, leases }) =>
	isActive && leases.length === 0 ? 1 : 0,
);

const allTenants = await db.query.tenants.findMany({
	with: {
		leases: {
			where: { isActive: true },
		},
	},
});
const activeTenantsCount = sumBy(allTenants, ({ leases }) =>
	leases.length > 0 ? 1 : 0,
);

const currentMonth = now.getMonth();
const currentYear = now.getFullYear();
const leasesEndingThisMonth = allTenants.reduce((count, tenant) => {
	const activeLease = tenant.leases[0];
	if (activeLease && activeLease.endDate) {
		const d = new Date(activeLease.endDate);
		if (d.getMonth() === currentMonth && d.getFullYear() === currentYear) {
			return count + 1;
		}
	}
	return count;
}, 0);

const unpaidInvoices = await db.query.invoices.findMany({
	where: { status: "unpaid" },
	with: {
		lease: {
			with: {
				tenant: true,
				room: true,
			},
		},
	},
	orderBy: { dueDate: "asc" },
});

const totalUnpaidAmount = sumBy(unpaidInvoices, (inv) => inv.amount);
const totalUnpaidCount = unpaidInvoices.length;

const pendingBills = unpaidInvoices.slice(0, 5).map((inv) => {
	const dueDate = new Date(inv.dueDate);
	const diffTime = dueDate.getTime() - now.getTime();
	const diffDays = Math.ceil(diffTime / (1000 * 60 * 60 * 24));
	const statusStr = diffDays <= 0 ? "Overdue" : `H-${diffDays}`;
	return {
		tenant: inv.lease?.tenant?.fullName ?? "-",
		room: inv.lease?.room?.roomNumber ?? "-",
		dueDate: inv.dueDate,
		status: statusStr,
		amount: inv.amount,
	};
});

const complaintsFromDb = await db.query.complaints.findMany({
	with: {
		tenant: {
			with: {
				leases: {
					where: { isActive: true },
					with: {
						room: true,
					},
				},
			},
		},
	},
	orderBy: { createdAt: "desc" },
	limit: 5,
});

const activeComplaintsCount = sumBy(complaintsFromDb, ({ status }) =>
	status !== "resolved" ? 1 : 0,
);

const recentComplaints = complaintsFromDb.map((complaint) => {
	const activeLease = complaint.tenant?.leases?.[0];
	return {
		title: complaint.description,
		room: activeLease?.room?.roomNumber
			? `Kamar ${activeLease.room.roomNumber}`
			: "Umum",
		tenant: complaint.tenant?.fullName ?? "-",
		date: complaint.createdAt,
		status: COMPLAINT_STATUS_LABELS[complaint.status] ?? "Terbuka",
		badge: COMPLAINT_STATUS_BADGES[complaint.status] ?? "badge-neutral",
	};
});

const user = Astro.locals.user;
const showTransactionsLink = user?.role !== "admin";
const showComplaintsLink = user?.role === "staff";

const stats = [
	{
		title: "Total Kamar",
		value: `${totalRooms} Kamar`,
		desc: `${occupiedRooms} Terisi, ${vacantRooms} Kosong`,
		icon: "lucide:house",
	},
	{
		title: "Penghuni Aktif",
		value: `${activeTenantsCount} Orang`,
		desc: `${leasesEndingThisMonth} sewa berakhir bulan ini`,
		icon: "lucide:user",
	},
	{
		title: "Tagihan Belum Bayar",
		value: formatCurrency(totalUnpaidAmount),
		desc: `${totalUnpaidCount} tagihan belum lunas`,
		icon: "lucide:file-text",
	},
	{
		title: "Komplain Terbuka",
		value: `${activeComplaintsCount} Komplain`,
		desc: `${complaintsFromDb.filter(({ status }) => status === "open").length} perlu tindakan segera`,
		icon: "lucide:circle-alert",
	},
];

const getStatusBadge = (status: string) => {
	if (status === "Overdue") return "badge-error";
	const match = status.match(/H-(\d+)/);
	if (match) {
		const days = parseInt(match[1], 10);
		if (days <= 2) return "badge-error";
		if (days <= 5) return "badge-warning";
		return "badge-info";
	}
	return "badge-neutral";
};
---

<DashboardLayout
	title="Dashboard"
	description="Ringkasan operasional dan kondisi indekos saat ini"
>
	<Stats items={stats} />

	<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
		<div class="card border border-base-300 bg-base-100 shadow-sm">
			<div class="card-body p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="card-title text-lg font-bold">
						<Icon
							class="text-primary"
							name="lucide:file-text"
							size="size-5"
						/>
						Tagihan Mendekati Jatuh Tempo
					</h2>
					{
						showTransactionsLink && (
							<a
								class="btn btn-outline btn-xs btn-primary"
								href="/dashboard/report/transactions"
							>
								Lihat Semua
							</a>
						)
					}
				</div>
				<div class="overflow-x-auto">
					<table class="table w-full table-sm">
						<thead>
							<tr>
								<th>Penghuni</th>
								<th>Kamar</th>
								<th>Nominal</th>
								<th>Jatuh Tempo</th>
								<th>Status</th>
							</tr>
						</thead>
						<tbody>
							{
								pendingBills.map(
									({ tenant, room, dueDate, status, amount }) => (
										<tr>
											<td>{tenant}</td>
											<td>
												<span class="badge font-mono badge-neutral">
													{room}
												</span>
											</td>
											<td class="font-mono">{formatCurrency(amount)}</td>
											<td class="font-mono">{formatDate(dueDate)}</td>
											<td>
												<span
													class:list={[
														"badge badge-sm font-bold",
														getStatusBadge(status),
													]}
												>
													{status}
												</span>
											</td>
										</tr>
									),
								)
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
		<div class="card border border-base-300 bg-base-100 shadow-sm">
			<div class="card-body p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="card-title text-lg font-bold">
						<Icon
							class="text-error"
							name="lucide:circle-alert"
							size="size-5"
						/>
						Komplain Terbaru
					</h2>
					{
						showComplaintsLink && (
							<a
								class="btn btn-outline btn-xs btn-primary"
								href="/dashboard/manage/complaints"
							>
								Kelola Komplain
							</a>
						)
					}
				</div>
				<div class="divide-y divide-base-200">
					{
						recentComplaints.map(
							({ title, room, tenant, date, status, badge }) => (
								<div class="flex items-start justify-between rounded-lg px-2 py-3.5 transition-colors first:pt-0 last:pb-0 hover:bg-base-200/20">
									<div class="flex flex-col gap-1">
										<span class="text-sm font-bold text-base-content">
											{title}
										</span>
										<div class="flex flex-wrap items-center gap-2 text-xs text-base-content/60">
											<span class="badge badge-ghost badge-sm">{room}</span>
											<span>•</span>
											<span>{tenant}</span>
											<span>•</span>
											<span>{formatDate(date)}</span>
										</div>
									</div>
									<span class:list={["badge badge-sm font-bold", badge]}>
										{status}
									</span>
								</div>
							),
						)
					}
				</div>
			</div>
		</div>
	</div>
</DashboardLayout>
