---
import { sumBy } from "es-toolkit";

import ReportLayout from "~/layouts/report-layout.astro";
import { formatCurrency } from "~/lib/transforms";
import {
	fetchRooms,
	ROOM_STATUS_LABELS,
	ROOM_TYPE_LABELS,
	roomQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(roomQuerySchema.omit({ query: true }));

const rooms = await fetchRooms(params);
const total = rooms.length;
const occupied = sumBy(rooms, ({ isActive, tenantName }) =>
	isActive && tenantName ? 1 : 0,
);
const vacant = sumBy(rooms, ({ isActive, tenantName }) =>
	isActive && !tenantName ? 1 : 0,
);
const inactive = sumBy(rooms, ({ isActive }) => (!isActive ? 1 : 0));

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${ROOM_STATUS_LABELS[params.status]}`);
}
if (params.type) {
	filterParts.push(`Tipe: ${ROOM_TYPE_LABELS[params.type]}`);
}
const subtitle =
	filterParts.length > 0 ? filterParts.join(" | ") : "Semua kamar";
---

<ReportLayout title="Rekap Status Kamar" subtitle={subtitle}>
	<div
		style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 12px; margin-bottom: 24px;"
	>
		<div style="border: 1px solid black; padding: 12px; text-align: center;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6;"
			>
				Total Kamar
			</div>
			<div style="font-size: 20px; font-weight: 700; margin-top: 4px;">
				{total}
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px; text-align: center;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6;"
			>
				Terisi
			</div>
			<div style="font-size: 20px; font-weight: 700; margin-top: 4px;">
				{occupied}
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px; text-align: center;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6;"
			>
				Tersedia
			</div>
			<div style="font-size: 20px; font-weight: 700; margin-top: 4px;">
				{vacant}
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px; text-align: center;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; opacity: 0.6;"
			>
				Nonaktif
			</div>
			<div style="font-size: 20px; font-weight: 700; margin-top: 4px;">
				{inactive}
			</div>
		</div>
	</div>

	<table>
		<thead>
			<tr>
				<th style="width: 20%;">No. Kamar</th>
				<th style="width: 15%;">Jenis</th>
				<th style="width: 22%;">Harga/Bulan</th>
				<th style="width: 15%;">Status</th>
				<th style="width: 28%;">Penghuni</th>
			</tr>
		</thead>
		<tbody>
			{
				rooms.map(
					({ roomNumber, roomType, monthlyPrice, isActive, tenantName }) => {
						const status = !isActive
							? "Nonaktif"
							: tenantName
								? "Terisi"
								: "Kosong";
						return (
							<tr>
								<td style="font-family: 'Courier New', monospace;">
									{roomNumber}
								</td>
								<td>{ROOM_TYPE_LABELS[roomType]}</td>
								<td style="font-family: 'Courier New', monospace; text-align: right;">
									{formatCurrency(monthlyPrice)}
								</td>
								<td>{status}</td>
								<td>{tenantName ?? "-"}</td>
							</tr>
						);
					},
				)
			}
		</tbody>
	</table>
</ReportLayout>
