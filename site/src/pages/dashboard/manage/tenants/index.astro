---
import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import SearchInput from "~/components/data/search-input.astro";
import FormResult from "~/components/form/form-result.astro";
import ActionsMenu from "~/components/ui/actions-menu.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import { createActionResult } from "~/lib/form-result";
import {
	fetchTenants,
	TENANT_STATUS_BADGES,
	tenantsQuerySchema,
} from "./_data";

const params = Astro.locals.parseQuery(tenantsQuerySchema);
const filteredTenants = await fetchTenants(params);
---

<FormResult
	actionResults={[
		createActionResult(
			actions.manage.tenants.add,
			"Tambah kontrak sewa",
			(d) => `Berhasil menambah kontrak sewa penghuni baru! (ID: ${d.id})`,
		),
		createActionResult(
			actions.manage.tenants.terminate,
			"Akhiri sewa",
			(d) => `Berhasil menghentikan sewa penghuni! (ID: ${d.id})`,
		),
		createActionResult(
			actions.manage.tenants.edit,
			"Edit penghuni",
			(d) => `Berhasil mengubah data penghuni! (ID: ${d.id})`,
		),
		createActionResult(
			actions.manage.tenants.register,
			"Daftarkan ulang sewa",
			(d) => `Berhasil mendaftarkan ulang sewa penghuni! (ID: ${d.id})`,
		),
		createActionResult(
			actions.manage.tenants.move,
			"Pindah kamar",
			(d) => `Berhasil memindahkan penghuni ke kamar baru! (ID: ${d.id})`,
		),
	]}
/>

<DashboardLayout
	title="Manajemen Penghuni"
	description="Kelola data identitas, kontak, dan masa aktif sewa penghuni"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/manage/tenants/report/download${Astro.url.search}`}
			download
		>
			<Icon name="line-md:download" /> PDF
		</a>
		{
			Astro.locals.canEdit() && (
				<button
					hx-get="/dashboard/manage/tenants/modal/add"
					class="btn btn-sm btn-primary"
				>
					<Icon name="line-md:plus" size="size-5" />
					Tambah Penghuni
				</button>
			)
		}
	</Fragment>

	<div
		class="flex items-center justify-end gap-2"
		hx-include=".filter-tenants"
		hx-select="#tenants-content-wrapper"
		hx-swap="outerHTML transition:true"
		hx-target="#tenants-content-wrapper"
	>
		<FilterPopover
			name="tenants"
			groups={[
				{
					title: "Status",
					name: "status",
					options: [
						{
							value: "active",
							label: "Aktif",
							checked: params.status === "active",
						},
						{
							value: "completed",
							label: "Selesai",
							checked: params.status === "completed",
						},
					],
				},
			]}
		/>
		<SearchInput
			value={params.query}
			filterClass="filter-tenants"
			placeholder="Cari nama penghuni..."
		/>
	</div>

	<div
		class="overflow-x-auto rounded-box border border-base-300 shadow-sm"
		id="tenants-content-wrapper"
	>
		<table class="table w-full table-sm">
			<thead>
				<tr>
					<th>Nama Penghuni</th>
					<th>No. HP</th>
					<th>Kamar</th>
					<th>Awal Sewa</th>
					<th>Akhir Sewa</th>
					<th>Status</th>
					<th class="text-right">Aksi</th>
				</tr>
			</thead>
			<tbody id="tenants-rows">
				{
					filteredTenants.map(
						({
							id,
							fullName,
							phoneNumber,
							roomNumber,
							startDate,
							endDate,
							isActive,
							isVerified,
						}) => {
							const status = isActive ? "Aktif" : "Selesai";
							return (
								<tr class:list={[!isVerified && "opacity-60"]}>
									<td class="font-semibold">
										<div class="flex items-center gap-3">
											<div class="avatar avatar-placeholder">
												<div class="w-9 rounded-full bg-neutral text-neutral-content">
													<span class="text-xs font-bold">
														{fullName.slice(0, 2)}
													</span>
												</div>
											</div>
											<div class="flex flex-col">
												<span class="font-semibold">
													{fullName}
													{!isVerified && (
														<span class="ml-1 badge align-middle badge-xs badge-warning">
															Belum Verifikasi
														</span>
													)}
												</span>
											</div>
										</div>
									</td>
									<td>
										<a
											class="btn flex items-center gap-1 btn-outline btn-xs btn-success"
											href={`https://wa.me/${phoneNumber}`}
											target="_blank"
										>
											<Icon name="line-md:phone-call-twotone" size="size-3.5" />
											+{phoneNumber}
										</a>
									</td>
									<td class="text-center">
										{isActive ? (
											<span class="badge font-mono badge-neutral">
												{roomNumber}
											</span>
										) : (
											<span class="text-xs text-base-content/30 italic">-</span>
										)}
									</td>
									<td class="font-mono text-xs text-base-content/70">
										{formatDate(startDate)}
									</td>
									<td class="font-mono text-xs text-base-content/70">
										{formatDate(endDate)}
									</td>
									<td>
										<span
											class:list={[
												"badge badge-sm font-bold",
												TENANT_STATUS_BADGES[status],
											]}
										>
											{status}
										</span>
									</td>
									<td class="text-right">
										<div class="flex justify-end gap-1.5">
											<button
												hx-get={`/dashboard/manage/tenants/modal/detail/${id}`}
												class="btn flex items-center gap-1 btn-outline btn-xs btn-primary"
											>
												<Icon name="line-md:document-list" /> Detail
											</button>
											{Astro.locals.canEdit() &&
												(isActive ? (
													<ActionsMenu
														id={id}
														menuClass="w-52"
														triggerLabel="Aksi"
													>
														<li>
															<button
																hx-get={`/dashboard/manage/tenants/modal/edit/${id}`}
															>
																<Icon name="line-md:edit" />
																Edit
															</button>
														</li>
														<li>
															<button
																hx-get={`/dashboard/manage/tenants/modal/move/${id}`}
															>
																<Icon name="line-md:arrow-right-circle" />
																Pindah Kamar
															</button>
														</li>
														<li>
															<button
																hx-get={
																	"/dashboard/manage/tenants/modal/terminate/" +
																	id
																}
																class="text-error"
															>
																<Icon name="line-md:close" /> Berhenti Menginap
															</button>
														</li>
													</ActionsMenu>
												) : (
													<ActionsMenu
														id={id}
														menuClass="w-52"
														triggerLabel="Aksi"
													>
														<li>
															<button
																hx-get={`/dashboard/manage/tenants/modal/edit/${id}`}
															>
																<Icon name="line-md:edit" />
																Edit
															</button>
														</li>
														<li>
															<button
																hx-get={
																	"/dashboard/manage/tenants/modal/register/" +
																	id
																}
																class="text-success"
															>
																<Icon name="line-md:plus" /> Sewa Baru
															</button>
														</li>
													</ActionsMenu>
												))}
										</div>
									</td>
								</tr>
							);
						},
					)
				}
			</tbody>
		</table>
	</div>
</DashboardLayout>
