---
import { sumBy } from "es-toolkit";

import ReportLayout from "~/layouts/report-layout.astro";
import { INVOICE_STATUS_LABELS } from "~/lib/badges";
import { formatCurrency } from "~/lib/currency";
import { formatDate } from "~/lib/date";
import { fetchTransactions, transactionQuerySchema } from "../_data";

const params = Astro.locals.parseQuery(transactionQuerySchema);

const mapped = await fetchTransactions(params);

const paidInvoices = mapped.filter((inv) => inv.status === "paid");
const unpaidInvoices = mapped.filter((inv) => inv.status !== "paid");

const totalRevenue = sumBy(paidInvoices, (inv) => inv.amount);
const paidCount = paidInvoices.length;
const unpaidCount = unpaidInvoices.length;
const outstandingAmount = sumBy(unpaidInvoices, (inv) => inv.amount);
---

<ReportLayout
	title="Laporan Transaksi Bulanan"
	subtitle={`${params.from} s/d ${params.to}`}
>
	<!-- Stats Cards -->
	<div
		style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;"
	>
		<div style="border: 1px solid black; padding: 12px 16px;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"
			>
				Total Pemasukan
			</div>
			<div
				style="font-size: 18px; font-weight: 700; font-family: 'Courier New', monospace;"
			>
				{formatCurrency(totalRevenue)}
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px 16px;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"
			>
				Sudah Terbayar
			</div>
			<div style="font-size: 18px; font-weight: 700;">
				{paidCount} Invoice
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px 16px;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"
			>
				Belum Terbayar
			</div>
			<div style="font-size: 18px; font-weight: 700;">
				{unpaidCount} Invoice
			</div>
			<div
				style="font-size: 11px; margin-top: 2px; font-family: 'Courier New', monospace;"
			>
				{formatCurrency(outstandingAmount)}
			</div>
		</div>
	</div>

	<!-- Transactions Table -->
	<table>
		<thead>
			<tr>
				<th style="text-align: center; width: 24px;">No</th>
				<th>No. Invoice</th>
				<th>Penghuni</th>
				<th style="width: 60px;">Kamar</th>
				<th style="text-align: right;">Nominal</th>
				<th>Jatuh Tempo</th>
				<th>Status</th>
			</tr>
		</thead>
		<tbody>
			{
				mapped.map((inv, idx) => (
					<tr>
						<td class="text-center">{idx + 1}</td>
						<td style="font-family: 'Courier New', monospace;">
							{inv.invoiceNumber}
						</td>
						<td>{inv.tenantName}</td>
						<td style="font-family: 'Courier New', monospace;">
							{inv.roomNumber}
						</td>
						<td style="text-align: right; font-family: 'Courier New', monospace;">
							{formatCurrency(inv.amount)}
						</td>
						<td style="font-family: 'Courier New', monospace;">
							{formatDate(inv.dueDate)}
						</td>
						<td>
							{
								INVOICE_STATUS_LABELS[
									inv.status as keyof typeof INVOICE_STATUS_LABELS
								]
							}
						</td>
					</tr>
				))
			}
		</tbody>
	</table>
</ReportLayout>
