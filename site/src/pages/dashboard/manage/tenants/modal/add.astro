---
import { and, db, eq } from "@e-kos/database";
import { leases, rooms as roomsTable } from "@e-kos/database/schema";

import { actions } from "astro:actions";

import IconLoader from "~/components/icon-loader.astro";
import Icon from "~/components/icon.astro";

export const partial = true;

const allRooms = await db
	.select({
		id: roomsTable.id,
		roomNumber: roomsTable.roomNumber,
		roomType: roomsTable.roomType,
		isActive: roomsTable.isActive,
		leaseActive: leases.isActive,
	})
	.from(roomsTable)
	.leftJoin(
		leases,
		and(eq(leases.roomId, roomsTable.id), eq(leases.isActive, true)),
	);

const emptyRooms = allRooms.filter(
	({ isActive, leaseActive }) => isActive && !leaseActive,
);
---

<dialog class="modal" id="add_tenant_modal">
	<div class="modal-box border-base-300 max-w-lg border">
		<form method="dialog">
			<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2"
				>✕</button
			>
		</form>
		<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
			<Icon class="text-primary" name="line-md:account-twotone" size="size-6" />
			Tambah Penghuni Baru
		</h3>
		<form
			hx-post={actions.manage.tenants.add}
			class="flex flex-col gap-4"
			id="add_tenant_form"
			hx-indicator="#add_tenant_btn"
			hx-on--after-request="event.detail.successful && add_tenant_modal.close()"
			hx-select-oob="#form_error, #form_result, #tenants-rows"
			hx-swap="none transition:true"
			action={actions.manage.tenants.add}
			method="post"
		>
			<fieldset class="fieldset">
				<legend class="fieldset-legend text-sm font-semibold"
					>Nama Lengkap</legend
				>
				<input
					class="input w-full"
					name="full_name"
					type="text"
					placeholder="Nama sesuai KTP..."
					required
				/>
			</fieldset>
			<fieldset class="fieldset">
				<legend class="fieldset-legend text-sm font-semibold"
					>Nomor HP (WhatsApp)</legend
				>
				<input
					class="input w-full"
					name="phone_number"
					type="text"
					placeholder="Contoh: 081234567890..."
					required
				/>
			</fieldset>
			<fieldset class="fieldset">
				<legend class="fieldset-legend text-sm font-semibold"
					>Daerah Asal</legend
				>
				<input
					class="input w-full"
					name="origin_region"
					type="text"
					placeholder="Opsional (misal: Bandung, Surabaya...)"
				/>
			</fieldset>

			<div class="divider text-xs tracking-wider uppercase opacity-60">
				Kontrak Sewa
			</div>

			<fieldset class="fieldset">
				<legend class="fieldset-legend text-sm font-semibold"
					>Pilih Kamar Tersedia</legend
				>
				<select class="select w-full" name="room_id" required>
					<option value="" disabled selected>Pilih nomor kamar...</option>
					{
						emptyRooms.map(({ id, roomNumber, roomType }) => (
							<option value={id}>
								{roomNumber} – {roomType} (Tersedia)
							</option>
						))
					}
				</select>
				<p class="text-base-content/40 mt-1 text-xs italic">
					Hanya menampilkan kamar dengan status kosong/tersedia
				</p>
			</fieldset>

			<div class="grid grid-cols-2 gap-3">
				<fieldset class="fieldset">
					<legend class="fieldset-legend text-sm font-semibold"
						>Tanggal Mulai</legend
					>
					<input class="input w-full" name="start_date" type="date" required />
				</fieldset>
				<fieldset class="fieldset">
					<legend class="fieldset-legend text-sm font-semibold"
						>Tanggal Selesai</legend
					>
					<input class="input w-full" name="end_date" type="date" />
				</fieldset>
			</div>

			<p class="text-error text-sm" id="form_error"></p>
		</form>
		<div class="modal-action">
			<form class="flex gap-2" method="dialog">
				<button class="btn btn-outline btn-sm">Batal</button>
				<button
					class="btn btn-primary btn-sm"
					id="add_tenant_btn"
					type="submit"
					form="add_tenant_form"
				>
					<IconLoader />
					Simpan Kontrak
				</button>
			</form>
		</div>
	</div>
	<form class="modal-backdrop" method="dialog">
		<button>close</button>
	</form>
</dialog>
