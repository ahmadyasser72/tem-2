---
import { formatDate } from "@indekos/utilities/date";
import { formatCurrency } from "@indekos/utilities/transforms";

import ReportStats from "~/components/data/report-stats.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import {
	fetchTransactions,
	getTransactionStats,
	INVOICE_STATUS_LABELS,
	transactionQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(
	transactionQuerySchema.omit({ query: true }),
);

const invoices = await fetchTransactions(params);
const transactionStats = getTransactionStats(invoices);

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${INVOICE_STATUS_LABELS[params.status]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Transaksi Bulanan" subtitle={subtitle}>
	<ReportStats stats={transactionStats} />

	<table>
		<thead>
			<tr>
				<th class="w-6 text-center">No</th>
				<th>No. Invoice</th>
				<th>Penghuni</th>
				<th class="w-16">Kamar</th>
				<th class="text-right">Nominal</th>
				<th>Jatuh Tempo</th>
				<th>Status</th>
			</tr>
		</thead>
		<tbody>
			{
				invoices.map(
					(
						{ invoiceNumber, tenantName, roomNumber, amount, dueDate, status },
						idx,
					) => (
						<tr>
							<td class="text-center">{idx + 1}</td>
							<td class="font-mono">{invoiceNumber}</td>
							<td>{tenantName}</td>
							<td class="font-mono">{roomNumber}</td>
							<td class="text-right font-mono">{formatCurrency(amount)}</td>
							<td class="font-mono">{formatDate(dueDate)}</td>
							<td>{INVOICE_STATUS_LABELS[status]}</td>
						</tr>
					),
				)
			}
		</tbody>
	</table>
</ReportLayout>
