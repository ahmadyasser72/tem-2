---
import { formatDate } from "@indekos/utilities/date";
import { formatCurrency } from "@indekos/utilities/transforms";

import { sumBy } from "es-toolkit";

import ReportStats from "~/components/data/report-stats.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import { PERIOD_SEPARATOR_UI } from "~/lib/query";
import {
	fetchLeaseInvoices,
	getInvoiceStats,
	INVOICE_STATUS_LABELS,
	invoiceQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(
	invoiceQuerySchema.omit({ query: true }),
);

const leases = await fetchLeaseInvoices(params);
const invoiceStats = getInvoiceStats(leases);

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${INVOICE_STATUS_LABELS[params.status]}`);
}
if (params.period) {
	const { from, to } = params.period;
	filterParts.push(
		from.isSame(to, "day")
			? `Per ${formatDate(from, "DD MMMM YYYY")}`
			: `Periode ${[from, to].map((date) => formatDate(date, "DD MMMM YYYY")).join(PERIOD_SEPARATOR_UI)}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Tagihan" subtitle={subtitle}>
	<ReportStats stats={invoiceStats} />

	{
		leases.map((lease) => (
			<div class="mb-6">
				<table>
					<thead>
						<tr>
							<th class="text-left" colspan="6">
								Kamar {lease.roomNumber} &mdash; {lease.tenantName} &mdash;{" "}
								{formatDate(lease.startDate)} s/d{" "}
								{lease.endDate ? formatDate(lease.endDate) : "sekarang"}
								{lease.isActive ? " (Aktif)" : " (Selesai)"}
							</th>
						</tr>
						<tr>
							<th class="w-[5%] text-center">No</th>
							<th class="w-[25%]">No. Invoice</th>
							<th class="w-[20%]">Jatuh Tempo</th>
							<th class="w-[20%]">Dibayar</th>
							<th class="w-[15%] text-right">Nominal</th>
							<th class="w-[15%] text-center">Status</th>
						</tr>
					</thead>
					<tbody>
						{lease.invoices.length > 0 ? (
							lease.invoices.map((invoice, idx) => (
								<tr>
									<td class="text-center font-mono">{idx + 1}</td>
									<td class="font-mono">{invoice.invoiceNumber}</td>
									<td class="font-mono">{formatDate(invoice.dueDate)}</td>
									<td class="font-mono">
										{invoice.paidAt ? formatDate(invoice.paidAt) : "-"}
									</td>
									<td class="text-right font-mono">
										{formatCurrency(invoice.amount)}
									</td>
									<td class="text-center">
										{INVOICE_STATUS_LABELS[invoice.status]}
									</td>
								</tr>
							))
						) : (
							<tr>
								<td class="text-center" colspan="6">
									Tidak ada tagihan
								</td>
							</tr>
						)}
					</tbody>
					<tfoot>
						<tr>
							<td
								class="border border-black bg-gray-100 p-2 font-bold"
								colspan="6"
							>
								Total tagihan: {lease.invoices.length} | Lunas:{" "}
								{formatCurrency(
									sumBy(lease.invoices, ({ amount, status }) =>
										status === "paid" ? amount : 0,
									),
								)}
							</td>
						</tr>
					</tfoot>
				</table>
			</div>
		))
	}
</ReportLayout>
