---
import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import FormResult from "~/components/form/form-result.astro";
import ActionsMenu from "~/components/ui/actions-menu.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import { createActionResult } from "~/lib/form-result";
import { formatCurrency } from "~/lib/transforms";
import {
	fetchTransactions,
	getTransactionStats,
	INVOICE_STATUS,
	INVOICE_STATUS_BADGES,
	INVOICE_STATUS_LABELS,
	transactionQuerySchema,
} from "./_data";

const params = Astro.locals.parseQuery(transactionQuerySchema);

const invoices = await fetchTransactions(params);
const { totalRevenue, paidCount, unpaidCount, outstandingAmount } =
	getTransactionStats(invoices);
const paidPercent =
	invoices.length > 0 ? Math.round((paidCount / invoices.length) * 100) : 0;

const summaryStats = [
	{
		title: "Total Pemasukan",
		value: formatCurrency(totalRevenue),
		desc: `${params.from} s/d ${params.to}`,
		icon: "lucide:arrow-up-right" as const,
	},
	{
		title: "Sudah Terbayar",
		value: `${paidCount} Invoice`,
		desc: `${paidPercent}% dari total tagihan`,
		icon: "lucide:circle-check" as const,
	},
	{
		title: "Pembayaran Tertunggak",
		value: `${unpaidCount} Invoice`,
		desc: `${formatCurrency(outstandingAmount)} belum dibayar`,
		icon: "lucide:x-circle" as const,
	},
];
---

<FormResult
	actionResults={[
		createActionResult(
			actions.manage.invoices.generatePaymentLink,
			"Buat link bayar",
			(d) =>
				`Link pembayaran berhasil dibuat! <a href="${d.paymentUrl}" class="link link-primary" target="_blank">Buka Pembayaran</a>`,
		),
		createActionResult(
			actions.manage.invoices.markAsPaid,
			"Tandai Lunas",
			() => "Berhasil menandai invoice sebagai lunas!",
		),
	]}
/>

<DashboardLayout
	title="Laporan Transaksi"
	description="Rekapitulasi tagihan dan riwayat pembayaran sewa bulanan penghuni"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/report/transactions/report/download${Astro.url.search}`}
			download
		>
			<Icon name="lucide:download" /> PDF
		</a>
	</Fragment>

	<FilterToolbar name="transactions" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="transactions"
				groups={[
					{
						title: "Status",
						name: "status",
						options: INVOICE_STATUS.map((status) => ({
							value: status,
							label: INVOICE_STATUS_LABELS[status],
							checked: params.status === status,
						})),
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-transactions"
				placeholder="Cari nama/No. Kamar..."
			/>
		</Fragment>
	</FilterToolbar>

	<div class="contents" id="transactions-content-wrapper">
		<Stats items={summaryStats} />

		<div class="overflow-x-auto rounded-box border border-base-300 shadow-sm">
			<table class="table w-full table-zebra table-sm">
				<thead>
					<tr>
						<th>No. Invoice</th>
						<th>Penghuni</th>
						<th>Kamar</th>
						<th>Nominal</th>
						<th>Jatuh Tempo</th>
						<th>Status</th>
						<th>Ref. Gateway</th>
						<th>Aksi</th>
					</tr>
				</thead>
				<tbody>
					{
						invoices.map(
							({
								id,
								invoiceNumber,
								tenantName,
								roomNumber,
								amount,
								dueDate,
								status,
								duitkuReference,
								paymentUrl,
							}) => (
								<tr>
									<td class="font-mono text-xs">{invoiceNumber}</td>
									<td>{tenantName}</td>
									<td>
										<span class="badge font-mono badge-neutral">
											{roomNumber}
										</span>
									</td>
									<td class="font-mono">{formatCurrency(amount)}</td>
									<td class="font-mono text-xs">{formatDate(dueDate)}</td>
									<td>
										<span
											class:list={[
												"badge badge-sm font-bold",
												INVOICE_STATUS_BADGES[status],
											]}
										>
											{INVOICE_STATUS_LABELS[status]}
										</span>
									</td>
									<td
										class="tooltip max-w-32 truncate font-mono text-xs tooltip-info"
										data-tip={duitkuReference}
									>
										{duitkuReference}
									</td>
									<td>
										{status === "paid" ? (
											<span class="text-xs">-</span>
										) : duitkuReference ? (
											<div class="flex items-center gap-1">
												<a
													class="btn w-24 btn-outline btn-xs btn-success"
													href={`/invoice/${id}`}
													target="_blank"
												>
													<Icon name="lucide:external-link" size="size-3.5" />{" "}
													Invoice
												</a>

												{Astro.locals.user?.allowEdit && (
													<ActionsMenu id={id} menuClass="w-36">
														<li>
															<button
																class="flex items-center gap-2"
																onclick={`navigator.clipboard.writeText("${paymentUrl}")`}
															>
																<Icon
																	name="lucide:clipboard-list"
																	size="size-3.5"
																/>
																Salin
															</button>
														</li>
														<li>
															<form
																hx-post={actions.manage.invoices.markAsPaid}
																class="contents"
																hx-select="#transactions-content-wrapper"
																hx-swap="outerHTML transition:true"
																hx-target="#transactions-content-wrapper"
																action={actions.manage.invoices.markAsPaid}
																enctype="multipart/form-data"
																method="post"
															>
																<input
																	name="invoice_id"
																	type="hidden"
																	value={id}
																/>
																<button
																	class="flex items-center gap-2"
																	type="submit"
																>
																	<Icon name="lucide:circle-check" />
																	Tandai Lunas
																</button>
															</form>
														</li>
													</ActionsMenu>
												)}
											</div>
										) : (
											<div class="flex items-center gap-1">
												{Astro.locals.user?.allowEdit && (
													<form
														hx-post={
															actions.manage.invoices.generatePaymentLink
														}
														class="contents"
														hx-select="#transactions-content-wrapper"
														hx-swap="outerHTML transition:true"
														hx-target="#transactions-content-wrapper"
														action={actions.manage.invoices.generatePaymentLink}
														enctype="multipart/form-data"
														method="post"
													>
														<input name="invoice_id" type="hidden" value={id} />
														<button
															class="btn w-24 btn-outline btn-xs btn-primary"
															type="submit"
														>
															<Icon name="lucide:link" size="size-3.5" />{" "}
															Generate
														</button>
													</form>
												)}

												{Astro.locals.user?.allowEdit && (
													<ActionsMenu id={id} menuClass="w-36">
														<form
															hx-post={actions.manage.invoices.markAsPaid}
															class="contents"
															hx-select="#transactions-content-wrapper"
															hx-swap="outerHTML transition:true"
															hx-target="#transactions-content-wrapper"
															action={actions.manage.invoices.markAsPaid}
															enctype="multipart/form-data"
															method="post"
														>
															<li>
																<input
																	name="invoice_id"
																	type="hidden"
																	value={id}
																/>
																<button type="submit">
																	<Icon name="lucide:circle-check" />
																	Tandai Lunas
																</button>
															</li>
														</form>
													</ActionsMenu>
												)}
											</div>
										)}
									</td>
								</tr>
							),
						)
					}
				</tbody>
			</table>
		</div>
	</div>
</DashboardLayout>
