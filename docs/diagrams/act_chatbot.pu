@startuml
|Penghuni|
start
:Kirim pesan ke chatbot;

|Sistem|
:Simpan pesan ke Basis Data;

if (Perintah terdeteksi?) then (ya)
  
  if (Cek tagihan?) then (ya)
    :Ambil data tagihan;
    if (Ada tagihan?) then (ya)
      :Kirim info tagihan;
    else (tidak)
      :Kirim "tidak ada tagihan";
    endif

  elseif (Riwayat pembayaran?) then (ya)
    :Ambil riwayat tagihan lunas;
    :Kirim riwayat;

  elseif (Bayar tagihan?) then (ya)
    :Ambil data tagihan;

    if (Status belum dibayar?) then (ya)
      :Buat permintaan pembayaran;
      :Tunggu konfirmasi;

      if (Pembayaran sukses?) then (ya)
        :Ubah status = lunas;
        :Kirim notifikasi sukses;
      else (gagal)
        :Kirim notifikasi gagal;
      endif

    else (sudah lunas)
      :Kirim "sudah dibayar";
    endif

  elseif (Komplain?) then (ya)
    :Catat komplain;
    :Kirim respon diterima;

  else
    :Respon default;
  endif

else (tidak)
  :Respon default;
endif

stop
@enduml