---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import Icon from "~/components/icon.astro";

export const partial = true;

const room = await db.query.rooms.findFirst({
	columns: {
		id: true,
		roomNumber: true,
		roomType: true,
		monthlyPrice: true,
		isActive: true,
	},
	where: { id: Number(Astro.params.id) },
});

if (!room) Astro.response.status = 404;
---

<dialog class="modal" id="edit_room_modal">
	{
		room ? (
			<div class="modal-box border-base-300 border">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>

				<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
					<Icon
						class="text-primary"
						name="line-md:home-md-twotone"
						size="size-6"
					/>
					Edit Kamar (ID: {room.id})
				</h3>

				<form
					hx-post={actions.manage.rooms.edit}
					class="flex flex-col gap-4"
					id="edit_room_form"
					hx-on--after-request="event.detail.successful && edit_room_modal.close()"
					hx-select-oob="#form_error, #form_result, #rooms-grid"
					hx-swap="none transition:true"
					action={actions.manage.rooms.edit}
					method="post"
				>
					<input name="id" type="hidden" value={room.id} />

					<fieldset class="fieldset">
						<legend class="fieldset-legend text-sm font-semibold">
							Nomor Kamar
						</legend>
						<input
							class="input w-full"
							name="room_number"
							type="text"
							value={room.roomNumber}
							placeholder="Contoh: C05, A12..."
							required
						/>
					</fieldset>
					<fieldset class="fieldset">
						<legend class="fieldset-legend text-sm font-semibold">
							Jenis Kamar
						</legend>
						<select class="select w-full" name="room_type" required>
							<option value="Standar" selected={room.roomType === "Standar"}>
								Standar
							</option>
							<option value="Premium" selected={room.roomType === "Premium"}>
								Premium
							</option>
						</select>
					</fieldset>
					<fieldset class="fieldset">
						<legend class="fieldset-legend text-sm font-semibold">
							Harga Sewa / Bulan (Rp)
						</legend>
						<input
							class="input w-full"
							name="monthly_price"
							type="number"
							value={room.monthlyPrice}
							placeholder="800000"
							required
						/>
					</fieldset>
					<div class="bg-base-200/40 border-base-200 flex items-center gap-3 rounded-lg border p-3">
						<input
							class="toggle toggle-success"
							id="kamar-aktif-edit"
							name="is_active"
							type="checkbox"
							checked={room.isActive}
						/>
						<label
							class="cursor-pointer text-sm font-semibold"
							for="kamar-aktif-edit"
						>
							Kamar aktif (siap huni)
						</label>
					</div>

					<p class="text-error text-sm" id="form_error" />
				</form>
				<div class="modal-action">
					<form class="flex gap-2" method="dialog">
						<button class="btn btn-outline btn-sm">Batal</button>
						<button
							class="btn btn-primary btn-sm"
							type="submit"
							form="edit_room_form"
						>
							Simpan Kamar
						</button>
					</form>
				</div>
			</div>
		) : (
			<div class="modal-box border-base-300 border">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>
				<h3 class="mb-4 text-xl font-bold">Edit Kamar</h3>
				<p class="py-4">Kamar dengan ID: {Astro.params.id} tidak ditemukan.</p>
			</div>
		)
	}
	<form class="modal-backdrop" method="dialog">
		<button>close</button>
	</form>
</dialog>
