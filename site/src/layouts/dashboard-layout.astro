---
import { config } from "@indekos/utilities/brand";

import { actions } from "astro:actions";

import Icon from "~/components/ui/icon.astro";
import type { Props as BaseProps } from "./base-layout.astro";
import BaseLayout from "./base-layout.astro";
import FormResult from "./components/form-result.astro";
import NavbarMenu from "./components/navbar-menu.astro";
import NotificationDropdown from "./components/notification-dropdown.astro";
import UserDropdown from "./components/user-dropdown.astro";

interface Props extends BaseProps {
	pageTitle?: string;
	description?: string;
}

const { pageTitle = Astro.props.title, description } = Astro.props;

const user = Astro.locals.user;
if (!user) return Astro.redirect("/login");

const logoutResult = Astro.getActionResult(actions.auth.logout);
if (logoutResult && !logoutResult.error) {
	if (!Astro.request.headers.get("hx-request")) return Astro.redirect("/login");

	Astro.response.headers.set("hx-redirect", "/login");
}
---

<BaseLayout {...Astro.props}>
	<div class="drawer lg:drawer-open">
		<input class="drawer-toggle" id="dashboard-drawer" type="checkbox" />
		<div class="drawer-content" id="dashboard-content">
			<nav class="navbar w-full bg-base-200">
				<label
					class="btn btn-square btn-ghost lg:hidden"
					for="dashboard-drawer"
					aria-label="open sidebar"
				>
					<Icon name="lucide:menu" />
				</label>

				<div class="navbar-start px-4">
					<a class="btn btn-ghost px-4 btn-lg max-sm:hidden" href="/dashboard"
						>{config.siteName}</a
					>
				</div>

				<div class="navbar-end items-end px-4" id="user-profile">
					<NotificationDropdown />
					<UserDropdown />
				</div>
			</nav>
			<div class="p-4">
				<div class="flex flex-col gap-6">
					{
						pageTitle && (
							<div class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between">
								<div class="flex flex-col gap-1">
									<h1 class="text-3xl font-bold">{pageTitle}</h1>
									{description && (
										<p class="text-sm text-base-content/60">{description}</p>
									)}
								</div>
								<div class="flex items-center gap-2">
									<slot name="page-action" />
								</div>
							</div>
						)
					}
					<slot />
				</div>
			</div>
		</div>

		<div class="drawer-side">
			<label
				class="drawer-overlay"
				for="dashboard-drawer"
				aria-label="close sidebar"></label>

			<div
				class="flex min-h-full w-64 flex-col border-r border-base-300/80 bg-base-100"
			>
				<NavbarMenu />
			</div>
		</div>
	</div>

	<FormResult />
</BaseLayout>
