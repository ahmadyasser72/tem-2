---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";
import { formatCurrency } from "~/lib/transforms";
import { ROOM_TYPE_LABELS } from "../../_data";

export const partial = true;

const room = await db.query.rooms.findFirst({
	columns: {
		id: true,
		roomNumber: true,
		roomType: true,
		monthlyPrice: true,
		isActive: true,
	},
	where: { id: Number(Astro.params.id) },
});

if (!room) Astro.response.status = 404;
---

<Modal id="delete_room" title="Hapus Kamar" icon="lucide:x-circle">
	{
		room ? (
			<>
				<div class="mb-3 grid grid-cols-2 gap-2 text-sm">
					<span class="font-bold">Nomor Kamar:</span>
					<span>{room.roomNumber}</span>
					<span class="font-bold">Jenis Kamar:</span>
					<span>{ROOM_TYPE_LABELS[room.roomType] ?? room.roomType}</span>
					<span class="font-bold">Harga/Bulan:</span>
					<span>{formatCurrency(room.monthlyPrice)}</span>
					<span class="font-bold">Status:</span>
					<span
						class:list={[
							"badge badge-sm",
							room.isActive ? "badge-success" : "badge-ghost",
						]}
					>
						{room.isActive ? "Aktif" : "Tidak Aktif"}
					</span>
				</div>

				<ModalForm
					action={actions.manage.rooms._delete}
					hidden
					modalId="delete_room"
					submitClass="btn-error"
					submitLabel="Hapus"
					target="#form_result, #rooms-content-wrapper"
				>
					<input name="id" type="hidden" value={room.id} />
				</ModalForm>
			</>
		) : (
			<NotFound label="Kamar" />
		)
	}
</Modal>
