---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";

export const partial = true;

const complaint = await db.query.complaints.findFirst({
	where: { id: Number(Astro.params.id) },
});

if (!complaint) Astro.response.status = 404;
---

<Modal
	id="resolve_complaint"
	title="Selesaikan Komplain"
	icon="lucide:circle-check"
>
	{
		complaint ? (
			<>
				<p class="mb-4 text-sm text-base-content/60">
					Apakah Anda yakin ingin menandai komplain (ID: {complaint.id}) sebagai
					selesai? Penghuni akan mendapat kepastian bahwa masalah telah
					ditangani.
				</p>

				<ModalForm
					action={actions.manage.complaints.resolve}
					modalId="resolve_complaint"
					submitClass="btn-success text-white"
					submitLabel="Konfirmasi Selesai"
					target="#complaints-content-wrapper"
				>
					<input name="id" type="hidden" value={complaint.id} />

					<FormField label="Catatan Penyelesaian (opsional)">
						<textarea
							class="textarea h-24 w-full"
							name="resolveNotes"
							placeholder="Masukkan catatan penyelesaian..."
						/>
					</FormField>
				</ModalForm>
			</>
		) : (
			<NotFound label="Komplain" />
		)
	}
</Modal>
