---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";
import { formatDate } from "~/lib/date";

export const partial = true;

const log = await db.query.chatbotMessages.findFirst({
	where: { id: Number(Astro.params.id) },
	with: {
		tenant: {
			with: {
				leases: {
					where: { isActive: true },
					with: {
						room: true,
					},
				},
			},
		},
	},
});

const activeLease = log?.tenant?.leases?.[0];
const chatbotLog = log
	? {
			id: log.id,
			time: log.sentAt,
			tenantName: log.tenant?.fullName ?? "-",
			roomNumber: activeLease?.room?.roomNumber ?? "-",
			direction: log.direction === "incoming" ? "Masuk" : "Keluar",
			message: log.message,
		}
	: null;

if (!log) Astro.response.status = 404;
---

<Modal id="delete_chatbot" title="Hapus Chatbot Log" icon="lucide:message-square-warning">
	{
		chatbotLog ? (
			<>
				<div class="grid grid-cols-2 gap-2 border-b border-base-200 pb-4 text-sm">
					<span class="font-bold">Penghuni:</span>
					<span>
						{chatbotLog.tenantName} (Kamar {chatbotLog.roomNumber})
					</span>
					<span class="font-bold">Arah:</span>
					<span>{chatbotLog.direction}</span>
					<span class="font-bold">Waktu:</span>
					<span>{formatDate(chatbotLog.time, "DD MMM YYYY HH:mm:ss")}</span>
				</div>

				<div class="mt-4 text-sm">
					<span class="mb-1 block font-bold">Isi Pesan:</span>
					<p class="max-h-32 overflow-y-auto rounded border border-base-300 bg-base-200 p-3 text-xs leading-relaxed wrap-break-word whitespace-pre-wrap">
						{chatbotLog.message}
					</p>
				</div>

				<ModalForm
					action={actions.manage.chatbot.remove}
					hidden
					modalId="delete_chatbot"
					submitClass="btn-error"
					submitLabel="Hapus"
					target="#form_result, #chatbot-content-wrapper"
				>
					<input name="id" type="hidden" value={chatbotLog.id} />
				</ModalForm>
			</>
		) : (
			<NotFound label="Chatbot Log" />
		)
	}
</Modal>
