---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";
import { ROOM_TYPE_LABELS, ROOM_TYPES } from "../../_data";

export const partial = true;

const room = await db.query.rooms.findFirst({
	columns: {
		id: true,
		roomNumber: true,
		roomType: true,
		monthlyPrice: true,
		isActive: true,
	},
	where: { id: Number(Astro.params.id) },
});

if (!room) Astro.response.status = 404;
---

<Modal id="edit_room" title="Edit Kamar" icon="lucide:pencil">
	{
		room ? (
			<>
				<ModalForm
					action={actions.manage.rooms.edit}
					modalId="edit_room"
					submitLabel="Simpan Kamar"
					target="#form_result, #rooms-content-wrapper"
				>
					<input name="id" type="hidden" value={room.id} />

					<FormField label="Nomor Kamar">
						<input
							class="input w-full"
							name="room_number"
							type="text"
							value={room.roomNumber}
							placeholder="Contoh: C05, A12..."
							required
						/>
					</FormField>
					<FormField label="Jenis Kamar">
						<select class="select w-full" name="room_type" required>
							{ROOM_TYPES.map((t) => (
								<option value={t} selected={room.roomType === t}>
									{ROOM_TYPE_LABELS[t]}
								</option>
							))}
						</select>
					</FormField>
					<FormField label="Harga Sewa / Bulan (Rp)">
						<input
							class="input w-full"
							name="monthly_price"
							type="number"
							value={room.monthlyPrice}
							placeholder="800000"
							required
						/>
					</FormField>
					<div class="flex items-center gap-3 rounded-lg border border-base-200 bg-base-200/40 p-3">
						<input
							class="toggle toggle-success"
							id="kamar-aktif-edit"
							name="is_active"
							type="checkbox"
							checked={room.isActive}
						/>
						<label
							class="cursor-pointer text-sm font-semibold"
							for="kamar-aktif-edit"
						>
							Kamar aktif (siap huni)
						</label>
					</div>
				</ModalForm>
			</>
		) : (
			<NotFound label="Kamar" />
		)
	}
</Modal>
