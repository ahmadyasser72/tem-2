---
import { formatDate } from "@indekos/utilities/date";

import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import {
	ACTION_BADGES,
	AUDIT_ACTIONS,
	auditQuerySchema,
	fetchAuditLogs,
	getAuditStats,
} from "./_data";

Astro.locals.actionResults.push({
	action: actions.manage.audit.remove,
	title: "Hapus Audit Log",
	getDescription: () => "Audit log berhasil dihapus dari database!",
});

const params = Astro.locals.parseQuery(auditQuerySchema);

const auditLogs = await fetchAuditLogs(params);
const auditStats = getAuditStats(auditLogs);
---

<DashboardLayout
	title="Audit Log"
	description="Jejak rekaman log aktivitas mutasi data dan operasional yang dilakukan oleh pengguna"
	pageTitle="Audit Log Sistem"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			id="audit-print"
			href={`/dashboard/log/audit/report/html${Astro.url.search}`}
			hx-swap-oob="true"
			target="_blank"
		>
			<Icon name="lucide:download" /> PDF
		</a>
	</Fragment>

	<FilterToolbar name="audit" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="audit"
				checkbox={{
					name: "show_system",
					label: "Tampilkan System",
					checked: params.show_system,
				}}
				groups={[
					{
						title: "Jenis aksi",
						name: "action",
						options: AUDIT_ACTIONS.map((action) => ({
							label: action,
							value: action,
							checked: params.action === action,
						})),
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-audit"
				placeholder="Cari aksi, tabel, atau pengguna..."
			/>
		</Fragment>
	</FilterToolbar>

	<Stats stats={auditStats} />

	<div
		class="overflow-x-auto rounded-box border border-base-300 shadow-sm"
		id="audit-content-wrapper"
	>
		<table class="table w-full table-sm">
			<thead>
				<tr>
					<th class="w-48">Waktu Kejadian</th>
					<th>Pengguna</th>
					<th class="w-32">Jenis Aksi</th>
					<th>Tabel Target</th>
					<th>ID Record</th>
					<th class="w-28">Detail</th>
					<th class="w-16 text-right">Aksi</th>
				</tr>
			</thead>
			<tbody>
				{
					auditLogs.map(
						({
							id,
							createdAt,
							displayName,
							action,
							tableName,
							recordId,
							details,
						}) => (
							<tr>
								<td class="font-mono">
									{formatDate(createdAt, "DD MMM YYYY HH:mm:ss")}
								</td>
								<td>
									<div class="flex items-center gap-1.5">
										<Icon class="text-base-content/40" name="lucide:user" />
										{displayName}
									</div>
								</td>
								<td>
									<span
										class:list={[
											"badge badge-xs font-bold",
											ACTION_BADGES[action],
										]}
									>
										{action}
									</span>
								</td>
								<td class="font-mono">{tableName}</td>
								<td class="font-mono">
									<span class="rounded border border-base-300 bg-base-200 px-2 py-0.5 font-bold">
										{recordId ?? "-"}
									</span>
								</td>
								<td class="max-w-xs truncate overflow-hidden">
									{details?.description ?? "-"}
								</td>
								<td class="text-right">
									<div class="flex justify-end gap-0.5">
										{details &&
											(((details.type === "create" ||
												details.type === "update" ||
												details.type === "delete") &&
												details.changes?.length) ||
												details.type === "cron" ||
												(details.type === "reject" && details.reason) ||
												details.type === "payment" ||
												details.type === "notification") && (
												<button
													hx-get={`/dashboard/log/audit/modal/detail/${id}`}
													class="btn btn-square btn-ghost btn-xs"
												>
													<Icon name="lucide:eye" />
												</button>
											)}

										{Astro.locals.user?.allowEdit && (
											<button
												hx-get={`/dashboard/log/audit/modal/delete/${id}`}
												class="btn btn-square btn-ghost text-error btn-xs"
											>
												<Icon name="lucide:x" />
											</button>
										)}
									</div>
								</td>
							</tr>
						),
					)
				}
			</tbody>
		</table>
	</div>
</DashboardLayout>
