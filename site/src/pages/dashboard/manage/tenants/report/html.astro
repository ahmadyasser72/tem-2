---
import { db } from "@e-kos/database";
import { z } from "astro/zod";
import { formatDate } from "~/lib/date";
import ReportLayout from "~/layouts/report-layout.astro";

const params = Astro.locals.parseQuery(
	z.object({
		status: z.enum(["all", "active", "completed"]).optional().catch(undefined),
	}),
);

const createdBy = Astro.url.searchParams.get("createdBy") ?? "Staff";

const owners = await db.query.users.findMany({ where: { role: "owner" } });
const knownBy = owners[0]?.displayName ?? "Pemilik Kos";

// Query all tenants with leases (with room)
const tenantsFromDb = await db.query.tenants.findMany({
	with: {
		leases: {
			with: {
				room: true,
			},
		},
	},
});

// Map to display data — find current/latest lease per tenant
const allTenants = tenantsFromDb.map((tenant) => {
	const currentLease = tenant.leases.find(({ isActive }) => isActive)
		?? tenant.leases.reduce(
				(latest, current) =>
					new Date(current.startDate) > new Date(latest.startDate)
						? current
						: latest,
				tenant.leases[0],
			);

	return {
		fullName: tenant.fullName,
		phoneNumber: tenant.phoneNumber,
		roomNumber: currentLease?.room?.roomNumber ?? "-",
		startDate: currentLease?.startDate ?? null,
		endDate: currentLease?.endDate ?? null,
		isActive: !!currentLease?.isActive,
	};
});

// Apply status filter
const filteredTenants = allTenants.filter((t) => {
	if (params.status === "active" && !t.isActive) return false;
	if (params.status === "completed" && t.isActive) return false;
	return true;
});

// Subtitle
let subtitle = "Semua penghuni";
if (params.status === "active") subtitle = "Status: Aktif";
else if (params.status === "completed") subtitle = "Status: Selesai";

const total = filteredTenants.length;
---

<ReportLayout title="Daftar Penghuni Aktif" subtitle={subtitle} createdBy={createdBy} knownBy={knownBy}>
	<!-- Waktu Cetak -->
	<div style="font-size: 10px; margin-bottom: 12px; opacity: 0.6;">
		Dicetak: {formatDate(new Date(), "DD MMMM YYYY HH:mm")}
	</div>

	<!-- Table -->
	<table>
		<thead>
			<tr>
				<th style="width: 5%; text-align: center;">No</th>
				<th style="width: 22%;">Nama Lengkap</th>
				<th style="width: 15%;">No. HP</th>
				<th style="width: 10%;">Kamar</th>
				<th style="width: 15%;">Awal Sewa</th>
				<th style="width: 15%;">Akhir Sewa</th>
				<th style="width: 10%;">Status</th>
			</tr>
		</thead>
		<tbody>
			{filteredTenants.length === 0 ? (
				<tr>
					<td colspan="7" style="text-align: center; padding: 24px; font-size: 11px; opacity: 0.5;">
						Tidak ada data penghuni yang sesuai dengan filter.
					</td>
				</tr>
			) : (
				filteredTenants.map(
					({ fullName, phoneNumber, roomNumber, startDate, endDate, isActive }, i) => (
						<tr>
							<td style="text-align: center; font-family: 'Courier New', monospace;">{i + 1}</td>
							<td>{fullName}</td>
							<td style="font-family: 'Courier New', monospace;">{phoneNumber}</td>
							<td style="text-align: center; font-family: 'Courier New', monospace;">{roomNumber}</td>
							<td style="font-family: 'Courier New', monospace;">{formatDate(startDate)}</td>
							<td style="font-family: 'Courier New', monospace;">{formatDate(endDate)}</td>
							<td style="text-align: center;">{isActive ? "Aktif" : "Selesai"}</td>
						</tr>
					),
				)
			)}
		</tbody>
		<tfoot>
			<tr>
				<td colspan="7" style="border: 1px solid black; padding: 8px; font-weight: 700; background: #f3f4f6;">
					Total penghuni: {total}
				</td>
			</tr>
		</tfoot>
	</table>
</ReportLayout>
