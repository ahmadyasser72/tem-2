---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";
import { z } from "astro/zod";

import Icon from "~/components/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";

const formResult = (():
	| { success: false; message: string }
	| { success: true; message: string }
	| void => {
	const linkResult = Astro.getActionResult(
		actions.manage.invoices.generatePaymentLink,
	);
	if (linkResult?.error)
		return { success: false, message: linkResult.error.message };
	else if (linkResult?.data) {
		return {
			success: true,
			message: `Link pembayaran berhasil dibuat! <a href="${linkResult.data.paymentUrl}" class="link link-primary" target="_blank">Buka Pembayaran</a>`,
		};
	}

	const paidResult = Astro.getActionResult(actions.manage.invoices.markAsPaid);
	if (paidResult?.error)
		return { success: false, message: paidResult.error.message };
	else if (paidResult?.data) {
		return {
			success: true,
			message: "Invoice berhasil ditandai sebagai lunas.",
		};
	}
})();

const currentMonthStr = (() => {
	const now = new Date();
	return `${now.getFullYear()}-${(now.getMonth() + 1).toString().padStart(2, "0")}`;
})();
const defaultFrom = currentMonthStr;
const defaultTo = currentMonthStr;

const params = Astro.locals.parseQuery(
	z.object({
		from: z.string().catch(defaultFrom),
		to: z.string().catch(defaultTo),
		status: z
			.enum(["all", "paid", "unpaid", "overdue"])
			.optional()
			.catch(undefined),
	}),
);

// If from > to, adjust to follow from
if (params.from > params.to) {
	params.to = params.from;
}

// Handle status messages from HTMX redirect
const queryStatusMsg = Astro.url.searchParams.get("statusMsg");
const queryStatusDetail = Astro.url.searchParams.get("statusDetail");
const queryPaymentUrl = Astro.url.searchParams.get("paymentUrl");

const redirectResult = ((): { success: boolean; message: string } | void => {
	if (!queryStatusMsg) return;
	if (queryStatusMsg === "success") {
		const msg = queryPaymentUrl
			? `Link pembayaran berhasil dibuat! <a href="${queryPaymentUrl}" class="link link-primary" target="_blank">Buka Pembayaran</a>`
			: queryStatusDetail;
		return { success: true, message: msg ?? "Berhasil" };
	}
	return {
		success: false,
		message: queryStatusDetail ?? "Terjadi kesalahan",
	};
})();

// Parse start and end month from params
const [fromYear, fromMonth] = params.from.split("-").map(Number);
const [toYear, toMonth] = params.to.split("-").map(Number);
const startDate = new Date(fromYear, fromMonth - 1, 1);
const endDate = new Date(toYear, toMonth, 0, 23, 59, 59, 999);

// 1. Query all invoices for the selected month at database level
const monthlyInvoicesFromDb = await db.query.invoices.findMany({
	where: {
		dueDate: {
			gte: startDate,
			lte: endDate,
		},
	},
	with: {
		lease: {
			with: {
				tenant: true,
				room: true,
			},
		},
	},
});

const monthlyInvoices = monthlyInvoicesFromDb.map((inv) => {
	return {
		id: inv.id,
		invoiceNumber: `INV-${inv.id.toString().padStart(6, "0")}`,
		tenantName: inv.lease?.tenant?.fullName ?? "-",
		roomNumber: inv.lease?.room?.roomNumber ?? "-",
		amount: inv.amount,
		dueDate: inv.dueDate,
		status: inv.status,
		gatewayRef: inv.duitkuReference ?? "-",
		duitkuReference: inv.duitkuReference,
	};
});

// Compute stats based on the monthly set
const totalRevenue = monthlyInvoices
	.filter(({ status }) => status === "paid")
	.reduce((sum, { amount }) => sum + amount, 0);

const paidCount = monthlyInvoices.filter(
	({ status }) => status === "paid",
).length;
const unpaidCount = monthlyInvoices.filter(
	({ status }) => status !== "paid",
).length;
const outstandingAmount = monthlyInvoices
	.filter(({ status }) => status !== "paid")
	.reduce((sum, { amount }) => sum + amount, 0);

const totalCount = monthlyInvoices.length;
const paidPercent =
	totalCount > 0 ? Math.round((paidCount / totalCount) * 100) : 0;

const summaryStats = [
	{
		title: "Total Pemasukan",
		value: `Rp ${totalRevenue.toLocaleString("id-ID")}`,
		desc: `${params.from} s/d ${params.to}`,
		icon: "line-md:edit-filled",
	},
	{
		title: "Sudah Terbayar",
		value: `${paidCount} Invoice`,
		desc: `${paidPercent}% dari total tagihan`,
		icon: "line-md:circle-to-confirm-circle-transition",
	},
	{
		title: "Belum Terbayar",
		value: `${unpaidCount} Invoice`,
		desc: `Rp ${outstandingAmount.toLocaleString("id-ID")} outstanding`,
		icon: "line-md:close-circle",
	},
];

// 2. Query filtered invoices using spread-based conditional where clause
const filteredInvoicesFromDb = await db.query.invoices.findMany({
	where: {
		dueDate: {
			gte: startDate,
			lte: endDate,
		},
		...(params.status && params.status !== "all" && { status: params.status }),
	},
	with: {
		lease: {
			with: {
				tenant: true,
				room: true,
			},
		},
	},
});

const filteredInvoices = filteredInvoicesFromDb.map((inv) => {
	return {
		id: inv.id,
		invoiceNumber: `INV-${inv.id.toString().padStart(6, "0")}`,
		tenantName: inv.lease?.tenant?.fullName ?? "-",
		roomNumber: inv.lease?.room?.roomNumber ?? "-",
		amount: inv.amount,
		dueDate: inv.dueDate,
		status: inv.status,
		gatewayRef: inv.duitkuReference ?? "-",
		duitkuReference: inv.duitkuReference,
	};
});

const STAT_COLORS: Record<string, string> = {
	"Total Pemasukan": "bg-success/40 text-base-content",
	"Sudah Terbayar": "bg-success/40 text-base-content",
	"Belum Terbayar": "bg-error/40 text-base-content",
};

const STATUS_LABELS = {
	paid: "Lunas",
	unpaid: "Belum Bayar",
	overdue: "Terlambat",
};

const STATUS_BADGES: Record<string, string> = {
	paid: "badge-success",
	unpaid: "badge-warning",
	overdue: "badge-error",
};
---

<DashboardLayout title="Laporan Transaksi ">
	<div class="flex flex-col gap-6" id="transactions-content-wrapper">
		{
			(formResult || redirectResult) && (
				<div
					id="form-result"
					class:list={[
						"alert",
						(formResult ?? redirectResult)?.success
							? "alert-success"
							: "alert-error",
					]}
				>
					<span set:html={(formResult ?? redirectResult)?.message ?? ""} />
				</div>
			)
		}

		<div
			class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
		>
			<div class="flex flex-col gap-1">
				<h1 class="text-3xl font-bold">Laporan Transaksi</h1>
				<p class="text-base-content/60 text-sm">
					Rekapitulasi tagihan dan riwayat pembayaran sewa bulanan penghuni
				</p>
			</div>
			<div class="flex items-center gap-2">
				<a
					class="btn btn-outline btn-sm flex items-center gap-1"
					href={`/dashboard/report/transactions/report/download${Astro.url.search}`}
					download
				>
					<Icon name="line-md:download" /> PDF
				</a>
				<button class="btn btn-outline btn-sm flex items-center gap-1">
					<Icon name="line-md:download" /> Export Excel
				</button>
			</div>
		</div>

		<div class="card bg-base-100 border-base-300 border shadow-sm">
			<div
				class="card-body flex flex-col items-center justify-between gap-3 p-4 sm:flex-row"
				hx-include=".filter-transactions"
				hx-select="#transactions-content-wrapper"
				hx-swap="outerHTML transition:true"
				hx-target="#transactions-content-wrapper"
			>
				<div class="flex w-full items-center gap-3 sm:w-auto">
					<Icon
						class="text-primary shrink-0"
						name="line-md:calendar"
						size="size-5"
					/>
					<span
						class="text-base-content/75 hidden text-sm font-semibold md:inline"
						>Pilih Periode:</span
					>
					<input
						hx-get
						hx-trigger="change"
						class="input input-sm filter-transactions w-full sm:w-40"
						name="from"
						type="month"
						value={params.from}
					/>
					<span class="text-base-content/70 text-sm font-semibold">Sampai:</span
					>
					<input
						hx-get
						hx-trigger="change"
						class="input input-sm filter-transactions w-full sm:w-40"
						name="to"
						type="month"
						value={params.to}
						min={params.from}
					/>
				</div>
				<div class="flex w-full justify-end gap-2 sm:w-auto">
					<select
						hx-get
						class="select select-sm filter-transactions w-32"
						name="status"
					>
						<option
							value="all"
							selected={params.status === "all" || !params.status}
						>
							Semua Status
						</option>
						<option value="paid" selected={params.status === "paid"}>
							Lunas
						</option>
						<option value="unpaid" selected={params.status === "unpaid"}>
							Belum Bayar
						</option>
						<option value="overdue" selected={params.status === "overdue"}>
							Terlambat
						</option>
					</select>
				</div>
			</div>
		</div>

		<div class="grid grid-cols-1 gap-4 sm:grid-cols-3">
			{
				summaryStats.map(({ title, value, desc, icon }) => (
					<div class="card bg-base-100 border-base-300 border shadow-sm">
						<div class="card-body flex-row items-center gap-3 p-5">
							<div class:list={["flex rounded-xl p-3", STAT_COLORS[title]]}>
								<Icon name={icon as any} size="size-7" />
							</div>
							<div class="flex flex-col">
								<span class="text-base-content/60 text-xs font-semibold">
									{title}
								</span>
								<span class="text-2xl font-bold">{value}</span>
								<span class="text-base-content/50 mt-0.5 text-xs">{desc}</span>
							</div>
						</div>
					</div>
				))
			}
		</div>

		<div class="card bg-base-100 border-base-300 border shadow-sm">
			<div class="card-body p-0">
				<div class="overflow-x-auto">
					<table class="table-zebra table w-full">
						<thead>
							<tr class="border-base-300 border-b">
								<th class="text-base-content/60 text-xs font-bold"
									>No. Invoice</th
								>
								<th class="text-base-content/60 text-xs font-bold">Penghuni</th>
								<th class="text-base-content/60 text-xs font-bold">Kamar</th>
								<th class="text-base-content/60 text-xs font-bold">Nominal</th>
								<th class="text-base-content/60 text-xs font-bold"
									>Jatuh Tempo</th
								>
								<th class="text-base-content/60 text-xs font-bold">Status</th>
								<th class="text-base-content/60 text-xs font-bold"
									>Ref. Gateway</th
								>
								<th class="text-base-content/60 text-xs font-bold">Aksi</th>
							</tr>
						</thead>
						<tbody>
							{
								filteredInvoices.map(
									({
										id,
										invoiceNumber,
										tenantName,
										roomNumber,
										amount,
										dueDate,
										status,
										gatewayRef,
										duitkuReference,
									}) => (
										<tr
											class="border-base-200 hover:bg-base-200/40 border-b transition-colors"
											data-id={id}
										>
											<td class="text-primary font-mono text-xs font-bold">
												{invoiceNumber}
											</td>
											<td class="text-sm font-semibold">{tenantName}</td>
											<td>
												<span class="badge badge-neutral font-mono font-semibold">
													{roomNumber}
												</span>
											</td>
											<td class="font-mono text-sm font-semibold">
												Rp {amount.toLocaleString("id-ID")}
											</td>
											<td class="text-base-content/70 font-mono text-xs">
												{formatDate(dueDate)}
											</td>
											<td>
												<span
													class:list={[
														"badge badge-sm font-bold",
														STATUS_BADGES[status],
													]}
												>
													{STATUS_LABELS[status]}
												</span>
											</td>
											<td
												class="text-base-content/60 max-w-32 truncate font-mono text-xs"
												title={gatewayRef}
											>
												{gatewayRef}
											</td>
											<td>
												{status === "paid" ? (
													<span class="text-base-content/40 text-xs">-</span>
												) : duitkuReference ? (
													<div class="flex items-center gap-1">
														<button
															class="btn btn-ghost btn-xs"
															title="Salin Link Bayar"
															onclick={`navigator.clipboard.writeText("https://app-sandbox.duitku.com/redirect_checkout?reference=${duitkuReference}"); this.innerHTML = "<span class='text-xs'>Tersalin!</span>"; setTimeout(() => this.innerHTML = "<span class=\"iconify\" data-icon=\"line-md:content-copy\"></span>", 2000)`}
														>
															<span
																class="iconify"
																data-icon="line-md:content-copy"
																data-width="14"
															/>
														</button>
														<a
															class="btn btn-ghost btn-xs"
															href={`https://app-sandbox.duitku.com/redirect_checkout?reference=${duitkuReference}`}
															title="Buka Pembayaran"
															target="_blank"
														>
															<span
																class="iconify"
																data-icon="line-md:external-link"
																data-width="14"
															/>
														</a>
													</div>
												) : (
													<button
														hx-post="/dashboard/manage/invoices/generate-link"
														class="btn btn-primary btn-xs"
														name="invoice_id"
														value={id}
														hx-select="#transactions-content-wrapper"
														hx-swap="outerHTML transition:true"
														hx-target="#transactions-content-wrapper"
														hx-vals={JSON.stringify({
															invoice_id: id,
														})}
													>
														Generate Link
													</button>
												)}
											</td>
										</tr>
									),
								)
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</DashboardLayout>
