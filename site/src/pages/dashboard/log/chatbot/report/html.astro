---
import { formatDate } from "@e-kos/utilities/date";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	chatbotQuerySchema,
	DIRECTION_LABELS,
	fetchChatbotLogs,
} from "../_data";

const params = Astro.locals.parseQuery(chatbotQuerySchema);

const chatbotLogs = await fetchChatbotLogs(params);

const filterParts: string[] = [];
if (params.direction) {
	filterParts.push(`Arah: ${DIRECTION_LABELS[params.direction]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}

const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Percakapan Chatbot" subtitle={subtitle}>
	<table>
		<thead>
			<tr>
				<th style="width: 18%;">Waktu</th>
				<th style="width: 18%;">Penghuni</th>
				<th style="width: 10%;">Kamar</th>
				<th style="width: 10%;">Arah</th>
				<th style="width: 44%;">Isi Pesan</th>
			</tr>
		</thead>
		<tbody>
			{
				chatbotLogs.map((row) => (
					<tr>
						<td style="font-family: 'Courier New', monospace; font-size: 10px; white-space: nowrap;">
							{formatDate(row.sentAt, "DD MMM YYYY HH:mm")}
						</td>
						<td style="font-weight: 600;">{row.tenantName}</td>
						<td style="font-family: 'Courier New', monospace; text-align: center;">
							{row.roomNumber}
						</td>
						<td style="text-align: center;">
							{DIRECTION_LABELS[row.direction]}
						</td>
						<td style="max-width: 300px; word-break: break-word;">
							{row.message}
						</td>
					</tr>
				))
			}
		</tbody>
	</table>
</ReportLayout>
