---
import { db } from "@indekos/database";

import { actions } from "astro:actions";

import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";

export const partial = true;

const tenant = await db.query.tenants.findFirst({
	columns: { id: true, fullName: true },
	where: { id: Number(Astro.params.id) },
});

if (!tenant) Astro.response.status = 404;
---

<Modal
	id="terminate_lease"
	title="Akhiri Sewa"
	icon="lucide:user-x"
	iconClass="text-error"
>
	{
		tenant ? (
			<>
				<p class="mb-4 text-sm text-base-content/70">
					Apakah Anda yakin ingin menandai penghuni{" "}
					<strong>{tenant.fullName}</strong> telah keluar? Kontrak sewa aktif
					mereka akan diakhiri hari ini dan kamar yang bersangkutan akan kembali
					kosong/tersedia.
				</p>

				<ModalForm
					action={actions.manage.tenants.terminate}
					hidden
					modalId="terminate_lease"
					submitClass="btn-error"
					submitLabel="Konfirmasi Akhiri"
					target="#form_result, #tenants-content-wrapper"
				>
					<input name="id" type="hidden" value={tenant.id} />
				</ModalForm>
			</>
		) : (
			<NotFound label="Penghuni" />
		)
	}
</Modal>
