---
import ReportTableEmpty from "~/components/data/report-table-empty.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import {
	fetchNotifications,
	NOTIFICATION_TYPE_LABELS,
	notificationQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(notificationQuerySchema);

const mappedNotifications = await fetchNotifications(params);

// Build subtitle
const subtitleParts: string[] = [];
if (params.type) {
	subtitleParts.push(
		`Jenis: ${NOTIFICATION_TYPE_LABELS[params.type as keyof typeof NOTIFICATION_TYPE_LABELS]}`,
	);
}
const subtitle =
	subtitleParts.length > 0 ? subtitleParts.join(" | ") : undefined;

const total = mappedNotifications.length;
---

<ReportLayout title="Laporan Riwayat Notifikasi" subtitle={subtitle}>
	<!-- Table -->
	<table>
		<thead>
			<tr>
				<th style="width: 22%;">Waktu Kirim</th>
				<th style="width: 28%;">Penghuni</th>
				<th style="width: 18%;">No. Invoice</th>
				<th style="width: 16%;">Jenis</th>
				<th style="width: 16%;">Status</th>
			</tr>
		</thead>
		<tbody>
			{
				mappedNotifications.length === 0 ? (
					<ReportTableEmpty
						colspan={5}
						message="Tidak ada data notifikasi yang sesuai dengan filter."
					/>
				) : (
					mappedNotifications.map(
						({ time, tenantName, roomNumber, invoiceNumber, type, status }) => (
							<tr>
								<td style="font-family: 'Courier New', monospace; font-size: 10px;">
									{formatDate(time, "DD MMM YYYY HH:mm")}
								</td>
								<td>
									{tenantName}
									<span style="font-family: 'Courier New', monospace; font-size: 10px; opacity: 0.6; margin-left: 4px;">
										({roomNumber})
									</span>
								</td>
								<td style="font-family: 'Courier New', monospace; font-weight: 600;">
									{invoiceNumber}
								</td>
								<td>
									{
										NOTIFICATION_TYPE_LABELS[
											type as keyof typeof NOTIFICATION_TYPE_LABELS
										]
									}
								</td>
								<td style="font-weight: 600;">{status}</td>
							</tr>
						),
					)
				)
			}
		</tbody>
		<tfoot>
			<tr>
				<td
					colspan="5"
					style="border: 1px solid black; padding: 8px; font-weight: 700; background: #f3f4f6;"
				>
					Total notifikasi: {total}
				</td>
			</tr>
		</tfoot>
	</table>
</ReportLayout>
