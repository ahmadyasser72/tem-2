---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import Icon from "~/components/icon.astro";
import { formatDate } from "~/lib/date";

export const partial = true;

const log = await db.query.auditLogs.findFirst({
	where: { id: Number(Astro.params.id) },
	with: { user: true },
});

const auditLog = log
	? {
			id: log.id,
			time: log.createdAt,
			userName: log.user?.username ?? "Sistem",
			action: log.action,
			table: log.tableName,
			recordId: log.recordId,
		}
	: null;

const ACTION_BADGES: Record<string, string> = {
	CREATE: "badge-success text-white",
	UPDATE: "badge-warning text-white",
	DELETE: "badge-error text-white",
};

if (!log) Astro.response.status = 404;
---

<dialog class="modal" id="delete_audit_modal">
	{
		auditLog ? (
			<div class="modal-box">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>

				<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
					<Icon class="text-primary" name="line-md:document" size="size-6" />
					Hapus audit log berikut?
				</h3>

				<div class="grid grid-cols-2 gap-2 text-sm border-b border-base-200 pb-4">
					<span class="font-bold">Pengguna:</span>
					<span>{auditLog.userName}</span>
					<span class="font-bold">Jenis Aksi:</span>
					<span class:list={["badge badge-xs font-bold", ACTION_BADGES[auditLog.action]]}>
						{auditLog.action}
					</span>
					<span class="font-bold">Tabel Target:</span>
					<span class="font-mono text-xs text-primary font-semibold">{auditLog.table}</span>
					<span class="font-bold">ID Record:</span>
					<span class="font-mono text-xs">{auditLog.recordId}</span>
					<span class="font-bold">Waktu:</span>
					<span>{formatDate(auditLog.time, "DD MMM YYYY HH:mm:ss")}</span>
				</div>

				<form
					hx-post={actions.manage.audit.remove}
					class="hidden"
					id="delete_audit_form"
					hx-on--after-request="event.detail.successful && delete_audit_modal.close()"
					hx-select-oob="#form_result, #audit-table-body"
					hx-swap="none transition:true"
					action={actions.manage.audit.remove}
					method="post"
				>
					<input name="id" type="hidden" value={auditLog.id} />
				</form>

				<p id="form_error" />

				<div class="modal-action">
					<form class="flex gap-2" method="dialog">
						<button class="btn btn-outline btn-sm">Batal</button>
						<button
							class="btn btn-error btn-sm"
							type="submit"
							form="delete_audit_form"
						>
							Hapus
						</button>
					</form>
				</div>
			</div>
		) : (
			<div class="modal-box">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>

				<h3 class="mb-4 flex items-center gap-2 text-xl font-bold">
					<Icon class="text-primary" name="line-md:document" size="size-6" />
					Hapus Audit Log
				</h3>

				<p class="py-4">Audit log dengan ID: {Astro.params.id} tidak ditemukan.</p>
			</div>
		)
	}
	<form class="modal-backdrop" method="dialog">
		<button>close</button>
	</form>
</dialog>
