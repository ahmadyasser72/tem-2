---
import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import {
	chatbotQuerySchema,
	DIRECTION_BADGES,
	DIRECTION_ICONS,
	DIRECTION_LABELS,
	fetchChatbotLogs,
} from "./_data";

const params = Astro.locals.parseQuery(chatbotQuerySchema);

const chatbotLogs = await fetchChatbotLogs(params);
---

<DashboardLayout
	title="Log Chatbot"
	description="Riwayat interaksi percakapan WhatsApp antara penghuni dan sistem Chatbot Indekos Ungu"
	pageTitle="Log Percakapan Chatbot"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/log/chatbot/report/download${Astro.url.search}`}
			download
		>
			<Icon name="line-md:download" /> PDF
		</a>
	</Fragment>

	<FilterToolbar name="chatbot" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="chatbot"
				groups={[
					{
						title: "Arah percakapan",
						name: "direction",
						options: [
							{
								value: "incoming",
								label: "Masuk",
								checked: params.direction === "incoming",
							},
							{
								value: "outgoing",
								label: "Keluar",
								checked: params.direction === "outgoing",
							},
						],
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-chatbot"
				placeholder="Cari pesan atau penghuni..."
			/>
		</Fragment>
	</FilterToolbar>

	<div
		class="border-base-300 rounded-box overflow-x-auto border shadow-sm"
		id="chatbot-content-wrapper"
	>
		<table class="table-sm table w-full">
			<thead>
				<tr>
					<th class="w-48">Waktu</th>
					<th class="w-44">Penghuni</th>
					<th class="w-32">Arah</th>
					<th>Isi Pesan</th>
					<th class="w-16 text-right">Aksi</th>
				</tr>
			</thead>
			<tbody id="chatbot-table-body">
				{
					chatbotLogs.map(
						({ id, time, tenantName, roomNumber, direction, message }) => (
							<tr data-id={id}>
								<td class="font-mono whitespace-nowrap">
									{formatDate(time, "DD MMM YYYY HH:mm:ss")}
								</td>
								<td>
									{tenantName}
									<span class="badge badge-neutral badge-xs font-mono">
										{roomNumber}
									</span>
								</td>
								<td>
									<span
										class:list={[
											"badge badge-sm flex items-center gap-1 font-bold",
											DIRECTION_BADGES[
												direction as keyof typeof DIRECTION_BADGES
											],
										]}
									>
										<Icon
											name={
												DIRECTION_ICONS[
													direction as keyof typeof DIRECTION_ICONS
												] as any
											}
											size="size-3"
										/>
										{
											DIRECTION_LABELS[
												direction as keyof typeof DIRECTION_LABELS
											]
										}
									</span>
								</td>
								<td class="max-w-lg wrap-break-word">{message}</td>
								<td class="text-right">
									{Astro.locals.canEdit() && (
										<button
											hx-get={`/dashboard/log/chatbot/modal/delete/${id}`}
											class="btn btn-square btn-ghost btn-xs text-error"
										>
											<Icon name="line-md:close" size="size-4" />
										</button>
									)}
								</td>
							</tr>
						),
					)
				}
			</tbody>
		</table>
	</div>
</DashboardLayout>
