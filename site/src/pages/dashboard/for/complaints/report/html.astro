---
import { formatDate } from "@indekos/utilities/date";

import ReportStats from "~/components/data/report-stats.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import { PERIOD_SEPARATOR_UI } from "~/lib/query";
import {
	COMPLAINT_STATUS_LABELS,
	complaintQuerySchema,
	fetchComplaints,
	getComplaintStats,
} from "../_data";

const params = Astro.locals.parseQuery(complaintQuerySchema);

const complaints = await fetchComplaints(params);
const stats = getComplaintStats(complaints);

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${COMPLAINT_STATUS_LABELS[params.status]}`);
}
if (params.period) {
	const { from, to } = params.period;
	filterParts.push(
		from.isSame(to, "day")
			? `Per ${formatDate(from, "DD MMMM YYYY")}`
			: `Periode ${[from, to].map((date) => formatDate(date, "DD MMMM YYYY")).join(PERIOD_SEPARATOR_UI)}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Komplain Penghuni" subtitle={subtitle}>
	<ReportStats stats={stats} />

	<table>
		<thead>
			<tr>
				<th>No.</th>
				<th>Penghuni</th>
				<th>Kamar</th>
				<th>Deskripsi</th>
				<th>Status</th>
				<th>Tanggal Lapor</th>
				<th>Ditangani Oleh</th>
				<th>Tanggal Selesai</th>
			</tr>
		</thead>
		<tbody>
			{
				complaints.map(
					(
						{
							tenantName,
							roomNumber,
							description,
							status,
							createdAt,
							resolvedAt,
							resolvedByUserName,
						},
						idx,
					) => (
						<tr>
							<td class="text-center">{idx + 1}</td>
							<td>{tenantName}</td>
							<td class="text-center">{roomNumber}</td>
							<td>{description}</td>
							<td class="text-center">{COMPLAINT_STATUS_LABELS[status]}</td>
							<td class="text-center">{formatDate(createdAt)}</td>
							<td>{resolvedByUserName ?? "-"}</td>
							<td class="text-center">
								{resolvedAt ? formatDate(resolvedAt) : "-"}
							</td>
						</tr>
					),
				)
			}
		</tbody>
	</table>
</ReportLayout>
