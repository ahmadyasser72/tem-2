---
import { db } from "@indekos/database";
import { config } from "@indekos/utilities/brand";
import dayjs, { formatDate } from "@indekos/utilities/date";

import Icon from "~/components/ui/icon.astro";

import "~/styles/report.css";

export interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
const today = dayjs().format("DD MMMM YYYY");

const { user } = Astro.locals;
let createdBy = "Staff";
// admin/owner create -> generic staff
if (user && user.role === "staff") createdBy = user.name;

const owner = await db.query.users.findFirst({
	where: { role: "owner" },
	columns: { displayName: true },
});
const knownBy = owner?.displayName ?? "Pemilik Kos";
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="utf-8" />
		<title>{title}</title>
	</head>
	<body class="report-body">
		<div class="mb-4 border-b-2 border-black pb-2.5">
			<div class="flex items-center gap-4">
				<div
					class="flex size-14 shrink-0 items-center justify-center rounded-full bg-gray-700 text-xl font-bold text-white"
				>
					<Icon name="lucide:house" size="size-6" />
				</div>
				<div class="flex-1 text-center">
					<div class="text-xl font-bold tracking-wide uppercase">
						{config.siteName}
					</div>
					<div class="my-1 border-b border-black"></div>
					<div class="text-[11px] opacity-70">
						{config.address} · Telp: {config.phone}
					</div>
				</div>
			</div>
		</div>

		<div class="mb-4 text-center">
			<h2 class="text-sm font-bold tracking-[0.5px] uppercase underline">
				{title}
			</h2>
			{subtitle && <p class="mt-1 text-[11px] opacity-70">{subtitle}</p>}
		</div>

		<div class="mb-3 text-[10px] opacity-60">
			Dicetak: {formatDate(new Date(), "DD MMMM YYYY HH:mm")}
		</div>

		<slot />

		<div
			class="mt-12 grid grid-cols-2 place-items-center gap-10 text-center text-[11px] *:w-64"
		>
			<div>
				<p>Banjarbaru, {today}</p>
				<p class="mt-1 font-semibold">Dibuat oleh</p>
				<p class="text-[10px] capitalize opacity-60">
					({user?.role ?? "Staff"})
				</p>
				<br />
				<br />
				<div class="mt-10 border-t-2 border-black pt-1">
					<p>{createdBy}</p>
				</div>
			</div>
			<div>
				<p>Banjarbaru, {today}</p>
				<p class="mt-1 font-semibold">Diketahui oleh</p>
				<p class="text-[10px] opacity-60">(Pemilik Kos)</p>
				<br />
				<br />
				<div class="mt-10 border-t-2 border-black pt-1">
					<p>{knownBy}</p>
				</div>
			</div>
		</div>
	</body>
</html>

<script>
	import "iconify-icon";

	import { loadIcon } from "iconify-icon";

	if (import.meta.env.PROD) {
		window.addEventListener("load", async () => {
			await loadIcon("lucide:house");
			window.print();
			window.close();
		});
	}
</script>
