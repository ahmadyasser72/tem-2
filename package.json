{
	"name": "@indekos/workspaces",
	"private": true,
	"license": "AGPL-3.0",
	"type": "module",
	"workspaces": [
		"packages/*",
		"site"
	],
	"scripts": {
		"check": "pacwich run check",
		"pretest": "DATABASE_PATH=$(pwd)/test.db.sqlite bun --cwd=packages/database --sequential db:push db:seed",
		"test": "DATABASE_PATH=$(pwd)/test.db.sqlite bun test --sequential",
		"dev": "pacwich run dev",
		"prebuild": "bun --cwd=packages/database --sequential db:push db:seed",
		"build": "pacwich run build @indekos/site",
		"start": "pacwich run start",
		"wa:login": "bun --cwd=packages/whatsapp-bot run login",
		"wa:logout": "bun --cwd=packages/whatsapp-bot run logout",
		"scheduler:trigger": "bun --cwd=packages/scheduler run trigger",
		"format": "prettier . --write",
		"format:check": "prettier . --check",
		"docs:build-css": "bunx @tailwindcss/cli -i docs/wireframe-v2/src/style.css -o docs/wireframe-v2/dist/style.css"
	},
	"devDependencies": {
		"@ianvs/prettier-plugin-sort-imports": "4.7.1",
		"@types/bun": "1.3.14",
		"@types/node": "26.0.1",
		"@xeonlink/prettier-plugin-organize-attributes": "1.1.0",
		"daisyui": "5.6.3",
		"pacwich": "0.2.1",
		"prettier": "3.9.1",
		"prettier-plugin-astro": "0.14.1",
		"prettier-plugin-tailwindcss": "0.7.4",
		"puppeteer-core": "25.2.1",
		"tailwindcss": "4.3.1"
	}
}
