---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";
import { z } from "astro/zod";
import { pick } from "es-toolkit";

import Alert from "~/components/alert.astro";
import Icon from "~/components/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";

const params = Astro.locals.parseQuery(
	z.object({
		query: z.string().catch(""),
		action: z.enum(["CREATE", "UPDATE", "DELETE"]).optional().catch(undefined),
	}),
);

const logsFromDb = await db.query.auditLogs.findMany({
	where: {
		...(params.query && {
			OR: [
				{ action: { like: `%${params.query}%` } },
				{ tableName: { like: `%${params.query}%` } },
				{ recordId: { like: `%${params.query}%` } },
				{
					user: {
						username: { like: `%${params.query}%` },
					},
				},
			],
		}),
		...(params.action && { action: params.action }),
	},
	with: { user: true },
	orderBy: { createdAt: "desc" },
});

const auditLogs = logsFromDb.map((log) => {
	return {
		id: log.id,
		time: log.createdAt,
		username: log.user?.username ?? "Sistem",
		action: log.action,
		table: log.tableName,
		recordId: log.recordId,
		details: log.details,
	};
});

const ACTION_BADGES: Record<string, string> = {
	CREATE: "badge-success text-white",
	UPDATE: "badge-warning text-white",
	DELETE: "badge-error text-white",
};

const formResult = (():
	| { success: false; message: string }
	| { success: true; title: string; description: string }
	| void => {
	const removeResult = Astro.getActionResult(actions.manage.audit.remove);
	if (removeResult?.error)
		return { success: false, message: removeResult.error.message };
	else if (removeResult?.data) {
		return {
			success: true,
			title: "Hapus Audit Log",
			description: "Audit log berhasil dihapus dari database!",
		};
	}
})();
---

{
	formResult?.success === false && (
		<Alert id="form_error" type="error" description={formResult.message} />
	)
}

<DashboardLayout title="Audit Log ">
	<div class="flex flex-col gap-6">
		{
			formResult?.success ? (
				<Alert
					id="form_result"
					type="info"
					{...pick(formResult, ["title", "description"])}
				/>
			) : (
				<p id="form_result" />
			)
		}

		<div class="flex flex-col gap-1">
			<h1 class="text-3xl font-bold">Audit Log Sistem</h1>
			<p class="text-base-content/60 text-sm">
				Jejak rekaman log aktivitas mutasi data dan operasional yang dilakukan
				oleh pengguna
			</p>
		</div>

		<div class="card bg-base-100 border-base-300 border shadow-sm">
			<div class="card-body p-0">
				<div
					class="border-base-200 flex flex-col gap-3 border-b p-5 sm:flex-row sm:items-center sm:justify-between"
					hx-include=".filter-audit"
					hx-select="#audit-table-body"
					hx-swap="outerHTML transition:true"
					hx-target="#audit-table-body"
				>
					<label class="input input-sm max-w-xs flex-1">
						<Icon name="line-md:search" size="size-4" />
						<input
							hx-get
							hx-trigger="input changed delay:300ms"
							class="filter-audit"
							name="query"
							type="search"
							value={params.query}
							placeholder="Cari aksi, tabel, atau pengguna..."
						/>
					</label>
					<div class="flex gap-2">
						<select
							hx-get
							class="select select-sm filter-audit w-32"
							name="action"
						>
							<option value="all" selected={!params.action}>
								Aksi (Semua)
							</option>
							<option value="CREATE" selected={params.action === "CREATE"}>
								CREATE
							</option>
							<option value="UPDATE" selected={params.action === "UPDATE"}>
								UPDATE
							</option>
							<option value="DELETE" selected={params.action === "DELETE"}>
								DELETE
							</option>
						</select>
					</div>
				</div>

				<div class="overflow-x-auto">
					<table class="table w-full">
						<thead>
							<tr class="border-base-300 border-b">
								<th class="text-base-content/60 w-48 text-xs font-bold"
									>Waktu Kejadian</th
								>
								<th class="text-base-content/60 text-xs font-bold">Pengguna</th>
								<th class="text-base-content/60 w-32 text-xs font-bold"
									>Jenis Aksi</th
								>
								<th class="text-base-content/60 text-xs font-bold"
									>Tabel Target</th
								>
								<th class="text-base-content/60 text-xs font-bold">ID Record</th
								>
								<th
									class="text-base-content/60 w-16 text-right text-xs font-bold"
									>Aksi</th
								>
							</tr>
						</thead>
						<tbody id="audit-table-body">
							{
								auditLogs.map(
									({
										id,
										time,
										username: userName,
										action,
										table,
										recordId,
										details,
									}) => (
										<tr class="border-base-200 hover:bg-base-200/40 border-b transition-colors">
											<td class="text-base-content/70 font-mono text-xs">
												{formatDate(time, "DD MMM YYYY HH:mm:ss")}
											</td>
											<td class="text-sm font-semibold">
												<div class="flex items-center gap-1.5">
													<Icon
														class="text-base-content/40"
														name="line-md:account"
														size="size-4"
													/>
													{userName}
												</div>
											</td>
											<td>
												{details ? (
													<div class="tooltip tooltip-right cursor-help" data-tip={details}>
														<span
															class:list={[
																"badge badge-xs font-bold underline decoration-dotted underline-offset-2",
																ACTION_BADGES[action],
															]}
														>
															{action}
														</span>
													</div>
												) : (
													<span
														class:list={[
															"badge badge-xs font-bold",
															ACTION_BADGES[action],
														]}
													>
														{action}
													</span>
												)}
											</td>
											<td class="text-primary font-mono text-xs font-semibold">
												{table}
											</td>
											<td class="font-mono text-xs">
												<span class="bg-base-200 border-base-300 rounded border px-2 py-0.5 font-bold">
													{recordId}
												</span>
											</td>
											<td class="pt-2 text-right">
												<button
													hx-get={`/dashboard/log/audit/modal/delete/${id}`}
													class="btn btn-square btn-ghost btn-xs text-error"
												>
													<Icon name="line-md:close" size="size-4" />
												</button>
											</td>
										</tr>
									),
								)
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</DashboardLayout>
