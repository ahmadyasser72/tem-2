@startuml

class User {
    + id: int
    + username: string
    + passwordHash: string
    + role: string
    + lastAccessed: timestamp

    + processComplaint(c: Complaint): void
}

class Tenant {
    + id: int
    + fullName: string
    + phoneNumber: string
    + originRegion: string
    + createdAt: timestamp

    + sendMessage(msg: string): void
    + createComplaint(desc: string): Complaint
}

class Room {
    + id: int
    + roomNumber: string
    + roomType: string
    + monthlyPrice: int
    + isActive: boolean
}

class Lease {
    + id: int
    + startDate: timestamp
    + endDate: timestamp
    + isActive: boolean

    + generateInvoice(): Invoice
}

class Invoice {
    + id: int
    + amount: int
    + dueDate: timestamp
    + duitkuReference: string
    + callbackPayload: string
    + status: string

    + markAsPaid(): void
}

class ChatbotMessage {
    + id: int
    + direction: string
    + message: string
    + sentAt: timestamp
}

class Notification {
    + id: int
    + type: string
    + status: string

    + send(): void
}

class Complaint {
    + id: int
    + description: string
    + status: string
    + createdAt: timestamp

    + resolve(): void
}

' RELATIONSHIPS (OBJECT-BASED)
Tenant "1" -- "*" Lease
Room "1" -- "*" Lease
Lease "1" -- "*" Invoice
Tenant "1" -- "*" ChatbotMessage
Tenant "1" -- "*" Notification
Tenant "1" -- "*" Complaint
User "1" -- "*" Complaint : processes
Invoice "1" -- "*" Notification

@enduml