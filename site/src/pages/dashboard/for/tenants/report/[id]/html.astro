---
import { db } from "@indekos/database";
import { formatDate } from "@indekos/utilities/date";
import {
	formatCurrency,
	formatInvoiceNumber,
} from "@indekos/utilities/transforms";

import { sumBy } from "es-toolkit";

import ReportLayout from "~/layouts/report-layout.astro";
import { INVOICE_STATUS_LABELS } from "~/pages/dashboard/for/transactions/_data";

const tenant = await db.query.tenants.findFirst({
	columns: { id: true, fullName: true, phoneNumber: true, originRegion: true },
	where: { id: Number(Astro.params.id) },
	with: {
		lease: {
			columns: { id: true, startDate: true, endDate: true, isActive: true },
			with: {
				room: { columns: { roomNumber: true } },
				invoices: { orderBy: { dueDate: "asc" } },
			},
		},
		leaseHistory: {
			columns: { id: true, startDate: true, endDate: true, isActive: true },
			with: {
				room: { columns: { roomNumber: true } },
				invoices: { orderBy: { dueDate: "asc" } },
			},
			orderBy: { startDate: "desc" },
		},
	},
});

if (!tenant) return Astro.redirect("/404");

const leaseGroups = [
	...(tenant.lease ? [tenant.lease] : []),
	...tenant.leaseHistory,
];
---

<ReportLayout
	title={`Laporan Penghuni: ${tenant.fullName}`}
	subtitle={`No. HP: +${tenant.phoneNumber}${tenant.originRegion ? ` · Asal: ${tenant.originRegion}` : ""}`}
>
	{
		leaseGroups.map((lease) => (
			<div class="mb-6">
				<table>
					<thead>
						<tr>
							<th class="text-left" colspan="6">
								Kamar {lease.room.roomNumber} &mdash;{" "}
								{formatDate(lease.startDate)} s/d{" "}
								{lease.endDate ? formatDate(lease.endDate) : "sekarang"}
								{lease.isActive ? " (Aktif)" : " (Selesai)"}
							</th>
						</tr>
						<tr>
							<th class="w-[5%] text-center">No</th>
							<th class="w-[25%]">No. Invoice</th>
							<th class="w-[20%]">Jatuh Tempo</th>
							<th class="w-[20%]">Dibayar</th>
							<th class="w-[15%] text-right">Nominal</th>
							<th class="w-[15%] text-center">Status</th>
						</tr>
					</thead>
					<tbody>
						{lease.invoices.length > 0 ? (
							lease.invoices.map((invoice, idx) => (
								<tr>
									<td class="text-center font-mono">{idx + 1}</td>
									<td class="font-mono">{formatInvoiceNumber(invoice)}</td>
									<td class="font-mono">{formatDate(invoice.dueDate)}</td>
									<td class="font-mono">
										{invoice.paidAt ? formatDate(invoice.paidAt) : "-"}
									</td>
									<td class="text-right font-mono">
										{formatCurrency(invoice.amount)}
									</td>
									<td class="text-center">
										{INVOICE_STATUS_LABELS[invoice.status]}
									</td>
								</tr>
							))
						) : (
							<tr>
								<td class="text-center" colspan="6">
									Tidak ada tagihan
								</td>
							</tr>
						)}
					</tbody>
					<tfoot>
						<tr>
							<td
								class="border border-black bg-gray-100 p-2 font-bold"
								colspan="6"
							>
								Total tagihan: {lease.invoices.length} | Lunas:{" "}
								{formatCurrency(
									sumBy(lease.invoices, ({ amount, status }) =>
										status === "paid" ? amount : 0,
									),
								)}
							</td>
						</tr>
					</tfoot>
				</table>
			</div>
		))
	}
</ReportLayout>
