---
import { formatDate } from "@e-kos/utilities/date";
import { formatCurrency } from "@e-kos/utilities/transforms";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	fetchTransactions,
	getTransactionStats,
	INVOICE_STATUS_LABELS,
	transactionQuerySchema,
} from "../_data";

const params = Astro.locals.parseQuery(
	transactionQuerySchema.omit({ query: true }),
);

const invoices = await fetchTransactions(params);
const { totalRevenue, paidCount, unpaidCount, outstandingAmount } =
	getTransactionStats(invoices);

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${INVOICE_STATUS_LABELS[params.status]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Transaksi Bulanan" subtitle={subtitle}>
	<div
		style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; margin-bottom: 24px;"
	>
		<div style="border: 1px solid black; padding: 12px 16px;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"
			>
				Total Pemasukan
			</div>
			<div
				style="font-size: 18px; font-weight: 700; font-family: 'Courier New', monospace;"
			>
				{formatCurrency(totalRevenue)}
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px 16px;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"
			>
				Sudah Terbayar
			</div>
			<div style="font-size: 18px; font-weight: 700;">
				{paidCount} Invoice
			</div>
		</div>
		<div style="border: 1px solid black; padding: 12px 16px;">
			<div
				style="font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 4px;"
			>
				Pembayaran Tertunggak
			</div>
			<div style="font-size: 18px; font-weight: 700;">
				{unpaidCount} Invoice
			</div>
			<div
				style="font-size: 11px; margin-top: 2px; font-family: 'Courier New', monospace;"
			>
				{formatCurrency(outstandingAmount)}
			</div>
		</div>
	</div>

	<table>
		<thead>
			<tr>
				<th style="text-align: center; width: 24px;">No</th>
				<th>No. Invoice</th>
				<th>Penghuni</th>
				<th style="width: 60px;">Kamar</th>
				<th style="text-align: right;">Nominal</th>
				<th>Jatuh Tempo</th>
				<th>Status</th>
			</tr>
		</thead>
		<tbody>
			{
				invoices.map(
					(
						{ invoiceNumber, tenantName, roomNumber, amount, dueDate, status },
						idx,
					) => (
						<tr>
							<td class="text-center">{idx + 1}</td>
							<td style="font-family: 'Courier New', monospace;">
								{invoiceNumber}
							</td>
							<td>{tenantName}</td>
							<td style="font-family: 'Courier New', monospace;">
								{roomNumber}
							</td>
							<td style="text-align: right; font-family: 'Courier New', monospace;">
								{formatCurrency(amount)}
							</td>
							<td style="font-family: 'Courier New', monospace;">
								{formatDate(dueDate)}
							</td>
							<td>{INVOICE_STATUS_LABELS[status]}</td>
						</tr>
					),
				)
			}
		</tbody>
	</table>
</ReportLayout>
