---
import { formatDate } from "@e-kos/utilities/date";

import ReportLayout from "~/layouts/report-layout.astro";
import {
	COMPLAINT_STATUS_LABELS,
	complaintQuerySchema,
	fetchComplaints,
	getComplaintStats,
} from "../_data";

const params = Astro.locals.parseQuery(complaintQuerySchema);

const complaints = await fetchComplaints(params);
const stats = getComplaintStats(complaints);

const filterParts: string[] = [];
if (params.status) {
	filterParts.push(`Status: ${COMPLAINT_STATUS_LABELS[params.status]}`);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Komplain Penghuni" subtitle={subtitle}>
	<div class="mb-4 grid grid-cols-4 gap-2">
		{
			stats.map((stat) => (
				<div class="border border-black p-2 text-center">
					<p class="mb-1 text-[10px] font-normal">{stat.title}</p>
					<p class="text-lg font-bold">{stat.value}</p>
				</div>
			))
		}
	</div>

	<p class="mb-2 text-sm font-bold">Daftar Komplain</p>

	<table>
		<thead>
			<tr>
				<th>No.</th>
				<th>Penghuni</th>
				<th>Kamar</th>
				<th>Deskripsi</th>
				<th>Status</th>
				<th>Tanggal Lapor</th>
				<th>Ditangani Oleh</th>
				<th>Tanggal Selesai</th>
			</tr>
		</thead>
		<tbody>
			{
				complaints.map(
					(
						{
							tenantName,
							roomNumber,
							description,
							status,
							createdAt,
							resolvedAt,
							resolvedByUserName,
						},
						idx,
					) => (
						<tr>
							<td class="text-center">{idx + 1}</td>
							<td>{tenantName}</td>
							<td class="text-center">{roomNumber}</td>
							<td>{description}</td>
							<td class="text-center">{COMPLAINT_STATUS_LABELS[status]}</td>
							<td class="text-center">{formatDate(createdAt)}</td>
							<td>{resolvedByUserName}</td>
							<td class="text-center">
								{resolvedAt ? formatDate(resolvedAt) : "-"}
							</td>
						</tr>
					),
				)
			}
		</tbody>
	</table>
</ReportLayout>
