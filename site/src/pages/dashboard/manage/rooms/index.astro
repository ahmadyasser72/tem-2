---
import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import FormResult from "~/components/form/form-result.astro";
import ActionsMenu from "~/components/ui/actions-menu.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { createActionResult } from "~/lib/form-result";
import { formatCurrency } from "~/lib/transforms";
import {
	fetchFilteredRooms,
	getAllRoomsStats,
	ROOM_STATUS_BADGES,
	ROOM_STATUS_LABELS,
	ROOM_TYPE_LABELS,
	ROOM_TYPES,
	roomQuerySchema,
} from "./_data";

const params = Astro.locals.parseQuery(roomQuerySchema);
const filteredRooms = await fetchFilteredRooms(params);

const roomStats = (await getAllRoomsStats(filteredRooms)).map((s) => ({
	...s,
	value: String(s.value),
}));
---

<FormResult
	actionResults={[
		createActionResult(
			actions.manage.rooms.add,
			"Tambah kamar",
			(d) => `Berhasil menambah kamar! (ID: ${d.id})`,
		),
		createActionResult(
			actions.manage.rooms.edit,
			"Edit kamar",
			(d) => `Berhasil edit kamar! (ID: ${d.id})`,
		),
	]}
/>

<DashboardLayout
	title="Manajemen Kamar"
	description="Kelola inventaris, spesifikasi, dan status hunian kamar indekos"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={"/dashboard/manage/rooms/report/download" + Astro.url.search}
			download
		>
			<Icon name="line-md:download" /> PDF
		</a>
		{
			Astro.locals.canEdit() && (
				<button
					hx-get="/dashboard/manage/rooms/modal/add"
					class="btn btn-sm btn-primary"
				>
					<Icon name="line-md:plus" size="size-5" />
					Tambah Kamar
				</button>
			)
		}
	</Fragment>

	<div
		class="flex items-center justify-end gap-2"
		hx-include=".filter-rooms"
		hx-select="#rooms-content-wrapper"
		hx-swap="outerHTML transition:true"
		hx-target="#rooms-content-wrapper"
	>
		<FilterPopover
			name="rooms"
			groups={[
				{
					title: "Status",
					name: "status",
					options: [
						{
							value: "occupied",
							label: "Terisi",
							checked: params.status === "occupied",
						},
						{
							value: "vacant",
							label: "Kosong",
							checked: params.status === "vacant",
						},
						{
							value: "inactive",
							label: "Nonaktif",
							checked: params.status === "inactive",
						},
					],
				},
				{
					title: "Tipe Kamar",
					name: "type",
					options: ROOM_TYPES.map((t) => ({
						value: t,
						label: ROOM_TYPE_LABELS[t],
						checked: params.type === t,
					})),
				},
			]}
		/>
		<SearchInput
			value={params.query}
			filterClass="filter-rooms"
			placeholder="Cari nomor/penghuni..."
		/>
	</div>

	<Stats items={roomStats} />

	<div
		class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4"
		id="rooms-content-wrapper"
	>
		{
			filteredRooms.map(
				({ id, roomNumber, roomType, monthlyPrice, isActive, tenantName }) => {
					const statusKey = !isActive
						? "inactive"
						: tenantName
							? "occupied"
							: "vacant";
					const price = formatCurrency(monthlyPrice);
					return (
						<div class="card bg-base-100 border-base-300 border shadow-sm transition-all hover:shadow-md">
							<div class="card-body gap-3 p-5">
								<div class="flex items-start justify-between">
									<div class="flex flex-col">
										<span class="text-base-content/50 text-xs font-bold">
											{roomType}
										</span>
										<span class="text-2xl font-bold">{roomNumber}</span>
									</div>
									<span
										class:list={[
											"badge badge-sm font-bold",
											ROOM_STATUS_BADGES[statusKey],
										]}
									>
										{ROOM_STATUS_LABELS[statusKey]}
									</span>
								</div>

								<div class="border-base-200 my-1 flex flex-col gap-1 border-t border-b py-3">
									<div class="flex justify-between text-xs">
										<span class="text-base-content/60">Harga Sewa:</span>
										<span class="font-mono font-bold">{price}/Bln</span>
									</div>
									<div class="mt-1 flex justify-between text-xs">
										<span class="text-base-content/60">Penghuni:</span>
										<span class="text-base-content max-w-30 truncate font-semibold">
											{tenantName || "-"}
										</span>
									</div>
								</div>

								<div class="card-actions flex-row gap-2">
									<button
										hx-get={"/dashboard/manage/rooms/modal/detail/" + id}
										class="btn btn-outline btn-primary btn-xs flex flex-1 items-center justify-center gap-1"
									>
										<Icon name="line-md:document-list" /> Detail
									</button>
									{Astro.locals.canEdit() && (
										<ActionsMenu
											id={id}
											menuClass="w-52"
											triggerIcon="line-md:chevron-up"
										>
											<li>
												<button
													hx-get={"/dashboard/manage/rooms/modal/edit/" + id}
													class="flex items-center gap-2"
												>
													<Icon name="line-md:edit" /> Edit Kamar
												</button>
											</li>
											<li>
												<button
													hx-get={"/dashboard/manage/rooms/modal/delete/" + id}
													class="text-error flex items-center gap-2"
												>
													<Icon name="line-md:remove" /> Hapus
												</button>
											</li>
										</ActionsMenu>
									)}
								</div>
							</div>
						</div>
					);
				},
			)
		}
	</div>
</DashboardLayout>
