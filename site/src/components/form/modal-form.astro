---
import ModalActions from "~/components/form/modal-actions.astro";

interface Props {
	modalId: string;
	action: string;
	target?: string;
	submitLabel: string;
	hidden?: boolean;
	submitClass?: string;
	cancelLabel?: string;
}

const {
	modalId,
	action,
	target,
	submitLabel,
	hidden = false,
	submitClass,
	cancelLabel,
} = Astro.props;
---

<form
	hx-post={action}
	class={hidden ? "hidden" : "flex flex-col gap-4"}
	id={`${modalId}_form`}
	hx-indicator={`#${modalId}_button`}
	hx-on--after-request={`event.detail.target instanceof HTMLFormElement && event.detail.successful && ${modalId}_modal.close()`}
	hx-select-oob={target ? `${target}, #form_error` : "#form_error"}
	hx-swap="none transition:true"
	action={action}
	method="post"
>
	<slot />
</form>
<p class="text-sm text-error" id="form_error"></p>
<div class="modal-action">
	<ModalActions
		buttonId={`${modalId}_button`}
		cancelLabel={cancelLabel}
		formId={`${modalId}_form`}
		label={submitLabel}
		submitClass={submitClass}
	/>
</div>
