---
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import {
	AUDIT_ACTION_LABELS,
	auditQuerySchema,
	fetchAuditLogs,
} from "../_data";

const params = Astro.locals.parseQuery(auditQuerySchema.omit({ query: true }));

const auditLogs = await fetchAuditLogs(params);

const filterParts: string[] = [];
if (params.action) {
	filterParts.push(
		`Aksi: ${params.action} (${AUDIT_ACTION_LABELS[params.action]})`,
	);
}
if (params.from) {
	filterParts.push(
		params.from !== params.to
			? `Periode: ${params.from} s/d ${params.to}`
			: `Periode: ${params.from}`,
	);
}
const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout title="Laporan Aktivitas Pengguna" subtitle={subtitle}>
	<table>
		<thead>
			<tr>
				<th style="width: 5%; text-align: center;">No.</th>
				<th style="width: 20%;">Waktu Kejadian</th>
				<th style="width: 18%;">Pengguna</th>
				<th style="width: 14%;">Jenis Aksi</th>
				<th style="width: 28%;">Tabel Target</th>
				<th style="width: 15%;">ID Record</th>
			</tr>
		</thead>
		<tbody>
			{
				auditLogs.map((row, idx) => (
					<>
						<tr>
							<td rowspan="2" style="text-align: center; font-size: 10px;">
								{idx + 1}
							</td>
							<td
								rowspan="2"
								style="font-family: 'Courier New', monospace; font-size: 10px;"
							>
								{formatDate(row.createdAt, "DD MMM YYYY HH:mm")}
							</td>
							<td rowspan="2">{row.displayName}</td>
							<td
								rowspan="2"
								style="font-weight: 700; text-transform: uppercase; text-align: center;"
							>
								{row.action}
							</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px;">
								{row.tableName}
							</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px; text-align: center;">
								{row.recordId ?? "-"}
							</td>
						</tr>
						<tr>
							<td colspan="2">{row.details?.description ?? "-"}</td>
						</tr>
					</>
				))
			}
		</tbody>
	</table>
</ReportLayout>
