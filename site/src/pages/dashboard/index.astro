---
import { db, ne } from "@indekos/database";
import { complaints } from "@indekos/database/schema";
import dayjs, { formatDate } from "@indekos/utilities/date";
import { formatCurrency } from "@indekos/utilities/transforms";

import { sumBy } from "es-toolkit";

import Stats from "~/components/data/stats.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import {
	COMPLAINT_STATUS_BADGES,
	COMPLAINT_STATUS_LABELS,
} from "~/pages/dashboard/manage/complaints/_data";

const now = dayjs();

const allRooms = await db.query.rooms.findMany({ with: { lease: true } });
const occupiedRooms = sumBy(allRooms, ({ lease }) => (lease ? 1 : 0));
const vacantRooms = sumBy(allRooms, ({ isActive, lease }) =>
	isActive && !lease ? 1 : 0,
);

const allTenants = await db.query.tenants.findMany({ with: { lease: true } });
const activeTenants = sumBy(allTenants, ({ lease }) => (lease ? 1 : 0));

const leasesEndingThisMonth = sumBy(allTenants, (tenant) => {
	if (tenant.lease && tenant.lease.endDate) {
		const end = dayjs(tenant.lease.endDate);
		if (end.isSame(now, "month") && end.isSame(now, "years")) return 1;
	}

	return 0;
});

const unpaidInvoices = await db.query.invoices.findMany({
	where: { status: "unpaid" },
	limit: 5,
	with: {
		lease: {
			with: {
				tenant: true,
				room: true,
			},
		},
	},
	orderBy: { dueDate: "asc" },
});

const totalUnpaidAmount = sumBy(unpaidInvoices, ({ amount }) => amount);
const totalUnpaid = unpaidInvoices.length;

const pendingBills = unpaidInvoices
	.slice(0, 5)
	.map(({ lease, dueDate, amount }) => {
		const due = dayjs(dueDate);
		const diffDays = due.diff(now, "days");
		const status = diffDays <= 0 ? "Overdue" : `H-${diffDays}`;
		return {
			tenant: lease.tenant.fullName,
			room: lease.room.roomNumber,
			dueDate,
			status,
			amount,
		};
	});

const recentComplaints = await db.query.complaints.findMany({
	with: {
		tenant: { with: { lease: { with: { room: true } } } },
	},
	orderBy: { createdAt: "desc" },
	limit: 5,
});
const activeComplaints = await db.$count(
	complaints,
	ne(complaints.status, "resolved"),
);

const stats = [
	{
		title: "Total Kamar",
		value: `${allRooms.length} Kamar`,
		desc: `${occupiedRooms} Terisi, ${vacantRooms} Kosong`,
		icon: "lucide:house" as const,
	},
	{
		title: "Penghuni Aktif",
		value: `${activeTenants} Orang`,
		desc: `${leasesEndingThisMonth} sewa berakhir bulan ini`,
		icon: "lucide:user" as const,
	},
	{
		title: "Tagihan Belum Bayar",
		value: formatCurrency(totalUnpaidAmount),
		desc: `${totalUnpaid} tagihan belum lunas`,
		icon: "lucide:file-text" as const,
	},
	{
		title: "Komplain Terbuka",
		value: `${activeComplaints} Komplain`,
		desc: `${recentComplaints.filter(({ status }) => status === "open").length} perlu tindakan segera`,
		icon: "lucide:circle-alert" as const,
	},
];

const getStatusBadge = (status: string) => {
	if (status === "Overdue") return "badge-error";
	const match = status.match(/H-(\d+)/);
	if (match) {
		const days = parseInt(match[1], 10);
		if (days <= 2) return "badge-error";
		if (days <= 5) return "badge-warning";
		return "badge-info";
	}

	return "badge-neutral";
};
---

<DashboardLayout
	title="Dashboard"
	description="Ringkasan operasional dan kondisi indekos saat ini"
>
	<Stats stats={stats} />

	<div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
		<div class="card border border-base-300 bg-base-100 shadow-sm">
			<div class="card-body p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="card-title text-lg font-bold">
						<Icon class="text-primary" name="lucide:file-text" size="size-5" />
						Tagihan Mendekati Jatuh Tempo
					</h2>
					{
						Astro.locals.user?.role !== "admin" && (
							<a
								class="btn btn-outline btn-primary btn-xs"
								href="/dashboard/report/transactions"
							>
								Lihat Semua
							</a>
						)
					}
				</div>
				<div class="overflow-x-auto">
					<table class="table w-full table-sm">
						<thead>
							<tr>
								<th>Penghuni</th>
								<th>Kamar</th>
								<th>Nominal</th>
								<th>Jatuh Tempo</th>
								<th>Status</th>
							</tr>
						</thead>
						<tbody>
							{
								pendingBills.map(
									({ tenant, room, dueDate, status, amount }) => (
										<tr>
											<td>{tenant}</td>
											<td>
												<span class="badge font-mono badge-neutral">
													{room}
												</span>
											</td>
											<td class="font-mono">{formatCurrency(amount)}</td>
											<td class="font-mono">{formatDate(dueDate)}</td>
											<td>
												<span
													class:list={[
														"badge badge-sm font-bold",
														getStatusBadge(status),
													]}
												>
													{status}
												</span>
											</td>
										</tr>
									),
								)
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
		<div class="card border border-base-300 bg-base-100 shadow-sm">
			<div class="card-body p-6">
				<div class="mb-4 flex items-center justify-between">
					<h2 class="card-title text-lg font-bold">
						<Icon class="text-error" name="lucide:circle-alert" size="size-5" />
						Komplain Terbaru
					</h2>
					{
						Astro.locals.user?.role !== "admin" && (
							<a
								class="btn btn-outline btn-primary btn-xs"
								href="/dashboard/manage/complaints"
							>
								{Astro.locals.user?.role === "staff" ? "Kelola" : "Lihat"}{" "}
								Komplain
							</a>
						)
					}
				</div>
				<div class="divide-y divide-base-200">
					{
						recentComplaints.map(
							({ description, createdAt, tenant, status }) => (
								<div class="flex items-start justify-between rounded-lg px-2 py-3.5 transition-colors first:pt-0 last:pb-0 hover:bg-base-200/20">
									<div class="flex flex-col gap-1">
										<span class="text-sm font-bold text-base-content">
											{description}
										</span>
										<div class="flex flex-wrap items-center gap-2 text-xs text-base-content/60">
											<span class="badge badge-ghost badge-sm">
												{tenant.lease?.room.roomNumber ?? "-"}
											</span>
											<span>&bull;</span>
											<span>{tenant.fullName}</span>
											<span>&bull;</span>
											<span>{formatDate(createdAt)}</span>
										</div>
									</div>
									<span
										class:list={[
											"badge badge-sm font-bold",
											COMPLAINT_STATUS_BADGES[status],
										]}
									>
										{COMPLAINT_STATUS_LABELS[status]}
									</span>
								</div>
							),
						)
					}
				</div>
			</div>
		</div>
	</div>
</DashboardLayout>
