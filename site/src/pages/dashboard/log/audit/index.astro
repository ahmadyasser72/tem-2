---
import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import FormResult from "~/components/form/form-result.astro";
import Icon from "~/components/ui/icon.astro";
import SearchInput from "~/components/data/search-input.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate } from "~/lib/date";
import { ACTION_BADGES, auditQuerySchema, fetchAuditLogs } from "./_data";

const params = Astro.locals.parseQuery(auditQuerySchema);

const showSystem = params.show_system !== undefined;

const auditLogs = await fetchAuditLogs(params);
---

<FormResult
	actionResults={[
		{
			action: actions.manage.audit.remove,
			title: "Hapus Audit Log",
			getDescription: () => "Audit log berhasil dihapus dari database!",
		},
	]}
/>

<DashboardLayout
	title="Audit Log"
	description="Jejak rekaman log aktivitas mutasi data dan operasional yang dilakukan oleh pengguna"
	pageTitle="Audit Log Sistem"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/log/audit/report/download${Astro.url.search}`}
			download
		>
			<Icon name="line-md:download" /> PDF
		</a>
	</Fragment>

	<FilterToolbar name="audit" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="audit"
				checkbox={{
					name: "show_system",
					label: "Tampilkan System",
					checked: showSystem,
				}}
				groups={[
					{
						title: "Jenis aksi",
						name: "action",
						options: [
							{
								value: "CREATE",
								label: "CREATE",
								checked: params.action === "CREATE",
							},
							{
								value: "UPDATE",
								label: "UPDATE",
								checked: params.action === "UPDATE",
							},
							{
								value: "DELETE",
								label: "DELETE",
								checked: params.action === "DELETE",
							},
						],
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-audit"
				placeholder="Cari aksi, tabel, atau pengguna..."
			/>
		</Fragment>
	</FilterToolbar>

	<div
		class="border-base-300 rounded-box overflow-x-auto border shadow-sm"
		id="audit-content-wrapper"
	>
		<table class="table-sm table w-full">
			<thead>
				<tr>
					<th class="w-48">Waktu Kejadian</th>
					<th>Pengguna</th>
					<th class="w-32">Jenis Aksi</th>
					<th>Tabel Target</th>
					<th>ID Record</th>
					<th class="w-16 text-right">Aksi</th>
				</tr>
			</thead>
			<tbody>
				{
					auditLogs.map(
						({ id, time, displayName, action, table, recordId, details }) => (
							<tr>
								<td class="font-mono">
									{formatDate(time, "DD MMM YYYY HH:mm:ss")}
								</td>
								<td>
									<div class="flex items-center gap-1.5">
										<Icon
											class="text-base-content/40"
											name="line-md:account"
											size="size-4"
										/>
										{displayName}
									</div>
								</td>
								<td>
									{details ? (
										<div
											class="tooltip tooltip-right cursor-help"
											data-tip={details}
										>
											<span
												class:list={[
													"badge badge-xs font-bold underline decoration-dotted underline-offset-2",
													ACTION_BADGES[action as keyof typeof ACTION_BADGES],
												]}
											>
												{action}
											</span>
										</div>
									) : (
										<span
											class:list={[
												"badge badge-xs font-bold",
												ACTION_BADGES[action as keyof typeof ACTION_BADGES],
											]}
										>
											{action}
										</span>
									)}
								</td>
								<td class="font-mono">{table}</td>
								<td class="font-mono">
									<span class="bg-base-200 border-base-300 rounded border px-2 py-0.5 font-bold">
										{recordId}
									</span>
								</td>
								<td class="text-right">
									<button
										hx-get={`/dashboard/log/audit/modal/delete/${id}`}
										class="btn btn-square btn-ghost btn-xs text-error"
									>
										<Icon name="line-md:close" size="size-4" />
									</button>
								</td>
							</tr>
						),
					)
				}
			</tbody>
		</table>
	</div>
</DashboardLayout>
