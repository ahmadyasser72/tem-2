---
import { NOTIFICATION_STATUS, NOTIFICATION_TYPES } from "@indekos/database";
import { formatDate } from "@indekos/utilities/date";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import Alert from "~/components/ui/alert.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import {
	fetchNotifications,
	getNotificationStats,
	NOTIFICATION_STATUS_BADGES,
	NOTIFICATION_STATUS_LABELS,
	NOTIFICATION_TYPE_BADGES,
	NOTIFICATION_TYPE_LABELS,
	notificationQuerySchema,
} from "./_data";

const params = Astro.locals.parseQuery(notificationQuerySchema);

const notifications = await fetchNotifications(params);
const notificationStats = getNotificationStats(notifications);
---

<DashboardLayout
	title="Laporan Notifikasi"
	description="Riwayat pengiriman notifikasi (tagihan, pengingat, komplain) via WhatsApp Chatbot"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			id="notifications-print"
			href={`/dashboard/report/notifications/report/download${Astro.url.search}`}
			hx-swap-oob="true"
			download
		>
			<Icon name="lucide:download" /> PDF
		</a>
	</Fragment>
	<Alert
		type="info"
		title="Sistem Otomatisasi Aktif"
		close={false}
		description="Sistem mengirimkan pesan pengingat tagihan (WhatsApp) otomatis setiap hari pukul 08.00 WITA untuk penyewa yang memiliki tagihan belum lunas mendekati H-3 jatuh tempo."
	/>

	<FilterToolbar name="notifications" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="notifications"
				groups={[
					{
						title: "Tipe Notifikasi",
						name: "type",
						options: NOTIFICATION_TYPES.map((type) => ({
							value: type,
							label: NOTIFICATION_TYPE_LABELS[type],
							checked: params.type === type,
						})),
					},
					{
						title: "Status Notifikasi",
						name: "status",
						options: Object.values(NOTIFICATION_STATUS).map((status) => ({
							value: status,
							label: NOTIFICATION_STATUS_LABELS[status],
							checked: params.status === status,
						})),
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-notifications"
				placeholder="Cari nama penghuni..."
			/>
		</Fragment>
	</FilterToolbar>

	<Stats stats={notificationStats} />

	<div
		class="overflow-x-auto rounded-box border border-base-300 shadow-sm"
		id="notifications-content-wrapper"
	>
		<table class="table w-full table-sm">
			<thead>
				<tr>
					<th>Dibuat</th>
					<th>Dikirim</th>
					<th>Penghuni</th>
					<th>Invoice</th>
					<th>Tipe</th>
					<th>Status</th>
				</tr>
			</thead>
			<tbody id="notifications-table-body">
				{
					notifications.map(
						({
							createdAt,
							sentAt,
							tenantName,
							roomNumber,
							invoiceNumber,
							type,
							status,
						}) => (
							<tr>
								<td class="font-mono text-xs">
									{formatDate(createdAt, "DD MMM YYYY HH:mm")}
								</td>
								<td class="font-mono text-xs">
									{sentAt ? formatDate(sentAt, "DD MMM YYYY HH:mm") : "-"}
								</td>
								<td class="flex items-center gap-2 text-sm font-semibold">
									{tenantName}
									<span class="badge font-mono badge-xs badge-neutral">
										{roomNumber}
									</span>
								</td>
								<td class="font-mono text-xs font-semibold">{invoiceNumber}</td>
								<td>
									<span
										class:list={[
											"badge badge-sm font-bold",
											NOTIFICATION_TYPE_BADGES[type],
										]}
									>
										{NOTIFICATION_TYPE_LABELS[type]}
									</span>
								</td>
								<td>
									<span
										class:list={[
											"badge badge-sm font-bold",
											NOTIFICATION_STATUS_BADGES[status],
										]}
									>
										{NOTIFICATION_STATUS_LABELS[status]}
									</span>
								</td>
							</tr>
						),
					)
				}
			</tbody>
		</table>
	</div>
</DashboardLayout>
