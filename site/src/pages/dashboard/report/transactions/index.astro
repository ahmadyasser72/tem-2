---
import { actions } from "astro:actions";

import FilterPopover from "~/components/data/filter-popover.astro";
import FilterToolbar from "~/components/data/filter-toolbar.astro";
import SearchInput from "~/components/data/search-input.astro";
import Stats from "~/components/data/stats.astro";
import FormResult from "~/components/form/form-result.astro";
import ActionsMenu from "~/components/ui/actions-menu.astro";
import Icon from "~/components/ui/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { INVOICE_STATUS_BADGES, INVOICE_STATUS_LABELS } from "~/lib/badges";
import { formatDate } from "~/lib/date";
import { createActionResult } from "~/lib/form-result";
import {
	fetchTransactions,
	getTransactionStats,
	transactionQuerySchema,
} from "./_data";

const params = Astro.locals.parseQuery(transactionQuerySchema);

// Query all invoices for stats
const monthlyInvoices = await fetchTransactions(params);
const { totalRevenue, paidCount, unpaidCount, outstandingAmount } =
	getTransactionStats(monthlyInvoices);
const totalCount = monthlyInvoices.length;
const paidPercent =
	totalCount > 0 ? Math.round((paidCount / totalCount) * 100) : 0;

const summaryStats = [
	{
		title: "Total Pemasukan",
		value: `Rp ${totalRevenue.toLocaleString("id-ID")}`,
		desc: `${params.from} s/d ${params.to}`,
		icon: "line-md:edit-filled",
	},
	{
		title: "Sudah Terbayar",
		value: `${paidCount} Invoice`,
		desc: `${paidPercent}% dari total tagihan`,
		icon: "line-md:circle-to-confirm-circle-transition",
	},
	{
		title: "Belum Terbayar",
		value: `${unpaidCount} Invoice`,
		desc: `Rp ${outstandingAmount.toLocaleString("id-ID")} outstanding`,
		icon: "line-md:close-circle",
	},
];

// Query filtered invoices
const filteredInvoices = await fetchTransactions(params, { useQuery: true });
---

<FormResult
	actionResults={[
		createActionResult(
			actions.manage.invoices.generatePaymentLink,
			"Buat link bayar",
			(d) =>
				`Link pembayaran berhasil dibuat! <a href="${d.paymentUrl}" class="link link-primary" target="_blank">Buka Pembayaran</a>`,
		),
		createActionResult(
			actions.manage.invoices.markAsPaid,
			"Tandai Lunas",
			() => "Berhasil menandai invoice sebagai lunas!",
		),
	]}
/>

<DashboardLayout
	title="Laporan Transaksi"
	description="Rekapitulasi tagihan dan riwayat pembayaran sewa bulanan penghuni"
>
	<Fragment slot="page-action">
		<a
			class="btn btn-outline btn-sm"
			href={`/dashboard/report/transactions/report/download${Astro.url.search}`}
			download
		>
			<Icon name="line-md:download" /> PDF
		</a>
		<button class="btn btn-outline btn-sm">
			<Icon name="line-md:download" /> Export Excel
		</button>
	</Fragment>

	<FilterToolbar name="transactions" from={params.from} to={params.to}>
		<Fragment slot="actions">
			<FilterPopover
				name="transactions"
				groups={[
					{
						title: "Status",
						name: "status",
						options: [
							{
								value: "paid",
								label: "Lunas",
								checked: params.status === "paid",
							},
							{
								value: "unpaid",
								label: "Belum Bayar",
								checked: params.status === "unpaid",
							},
							{
								value: "overdue",
								label: "Terlambat",
								checked: params.status === "overdue",
							},
						],
					},
				]}
			/>
			<SearchInput
				value={params.query}
				filterClass="filter-transactions"
				placeholder="Cari nama/No. Kamar..."
			/>
		</Fragment>
	</FilterToolbar>

	<div class="contents" id="transactions-content-wrapper">
		<Stats items={summaryStats} />

		<div class="border-base-300 rounded-box overflow-x-auto border shadow-sm">
			<table class="table-zebra table-sm table w-full">
				<thead>
					<tr>
						<th>No. Invoice</th>
						<th>Penghuni</th>
						<th>Kamar</th>
						<th>Nominal</th>
						<th>Jatuh Tempo</th>
						<th>Status</th>
						<th>Ref. Gateway</th>
						<th>Aksi</th>
					</tr>
				</thead>
				<tbody>
					{
						filteredInvoices.map(
							({
								id,
								invoiceNumber,
								tenantName,
								roomNumber,
								amount,
								dueDate,
								status,
								gatewayRef,
								duitkuReference,
								paymentUrl,
							}) => (
								<tr data-id={id}>
									<td class="font-mono text-xs">{invoiceNumber}</td>
									<td>{tenantName}</td>
									<td>
										<span class="badge badge-neutral font-mono">
											{roomNumber}
										</span>
									</td>
									<td class="font-mono">Rp {amount.toLocaleString("id-ID")}</td>
									<td class="font-mono text-xs">{formatDate(dueDate)}</td>
									<td>
										<span
											class:list={[
												"badge badge-sm font-bold",
												INVOICE_STATUS_BADGES[
													status as keyof typeof INVOICE_STATUS_BADGES
												],
											]}
										>
											{
												INVOICE_STATUS_LABELS[
													status as keyof typeof INVOICE_STATUS_LABELS
												]
											}
										</span>
									</td>
									<td
										class="max-w-32 truncate font-mono text-xs"
										title={gatewayRef}
									>
										{gatewayRef}
									</td>
									<td>
										{status === "paid" ? (
											<span class="text-xs">-</span>
										) : duitkuReference ? (
											<div class="flex items-center gap-1">
												<a
													class="btn btn-outline btn-success btn-xs w-24"
													href={`/invoice/${id}`}
													target="_blank"
												>
													<Icon name="line-md:external-link" size="size-3.5" />{" "}
													Invoice
												</a>
												<ActionsMenu id={id} menuClass="w-36">
													<li>
														<button
															class="flex items-center gap-2"
															onclick={`navigator.clipboard.writeText("${paymentUrl}")`}
														>
															<Icon
																name="line-md:clipboard-list"
																size="size-3.5"
															/>
															Salin
														</button>
													</li>
													<li>
														<form
															hx-post={actions.manage.invoices.markAsPaid}
															class="contents"
															hx-select="#transactions-content-wrapper"
															hx-swap="outerHTML transition:true"
															hx-target="#transactions-content-wrapper"
															action={actions.manage.invoices.markAsPaid}
															enctype="multipart/form-data"
															method="post"
														>
															<input
																name="invoice_id"
																type="hidden"
																value={id}
															/>
															<button
																class="flex items-center gap-2"
																type="submit"
															>
																<Icon name="line-md:confirm-circle" />
																Tandai Lunas
															</button>
														</form>
													</li>
												</ActionsMenu>
											</div>
										) : (
											<div class="flex items-center gap-1">
												<form
													hx-post={actions.manage.invoices.generatePaymentLink}
													class="contents"
													hx-select="#transactions-content-wrapper"
													hx-swap="outerHTML transition:true"
													hx-target="#transactions-content-wrapper"
													action={actions.manage.invoices.generatePaymentLink}
													enctype="multipart/form-data"
													method="post"
												>
													<input name="invoice_id" type="hidden" value={id} />
													<button
														class="btn btn-outline btn-primary btn-xs w-24"
														type="submit"
													>
														<Icon name="line-md:link" size="size-3.5" />{" "}
														Generate
													</button>
												</form>
												<ActionsMenu id={id} menuClass="w-36">
													<li>
														<form
															hx-post={actions.manage.invoices.markAsPaid}
															class="contents"
															hx-select="#transactions-content-wrapper"
															hx-swap="outerHTML transition:true"
															hx-target="#transactions-content-wrapper"
															action={actions.manage.invoices.markAsPaid}
															enctype="multipart/form-data"
															method="post"
														>
															<input
																name="invoice_id"
																type="hidden"
																value={id}
															/>
															<button
																class="flex items-center gap-2"
																type="submit"
															>
																<Icon name="line-md:confirm-circle" />
																Tandai Lunas
															</button>
														</form>
													</li>
												</ActionsMenu>
											</div>
										)}
									</td>
								</tr>
							),
						)
					}
				</tbody>
			</table>
		</div>
	</div>
</DashboardLayout>
