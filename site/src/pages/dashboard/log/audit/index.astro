---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";
import { z } from "astro/zod";
import { pick } from "es-toolkit";

import Alert from "~/components/alert.astro";
import Icon from "~/components/icon.astro";
import DashboardLayout from "~/layouts/dashboard-layout.astro";
import { formatDate, getCurrentMonthStr, parsePeriod } from "~/lib/date";

const defaultFrom = getCurrentMonthStr();
const defaultTo = getCurrentMonthStr();

const params = Astro.locals.parseQuery(
	z.object({
		query: z.string().catch(""),
		from: z.string().catch(defaultFrom),
		to: z.string().catch(defaultTo),
		action: z.enum(["CREATE", "UPDATE", "DELETE"]).optional().catch(undefined),
		show_system: z.string().optional().catch(undefined),
	}),
);

// If from > to, adjust to follow from
if (params.from > params.to) {
	params.to = params.from;
}

// Parse period
const { startDate, endDate } = parsePeriod(params.from, params.to);

const showSystem = params.show_system !== undefined;

const logsFromDb = await db.query.auditLogs.findMany({
	where: {
		...(params.query && {
			OR: [
				{ action: { like: `%${params.query}%` } },
				{ tableName: { like: `%${params.query}%` } },
				{ recordId: { like: `%${params.query}%` } },
				{
					user: {
						username: { like: `%${params.query}%` },
					},
				},
			],
		}),
		createdAt: {
			gte: startDate,
			lte: endDate,
		},
		...(params.action && { action: params.action }),
		...(!showSystem && {
			user: {
				role: { ne: "system" },
			},
		}),
	},
	with: { user: true },
	orderBy: { createdAt: "desc" },
});

const auditLogs = logsFromDb.map((log) => {
	return {
		id: log.id,
		time: log.createdAt,
		username: log.user?.username ?? "Sistem",
		action: log.action,
		table: log.tableName,
		recordId: log.recordId,
		details: log.details,
	};
});

const ACTION_BADGES: Record<string, string> = {
	CREATE: "badge-success text-white",
	UPDATE: "badge-warning text-white",
	DELETE: "badge-error text-white",
};

const formResult = (():
	| { success: false; message: string }
	| { success: true; title: string; description: string }
	| void => {
	const removeResult = Astro.getActionResult(actions.manage.audit.remove);
	if (removeResult?.error)
		return { success: false, message: removeResult.error.message };
	else if (removeResult?.data) {
		return {
			success: true,
			title: "Hapus Audit Log",
			description: "Audit log berhasil dihapus dari database!",
		};
	}
})();
---

{
	formResult?.success === false && (
		<Alert id="form_error" type="error" description={formResult.message} />
	)
}

<DashboardLayout title="Audit Log ">
	<div class="flex flex-col gap-6">
		{
			formResult?.success ? (
				<Alert
					id="form_result"
					type="info"
					{...pick(formResult, ["title", "description"])}
				/>
			) : (
				<p id="form_result" />
			)
		}

		<div
			class="flex flex-col gap-4 sm:flex-row sm:items-center sm:justify-between"
		>
			<div class="flex flex-col gap-1">
				<h1 class="text-3xl font-bold">Audit Log Sistem</h1>
				<p class="text-base-content/60 text-sm">
					Jejak rekaman log aktivitas mutasi data dan operasional yang dilakukan
					oleh pengguna
				</p>
			</div>
			<a
				class="btn btn-outline btn-sm flex items-center gap-1"
				href={`/dashboard/log/audit/report/download${Astro.url.search}`}
				download
			>
				<Icon name="line-md:download" /> PDF
			</a>
		</div>

		<div class="card bg-base-100 border-base-300 border shadow-sm">
			<div
				class="card-body flex flex-col gap-3 p-4 sm:flex-row sm:items-center sm:justify-between"
				hx-include=".filter-audit"
				hx-select="#audit-content-wrapper"
				hx-swap="outerHTML transition:true"
				hx-target="#audit-content-wrapper"
			>
				<div class="flex w-full items-center gap-3 sm:flex-1">
					<Icon
						class="text-primary shrink-0"
						name="line-md:calendar"
						size="size-5"
					/>
					<span
						class="text-base-content/75 hidden text-sm font-semibold md:inline"
						>Pilih Periode:</span
					>
					<input
						hx-get
						class="input input-sm filter-audit w-full sm:w-40"
						name="from"
						type="month"
						value={params.from}
					/>
					<span class="text-base-content/70 text-sm font-semibold">Sampai:</span
					>
					<input
						hx-get
						class="input input-sm filter-audit w-full sm:w-40"
						name="to"
						type="month"
						value={params.to}
						min={params.from}
					/>
				</div>

				<div class="flex gap-2">
					<button
						class="btn btn-sm btn-outline"
						popovertarget="filter-audit-popover"
						style="anchor-name:--filter-audit"
					>
						<Icon name="line-md:filter" size="size-4" />
						Filter
					</button>
					<div
						class="dropdown menu rounded-box bg-base-100 mt-2 min-w-64 shadow-sm"
						id="filter-audit-popover"
						popover
						style="position-anchor:--filter-audit"
					>
						<li class="menu-title">Jenis aksi</li>

						<div class="mx-2 mb-4 filter">
							<input
								hx-get
								class="btn filter-reset filter-audit btn-sm"
								name="action"
								type="radio"
								value="all"
							/>
							<input
								hx-get
								class="btn filter-audit btn-sm"
								name="action"
								type="radio"
								value="CREATE"
								aria-label="CREATE"
								checked={params.action === "CREATE"}
							/>
							<input
								hx-get
								class="btn filter-audit btn-sm"
								name="action"
								type="radio"
								value="UPDATE"
								aria-label="UPDATE"
								checked={params.action === "UPDATE"}
							/>
							<input
								hx-get
								class="btn filter-audit btn-sm"
								name="action"
								type="radio"
								value="DELETE"
								aria-label="DELETE"
								checked={params.action === "DELETE"}
							/>
						</div>

						<label class="label label-sm mx-2">
							<input
								hx-get
								class="checkbox checkbox-sm filter-audit"
								name="show_system"
								type="checkbox"
								value="1"
								checked={showSystem}
							/>
							Tampilkan System
						</label>
					</div>

					<label class="input input-sm w-full sm:max-w-xs">
						<Icon name="line-md:search" size="size-4" />
						<input
							hx-get
							hx-trigger="input changed delay:300ms"
							class="filter-audit"
							name="query"
							type="search"
							value={params.query}
							placeholder="Cari aksi, tabel, atau pengguna..."
						/>
					</label>
				</div>
			</div>
		</div>

		<div
			class="card bg-base-100 border-base-300 border shadow-sm"
			id="audit-content-wrapper"
		>
			<div class="card-body p-0">
				<div class="overflow-x-auto">
					<table class="table w-full">
						<thead>
							<tr class="border-base-300 border-b">
								<th class="text-base-content/60 w-48 text-xs font-bold"
									>Waktu Kejadian</th
								>
								<th class="text-base-content/60 text-xs font-bold">Pengguna</th>
								<th class="text-base-content/60 w-32 text-xs font-bold"
									>Jenis Aksi</th
								>
								<th class="text-base-content/60 text-xs font-bold"
									>Tabel Target</th
								>
								<th class="text-base-content/60 text-xs font-bold">ID Record</th
								>
								<th
									class="text-base-content/60 w-16 text-right text-xs font-bold"
									>Aksi</th
								>
							</tr>
						</thead>
						<tbody>
							{
								auditLogs.map(
									({
										id,
										time,
										username: userName,
										action,
										table,
										recordId,
										details,
									}) => (
										<tr class="border-base-200 hover:bg-base-200/40 border-b transition-colors">
											<td class="text-base-content/70 font-mono text-xs">
												{formatDate(time, "DD MMM YYYY HH:mm:ss")}
											</td>
											<td class="text-sm font-semibold">
												<div class="flex items-center gap-1.5">
													<Icon
														class="text-base-content/40"
														name="line-md:account"
														size="size-4"
													/>
													{userName}
												</div>
											</td>
											<td>
												{details ? (
													<div
														class="tooltip tooltip-right cursor-help"
														data-tip={details}
													>
														<span
															class:list={[
																"badge badge-xs font-bold underline decoration-dotted underline-offset-2",
																ACTION_BADGES[action],
															]}
														>
															{action}
														</span>
													</div>
												) : (
													<span
														class:list={[
															"badge badge-xs font-bold",
															ACTION_BADGES[action],
														]}
													>
														{action}
													</span>
												)}
											</td>
											<td class="text-primary font-mono text-xs font-semibold">
												{table}
											</td>
											<td class="font-mono text-xs">
												<span class="bg-base-200 border-base-300 rounded border px-2 py-0.5 font-bold">
													{recordId}
												</span>
											</td>
											<td class="pt-2 text-right">
												<button
													hx-get={`/dashboard/log/audit/modal/delete/${id}`}
													class="btn btn-square btn-ghost btn-xs text-error"
												>
													<Icon name="line-md:close" size="size-4" />
												</button>
											</td>
										</tr>
									),
								)
							}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
</DashboardLayout>
