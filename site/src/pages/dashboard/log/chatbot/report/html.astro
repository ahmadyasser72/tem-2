---
import { db } from "@e-kos/database";
import { z } from "astro/zod";
import dayjs, { formatDate } from "~/lib/date";
import ReportLayout from "~/layouts/report-layout.astro";

const params = Astro.locals.parseQuery(
	z.object({
		tenantId: z.coerce.number().optional().catch(undefined),
		from: z.string().optional().catch(undefined),
		to: z.string().optional().catch(undefined),
		direction: z.enum(["incoming", "outgoing"]).optional().catch(undefined),
	}),
);

// knownBy — first owner user
const owner = await db.query.users.findFirst({
	where: { role: "owner" },
	columns: { displayName: true },
});
const knownBy = owner?.displayName ?? "Pemilik Kos";

// createdBy — from searchParams
const createdBy = Astro.url.searchParams.get("createdBy") ?? "Staff";

// Build where clause
const where: Record<string, unknown> = {};
if (params.tenantId != null && !Number.isNaN(params.tenantId)) {
	where.tenantId = params.tenantId;
}
if (params.direction) {
	where.direction = params.direction;
}
if (params.from || params.to) {
	const sentAtFilter: Record<string, Date> = {};
	if (params.from) {
		sentAtFilter.gte = dayjs(params.from).startOf("day").toDate();
	}
	if (params.to) {
		sentAtFilter.lte = dayjs(params.to).endOf("day").toDate();
	}
	where.sentAt = sentAtFilter;
}

// Query chatbotMessages with tenant → leases (active) → room
const logsFromDb = await db.query.chatbotMessages.findMany({
	where,
	with: {
		tenant: {
			with: {
				leases: {
					where: { isActive: true },
					with: { room: true },
				},
			},
		},
	},
	orderBy: (chatbotMessages, { asc }) => [asc(chatbotMessages.sentAt)],
});

// Map to display rows
const rows = logsFromDb.map((log) => {
	const activeLease = log.tenant?.leases?.[0];
	return {
		time: log.sentAt,
		tenantName: log.tenant?.fullName ?? "-",
		roomNumber: activeLease?.room?.roomNumber ?? "-",
		direction: log.direction === "incoming" ? "Masuk" : "Keluar",
		message: log.message,
	};
});

// Header info — if tenantId is set, show tenant name & room above table
const hasTenantFilter = params.tenantId != null && !Number.isNaN(params.tenantId);
let headerTenant: { fullName: string; roomNumber: string } | null = null;
if (hasTenantFilter) {
	const tenant = await db.query.tenants.findFirst({
		where: { id: params.tenantId },
		with: {
			leases: {
				where: { isActive: true },
				with: { room: true },
			},
		},
	});
	if (tenant) {
		const activeLease = tenant.leases?.[0];
		headerTenant = {
			fullName: tenant.fullName,
			roomNumber: activeLease?.room?.roomNumber ?? "-",
		};
	}
}

// Subtitle — filter summary
const subtitleParts: string[] = [];
if (params.direction) {
	subtitleParts.push(
		`Arah: ${params.direction === "incoming" ? "Masuk" : "Keluar"}`,
	);
}
if (params.from) subtitleParts.push(`Dari: ${formatDate(params.from)}`);
if (params.to) subtitleParts.push(`Sampai: ${formatDate(params.to)}`);
const subtitle =
	subtitleParts.length > 0 ? subtitleParts.join(" | ") : undefined;
---

<ReportLayout
	title="Laporan Percakapan Chatbot"
	subtitle={subtitle}
	createdBy={createdBy}
	knownBy={knownBy}
>
	<!-- Waktu Cetak -->
	<div style="font-size: 10px; margin-bottom: 12px; opacity: 0.6;">
		Dicetak: {formatDate(new Date(), "DD MMMM YYYY HH:mm")}
	</div>

	<!-- Header Info -->
	{
		headerTenant && (
			<div
				style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 12px; margin-bottom: 16px; font-size: 11px;"
			>
				<div>
					<span style="font-weight: 700; opacity: 0.6;">Penghuni</span>
					<div style="font-weight: 700; margin-top: 2px;">
						{headerTenant.fullName}
					</div>
				</div>
				<div>
					<span style="font-weight: 700; opacity: 0.6;">Kamar</span>
					<div
						style="font-weight: 700; margin-top: 2px; font-family: 'Courier New', monospace;"
					>
						{headerTenant.roomNumber}
					</div>
				</div>
			</div>
		)
	}

	<!-- Table -->
	<table>
		<thead>
			<tr>
				<th style="width: 18%;">Waktu</th>
				<th style="width: 18%;">Penghuni</th>
				<th style="width: 10%;">Kamar</th>
				<th style="width: 10%;">Arah</th>
				<th style="width: 44%;">Isi Pesan</th>
			</tr>
		</thead>
		<tbody>
			{
				rows.length === 0 ? (
					<tr>
						<td
							colspan="5"
							style="text-align: center; padding: 24px; font-size: 11px; opacity: 0.5;"
						>
							Tidak ada data percakapan chatbot.
						</td>
					</tr>
				) : (
					rows.map((row) => (
						<tr>
							<td
								style="font-family: 'Courier New', monospace; font-size: 10px; white-space: nowrap;"
							>
								{formatDate(row.time, "DD MMM YYYY HH:mm")}
							</td>
							<td style="font-weight: 600;">{row.tenantName}</td>
							<td
								style="font-family: 'Courier New', monospace; text-align: center;"
							>
								{row.roomNumber}
							</td>
							<td style="text-align: center;">{row.direction}</td>
							<td style="max-width: 300px; word-break: break-word;">
								{row.message}
							</td>
						</tr>
					))
				)
			}
		</tbody>
	</table>
</ReportLayout>
