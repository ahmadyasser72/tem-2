---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import Icon from "~/components/icon.astro";

export const partial = true;

const complaint = await db.query.complaints.findFirst({
	where: { id: Number(Astro.params.id) },
});

if (!complaint) Astro.response.status = 404;
---

<dialog class="modal" id="resolve_complaint_modal">
	{
		complaint ? (
			<div class="modal-box border-base-300 border">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>
				<h3 class="text-success mb-2 flex items-center gap-2 text-xl font-bold">
					<Icon
						name="line-md:circle-to-confirm-circle-transition"
						size="size-6"
					/>
					Tandai Komplain Selesai
				</h3>
				<p class="text-base-content/60 mb-4 text-sm">
					Apakah Anda yakin ingin menandai komplain (ID: {complaint.id}) sebagai
					selesai? Penghuni akan mendapat kepastian bahwa masalah sarana mereka
					telah berhasil diperbaiki.
				</p>

				<form
					hx-post={actions.manage.complaints.resolve}
					id="resolve_complaint_form"
					hx-on--after-request="event.detail.successful && resolve_complaint_modal.close()"
					hx-select-oob="#form_error, #form_result, #complaints-list"
					hx-swap="none transition:true"
					action={actions.manage.complaints.resolve}
					method="post"
				>
					<input name="id" type="hidden" value={complaint.id} />

					<div class="mb-4">
						<span class="font-bold text-xs block mb-1">Deskripsi Masalah:</span>
						<p class="bg-base-200 border border-base-300 rounded p-3 text-xs leading-relaxed max-h-24 overflow-y-auto whitespace-pre-wrap break-words">
							{complaint.description}
						</p>
					</div>

					<div class="form-control mb-4">
						<label class="label pt-0 pb-1">
							<span class="label-text font-semibold text-xs">Keterangan Resolve (Opsional):</span>
						</label>
						<textarea
							name="resolveNotes"
							class="textarea textarea-bordered h-20 text-sm"
							placeholder="Tuliskan detail perbaikan atau catatan penyelesaian (opsional)..."
						></textarea>
					</div>
				</form>

				<p id="form_error" class="text-error mb-4 text-sm" />

				<div class="modal-action">
					<form class="flex gap-2" method="dialog">
						<button class="btn btn-outline btn-sm">Batal</button>
						<button
							class="btn btn-success btn-sm text-white"
							type="submit"
							form="resolve_complaint_form"
						>
							Konfirmasi Selesai
						</button>
					</form>
				</div>
			</div>
		) : (
			<div class="modal-box border-base-300 border">
				<form method="dialog">
					<button class="btn btn-sm btn-circle btn-ghost absolute top-2 right-2">
						✕
					</button>
				</form>
				<h3 class="mb-4 text-xl font-bold">Selesaikan Komplain</h3>
				<p class="py-4">
					Komplain dengan ID: {Astro.params.id} tidak ditemukan.
				</p>
			</div>
		)
	}
	<form class="modal-backdrop" method="dialog">
		<button>close</button>
	</form>
</dialog>
