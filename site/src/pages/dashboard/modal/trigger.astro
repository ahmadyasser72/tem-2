---
import { db } from "@indekos/database";
import dayjs from "@indekos/utilities/date";

import { actions, type ActionInputSchema } from "astro:actions";
import { z } from "astro/zod";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";

export const partial = true;

const onlyNotificationWorker = Astro.url.searchParams.has(
	"notification-worker",
);

const workers = {
	"payment-reminder": "Pengingat Pembayaran (H-3)",
	"overdue-reminder": "Pengingat Overdue",
	report: "Laporan Bulanan",
	...(!onlyNotificationWorker && {
		overdue: "Tandai Overdue",
		invoice: "Generate Invoice",
	}),
} satisfies Partial<
	Record<
		z.infer<
			ActionInputSchema<typeof actions.worker.trigger>["def"]["shape"]["worker"]
		>,
		string
	>
>;

const shortLabels: Record<string, string> = {
	invoice: "Invoice",
	"payment-reminder": "Pembayaran",
	"overdue-reminder": "Overdue",
	overdue: "Tandai",
	report: "Laporan",
};

const { worker: selectedWorker } = Astro.locals.parseQuery(
	z.object({ worker: z.string().optional() }),
);

const data: Record<string, string[]> = {};
const cumulativeCounts: Record<string, number> = {};
const pendingByDate: Record<string, { roomNumber: string; tenantName: string }[]> = {};

if (selectedWorker === "invoice") {
	const activeLeases = await db.query.leases.findMany({
		where: { isActive: true },
		with: { invoices: true, tenant: true, room: true },
	});

	for (const lease of activeLeases) {
		const endDate = lease.endDate ? dayjs(lease.endDate) : null;
		let cycleStart = dayjs(lease.startDate).add(1, "month");
		const roomNumber = lease.room?.roomNumber ?? "?";
		const tenantName = lease.tenant?.fullName ?? "?";

		while (true) {
			if (endDate && !cycleStart.isBefore(endDate, "day")) break;

			const creationDate = cycleStart.subtract(7, "days");
			if (creationDate.isAfter(dayjs().add(2, "years"), "day")) break;

			const existing = lease.invoices.find(({ dueDate }) =>
				cycleStart.isSame(dueDate, "day"),
			);

			if (!existing) {
				const dateStr = creationDate.format("YYYY-MM-DD");
				pendingByDate[dateStr] ??= [];
				pendingByDate[dateStr].push({ roomNumber, tenantName });
			}

			cycleStart = cycleStart.add(1, "month");
		}
	}
} else if (
	selectedWorker === "payment-reminder" ||
	selectedWorker === "overdue-reminder" ||
	selectedWorker === "overdue"
) {
	const invoices = await db.query.invoices.findMany({
		columns: { id: true, dueDate: true, status: true },
		with: { lease: { with: { room: true, tenant: true } } },
	});

	// Fetch existing notifications to mirror worker dedup (23h window)
	const notificationType =
		selectedWorker === "overdue-reminder" ? "overdue_reminder" : "reminder";
	const existingNotifications = await db.query.notifications.findMany({
		columns: { invoiceId: true, type: true, status: true, createdAt: true },
		where: { type: notificationType, status: { NOT: "failed" } },
	});

	// Returns true if a non-failed notification of the worker's type was sent
	// for this invoice within 23h before the given date (matches worker logic)
	const alreadyNotified = (invoiceId: number, dateStr: string): boolean => {
		const cutoff = dayjs(dateStr).subtract(23, "hours");
		return existingNotifications.some(
			(n) =>
				n.invoiceId === invoiceId &&
				dayjs(n.createdAt).isAfter(cutoff, "hour"),
		);
	};

	if (selectedWorker === "payment-reminder") {
		const unpaidInvoices = invoices.filter((inv) => inv.status === "unpaid");

		for (const invoice of unpaidInvoices) {
			const dueDate = dayjs(invoice.dueDate);
			const reminderStartDate = dueDate.subtract(3, "days");
			const roomNumber = invoice.lease?.room?.roomNumber ?? "?";
			const tenantName = invoice.lease?.tenant?.fullName ?? "?";

			let currentDate = reminderStartDate;
			while (currentDate.isBefore(dueDate, "day")) {
				if (!alreadyNotified(invoice.id, currentDate.format("YYYY-MM-DD"))) {
					const dateStr = currentDate.format("YYYY-MM-DD");
					pendingByDate[dateStr] ??= [];
					pendingByDate[dateStr].push({ roomNumber, tenantName });
				}
				currentDate = currentDate.add(1, "day");
			}
		}
	} else if (selectedWorker === "overdue-reminder") {
		const overdueInvoices = invoices.filter((inv) => inv.status === "overdue");

		if (overdueInvoices.length > 0) {
			const earliestDueDate = overdueInvoices.reduce(
				(min, inv) =>
					dayjs(inv.dueDate).isBefore(dayjs(min), "day") ? inv.dueDate : min,
				overdueInvoices[0].dueDate,
			);

			let currentDate = dayjs(earliestDueDate);
			for (let i = 0; i < 30; i++) {
				const dateStr = currentDate.format("YYYY-MM-DD");
				const itemsOnDate = overdueInvoices
					.filter(
						(inv) =>
							dayjs(inv.dueDate).isBefore(currentDate, "day") &&
							!alreadyNotified(inv.id, dateStr),
					)
					.map((inv) => ({
						roomNumber: inv.lease?.room?.roomNumber ?? "?",
						tenantName: inv.lease?.tenant?.fullName ?? "?",
					}));

				if (itemsOnDate.length > 0) {
					pendingByDate[dateStr] = itemsOnDate;
				}

				currentDate = currentDate.add(1, "day");
			}
		}
	} else if (selectedWorker === "overdue") {
		const unpaidInvoices = invoices.filter((inv) => inv.status === "unpaid");

		for (const invoice of unpaidInvoices) {
			const dueDate = dayjs(invoice.dueDate);
			const roomNumber = invoice.lease?.room?.roomNumber ?? "?";
			const tenantName = invoice.lease?.tenant?.fullName ?? "?";

			let currentDate = dueDate;
			for (let i = 0; i < 30; i++) {
				const dateStr = currentDate.format("YYYY-MM-DD");
				pendingByDate[dateStr] ??= [];
				pendingByDate[dateStr].push({ roomNumber, tenantName });
				currentDate = currentDate.add(1, "day");
			}
		}
	}
} else if (selectedWorker === "report") {
	const invoices = await db.query.invoices.findMany({
		columns: { dueDate: true },
	});

	if (invoices.length > 0) {
		const monthsWithData = new Set(
			invoices.map((inv) => dayjs(inv.dueDate).format("YYYY-MM")),
		);

		for (const yearMonth of monthsWithData) {
			const monthStart = dayjs(yearMonth, "YYYY-MM")
				.startOf("month")
				.add(1, "month")
				.format("YYYY-MM-DD");
			data[monthStart] = ["1 Laporan Bulanan"];
		}
	}
}

// Build cumulative counts with rolling window
const windowDays = selectedWorker === "payment-reminder" ? 3 : 7;
const sortedDates = Object.keys(pendingByDate).sort();

	for (const dateStr of sortedDates) {
		const windowStart = dayjs(dateStr).subtract(windowDays - 1, "day").format("YYYY-MM-DD");

		const windowItems: { roomNumber: string; tenantName: string }[] = [];
		const seen = new Set<string>();
		for (const d of sortedDates) {
			if (d >= windowStart && d <= dateStr) {
				for (const item of pendingByDate[d]) {
					const key = `${item.roomNumber}-${item.tenantName}`;
					if (!seen.has(key)) {
						seen.add(key);
						windowItems.push(item);
					}
				}
			}
		}
		cumulativeCounts[dateStr] = windowItems.length;

		data[dateStr] = windowItems.map(
			({ roomNumber, tenantName }) => `${roomNumber} - ${tenantName}`,
		);
	}

export type Data = { items: Record<string, string[]>; cumulativeCounts: Record<string, number>; shortLabel: string };
---

<Modal
	id="trigger_worker"
	title={`Trigger ${onlyNotificationWorker ? "Pengingat" : "Worker"}`}
	icon="lucide:play"
	modalClass="overflow-visible"
>
	<ModalForm
		action={actions.worker.trigger}
		modalId="trigger_worker"
		submitLabel="Jalankan"
	>
		<FormField
			label={`Pilih ${onlyNotificationWorker ? "Jenis Pengingat" : "Worker"}`}
		>
			<select
				hx-get={Astro.url.pathname}
				class="select w-full"
				name="worker"
				hx-select="#select-trigger-date"
				hx-swap="outerHTML"
				hx-target="#select-trigger-date"
				required
			>
				<option value="" disabled selected
					>-- Pilih {onlyNotificationWorker ? "pengingat" : "worker"} --</option
				>
				{
					Object.entries(workers).map(([id, label]) => (
						<option value={id}>{label}</option>
					))
				}
			</select>
		</FormField>

		<FormField
			helperText={`Jalankan ${onlyNotificationWorker ? "pengingat" : "worker"} untuk tanggal tertentu (kosongkan untuk menggunakan waktu sekarang)`}
			label="Tanggal Eksekusi"
		>
			<div
				class="vc"
				id="select-trigger-date"
				data-calendar={JSON.stringify({ items: data, cumulativeCounts, shortLabel: shortLabels[selectedWorker ?? "invoice"] ?? "Worker" })}
			>
			</div>
			<input name="target" type="hidden" />
		</FormField>
	</ModalForm>
</Modal>

<script>
	import htmx from "htmx.org";
	import { Calendar } from "vanilla-calendar-pro";

	import type { Data } from "./trigger.astro";

	const init = (node: unknown) => {
		if (!(node instanceof HTMLElement)) return;

		const calendarElement = node.matches(".vc#select-trigger-date")
			? node
			: node.querySelector<HTMLElement>(".vc#select-trigger-date");
		if (!(calendarElement instanceof HTMLElement)) return;

		const data = JSON.parse(calendarElement.dataset.calendar!) as Data;
		const { items: allItems, cumulativeCounts, shortLabel } = data;
		const calendar = new Calendar(calendarElement, {
			disableToday: true,
			disableAllDates: true,
			enableDates: Object.keys(allItems),

			onClickDate: ({ context }) => {
				(context.mainElement.nextElementSibling as HTMLInputElement).value =
					context.selectedDates[0] ?? "";
			},

			onCreateDateEls: (_, element) => {
				const dateItems = allItems[element.dataset.vcDate!] ?? [];
				if (dateItems.length === 0) return;

				const dateStr = element.dataset.vcDate!;
				const badgeCount = cumulativeCounts[dateStr] ?? dateItems.length;

				const button = element.querySelector(
					"[data-vc-date-btn]",
				) as HTMLButtonElement;
				button.classList.add("flex-col");
				const day = button.innerText;
				button.innerHTML = "";
				button.innerHTML += `<span>${day}</span>`;
				button.innerHTML += `<span class="badge badge-xs badge-primary badge-soft">${badgeCount}</span>`;
			},

			popups: Object.fromEntries(
				Object.entries(allItems).map(([date, items]) => [
					date,
					{
						html: [
							'<div class="flex max-w-52 min-w-full flex-col flex-wrap items-center gap-1 py-2 text-xs font-medium">',
							...(cumulativeCounts[date]
								? [`<span class="badge badge-xs badge-primary">${cumulativeCounts[date]} ${shortLabel}</span>`]
								: []),
							...items.map(
								(item) =>
									`<span class="badge badge-soft badge-xs block min-w-0 max-w-full shrink items-start overflow-hidden text-ellipsis whitespace-nowrap text-left">${item}</span>`,
							),
							"</div>",
						].join(""),
					},
				]),
			),
		});

		calendar.init();
	};

	htmx.onLoad((node) => init(node));
	init(document.documentElement);
</script>
