{
	"name": "@indekos/scheduler",
	"type": "module",
	"license": "AGPL-3.0",
	"private": true,
	"exports": {
		"./*": "./src/workers/*.ts"
	},
	"scripts": {
		"build": "bun build src/index.ts --sourcemap --minify --target=bun --outdir dist",
		"start": "bun dist/index.js",
		"check": "tsc --noEmit",
		"trigger": "bun src/trigger.ts"
	},
	"dependencies": {
		"@indekos/database": "workspace:*",
		"@indekos/utilities": "workspace:*",
		"es-toolkit": "1.50.0"
	},
	"devDependencies": {
		"@types/bun": "1.3.14",
		"@types/node": "26.1.1",
		"typescript": "6.0.3"
	}
}
