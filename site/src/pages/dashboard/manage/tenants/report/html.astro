---
import ReportTableEmpty from "~/components/data/report-table-empty.astro";
import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";
import { fetchAllTenants, reportTenantsQuerySchema } from "../_data";

const params = Astro.locals.parseQuery(reportTenantsQuerySchema);

// Query all tenants
const allTenants = await fetchAllTenants();

// Apply status filter
const filteredTenants = allTenants.filter((t) => {
	if (params.status === "active" && !t.isActive) return false;
	if (params.status === "completed" && t.isActive) return false;
	return true;
});

// Subtitle
let subtitle = "Semua penghuni";
if (params.status === "active") subtitle = "Status: Aktif";
else if (params.status === "completed") subtitle = "Status: Selesai";

const total = filteredTenants.length;
---

<ReportLayout title="Daftar Penghuni Aktif" subtitle={subtitle}>
	<!-- Table -->
	<table>
		<thead>
			<tr>
				<th style="width: 5%; text-align: center;">No</th>
				<th style="width: 22%;">Nama Lengkap</th>
				<th style="width: 15%;">No. HP</th>
				<th style="width: 10%;">Kamar</th>
				<th style="width: 15%;">Awal Sewa</th>
				<th style="width: 15%;">Akhir Sewa</th>
				<th style="width: 10%;">Status</th>
			</tr>
		</thead>
		<tbody>
			{
				filteredTenants.length === 0 ? (
					<ReportTableEmpty
						colspan={7}
						message="Tidak ada data penghuni yang sesuai dengan filter."
					/>
				) : (
					filteredTenants.map(
						(
							{
								fullName,
								phoneNumber,
								roomNumber,
								startDate,
								endDate,
								isActive,
							},
							i,
						) => (
							<tr>
								<td style="text-align: center; font-family: 'Courier New', monospace;">
									{i + 1}
								</td>
								<td>{fullName}</td>
								<td style="font-family: 'Courier New', monospace;">
									{phoneNumber}
								</td>
								<td style="text-align: center; font-family: 'Courier New', monospace;">
									{roomNumber}
								</td>
								<td style="font-family: 'Courier New', monospace;">
									{formatDate(startDate)}
								</td>
								<td style="font-family: 'Courier New', monospace;">
									{formatDate(endDate)}
								</td>
								<td style="text-align: center;">
									{isActive ? "Aktif" : "Selesai"}
								</td>
							</tr>
						),
					)
				)
			}
		</tbody>
		<tfoot>
			<tr>
				<td
					colspan="7"
					style="border: 1px solid black; padding: 8px; font-weight: 700; background: #f3f4f6;"
				>
					Total penghuni: {total}
				</td>
			</tr>
		</tfoot>
	</table>
</ReportLayout>
