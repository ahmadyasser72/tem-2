---
import { db } from "@e-kos/database";

import { actions } from "astro:actions";

import FormField from "~/components/form/form-field.astro";
import ModalForm from "~/components/form/modal-form.astro";
import Modal from "~/components/modal/modal.astro";
import NotFound from "~/components/ui/not-found.astro";
import { formatDate } from "~/lib/date";
import { ROOM_TYPE_LABELS } from "../../../rooms/_data";

export const partial = true;

const tenant = await db.query.tenants.findFirst({
	columns: { id: true, fullName: true },
	where: { id: Number(Astro.params.id) },
});

const activeLease = tenant
	? await db.query.leases.findFirst({
			where: { tenantId: tenant.id, isActive: true },
			with: { room: true },
		})
	: null;

const allRooms = await db.query.rooms.findMany({
	columns: { id: true, roomNumber: true, roomType: true, isActive: true },
	with: { lease: true },
});

const availableRooms = allRooms.filter(
	({ isActive, lease }) => isActive && !lease,
);

if (!tenant || !activeLease) Astro.response.status = 404;
---

<Modal
	id="move_tenant"
	title="Pindah Kamar Penghuni"
	icon="lucide:external-link"
>
	{
		tenant && activeLease ? (
			<>
				<div class="mb-4 grid grid-cols-2 gap-2 rounded-lg bg-base-200 p-3 text-sm">
					<span class="font-bold">Penghuni:</span>
					<span>{tenant.fullName}</span>
					<span class="font-bold">Kamar Saat Ini:</span>
					<span class="font-mono font-bold">
						{activeLease.room?.roomNumber ?? "-"}
						<span class="text-xs text-base-content/50">
							(
							{activeLease.room?.roomType
								? ROOM_TYPE_LABELS[activeLease.room.roomType]
								: "-"}
							)
						</span>
					</span>
					<span class="font-bold">Mulai Sewa:</span>
					<span>{formatDate(activeLease.startDate)}</span>
				</div>

				<ModalForm
					action={actions.manage.tenants.move}
					modalId="move_tenant"
					submitLabel="Konfirmasi Pindah"
					target="#form_result, #tenants-content-wrapper"
				>
					<input name="id" type="hidden" value={tenant.id} />

					<FormField label="Pilih Kamar Tujuan">
						<select class="select w-full" name="room_id" required>
							<option value="" disabled selected>
								Pilih kamar baru...
							</option>
							{availableRooms.map(({ id, roomNumber, roomType }) => (
								<option value={id}>
									{roomNumber} – {ROOM_TYPE_LABELS[roomType] ?? roomType}{" "}
									(Tersedia)
								</option>
							))}
						</select>
					</FormField>

					<FormField label="Tanggal Pindah">
						<input
							class="input w-full"
							name="start_date"
							type="date"
							required
						/>
					</FormField>
				</ModalForm>
			</>
		) : (
			<NotFound label="Penghuni" />
		)
	}
</Modal>
