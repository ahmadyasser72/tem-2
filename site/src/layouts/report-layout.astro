---
import { db } from "@indekos/database";
import dayjs, { formatDate } from "@indekos/utilities/date";

import "~/styles/report.css";

export interface Props {
	title: string;
	subtitle?: string;
}

const { title, subtitle } = Astro.props;
const today = dayjs().format("DD MMMM YYYY");

const createdBy = Astro.url.searchParams.get("createdBy") ?? "Staff";
const owner = await db.query.users.findFirst({
	where: { role: "owner" },
	columns: { displayName: true },
});
const knownBy = owner?.displayName ?? "Pemilik Kos";
---

<!doctype html>
<html lang="id">
	<head>
		<meta charset="utf-8" />
		<title>{title}</title>
	</head>
	<body class="report-body">
		<div class="mb-4 border-b-2 border-black pb-2.5">
			<div class="flex items-center gap-4">
				<div
					class="flex size-14 shrink-0 items-center justify-center rounded-full bg-gray-700 text-xl font-bold text-white"
				>
					<svg
						height="1.5em"
						viewBox="0 0 24 24"
						width="1.5em"
						xmlns="http://www.w3.org/2000/svg"
					>
						<path d="M0 0h24v24H0z" fill="none"></path>
						<g
							fill="none"
							stroke="currentColor"
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
						>
							<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8"></path>
							<path
								d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"
							></path>
						</g>
					</svg>
				</div>
				<div class="flex-1 text-center">
					<div class="text-xl font-bold tracking-wide uppercase">
						Indekos Ungu
					</div>
					<div class="my-1 border-b border-black"></div>
					<div class="text-[11px] opacity-70">
						Jl. Sejahtera, Komplek Damai, RT 002/RW 006, Kelurahan Mentaos, Kec.
						Banjarbaru Utara, Kota Banjar Baru, Kalimantan Selatan 70714 · Telp:
						+62 896-7268-4032
					</div>
				</div>
			</div>
		</div>

		<div class="mb-4 text-center">
			<h2 class="text-sm font-bold tracking-[0.5px] uppercase underline">
				{title}
			</h2>
			{subtitle && <p class="mt-1 text-[11px] opacity-70">{subtitle}</p>}
		</div>

		<div class="mb-3 text-[10px] opacity-60">
			Dicetak: {formatDate(new Date(), "DD MMMM YYYY HH:mm")}
		</div>

		<slot />

		<div class="mt-12 grid grid-cols-2 gap-10 text-center text-[11px]">
			<div>
				<p>Banjarbaru, {today}</p>
				<p class="mt-1 font-semibold">Dibuat oleh</p>
				<p class="text-[10px] opacity-60">(Staff/Admin)</p>
				<div class="mt-10 border-t-2 border-black pt-1">
					<p>{createdBy}</p>
				</div>
			</div>
			<div>
				<p>Banjarbaru, {today}</p>
				<p class="mt-1 font-semibold">Diketahui oleh</p>
				<p class="text-[10px] opacity-60">(Pemilik Kos)</p>
				<div class="mt-10 border-t-2 border-black pt-1">
					<p>{knownBy}</p>
				</div>
			</div>
		</div>
	</body>
</html>
