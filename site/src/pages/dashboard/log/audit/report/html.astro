---
import { db } from "@e-kos/database";

import { z } from "astro/zod";

import ReportLayout from "~/layouts/report-layout.astro";
import { formatDate } from "~/lib/date";

const params = Astro.locals.parseQuery(
	z.object({
		userId: z.coerce.number().optional().catch(undefined),
		from: z.string().optional().catch(undefined),
		to: z.string().optional().catch(undefined),
		action: z.enum(["CREATE", "UPDATE", "DELETE"]).optional().catch(undefined),
	}),
);

const createdBy = Astro.url.searchParams.get("createdBy") ?? "Staff";
const owner = await db.query.users.findFirst({ where: { role: "owner" } });
const knownBy = owner?.displayName ?? "Pemilik Kos";

const { userId, from, to, action } = params;

const targetUser =
	userId != null
		? await db.query.users.findFirst({ where: { id: userId } })
		: null;

const fromDate = from ? new Date(from) : undefined;
const toDate = to
	? (() => {
			const d = new Date(to);
			d.setHours(23, 59, 59, 999);
			return d;
		})()
	: undefined;

const logs = await db.query.auditLogs.findMany({
	where: {
		...(userId != null && { userId }),
		...(action != null && { action }),
		...(fromDate && toDate && { createdAt: { gte: fromDate, lte: toDate } }),
		...(!fromDate && toDate && { createdAt: { lte: toDate } }),
		...(fromDate && !toDate && { createdAt: { gte: fromDate } }),
	},
	with: { user: true },
	orderBy: { createdAt: "desc" },
});

const rows = logs.map((log) => ({
	time: log.createdAt,
	username: log.user?.username ?? "Sistem",
	displayName: log.user?.displayName ?? log.user?.username ?? "Sistem",
	action: log.action,
	tableName: log.tableName,
	recordId: log.recordId,
}));

const filterParts: string[] = [];
if (targetUser) {
	filterParts.push(
		`Pengguna: ${targetUser.displayName ?? targetUser.username}`,
	);
}
if (action != null) {
	const label: Record<string, string> = {
		CREATE: "Membuat",
		UPDATE: "Mengubah",
		DELETE: "Menghapus",
	};
	filterParts.push(`Aksi: ${label[action] ?? action}`);
}
if (from) filterParts.push(`Dari: ${formatDate(from, "DD MMM YYYY")}`);
if (to) filterParts.push(`Sampai: ${formatDate(to, "DD MMM YYYY")}`);

const subtitle = filterParts.length > 0 ? filterParts.join(" | ") : undefined;
---

<ReportLayout
	title="Laporan Aktivitas Pengguna"
	createdBy={createdBy}
	knownBy={knownBy}
	subtitle={subtitle}
>
	<div style="font-size: 10px; margin-bottom: 12px; opacity: 0.6;">
		Dicetak: {formatDate(new Date(), "DD MMMM YYYY HH:mm")}
	</div>

	{
		targetUser && (
			<div style="display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-bottom: 16px; font-size: 11px; padding: 8px; border: 1px solid black; background: #fafafa;">
				<div>
					<span style="font-weight: 700; opacity: 0.6;">Nama</span>
					<div style="font-weight: 700; margin-top: 2px;">
						{targetUser.displayName ?? targetUser.username}
					</div>
				</div>
				<div>
					<span style="font-weight: 700; opacity: 0.6;">Peran</span>
					<div style="font-weight: 700; margin-top: 2px; text-transform: capitalize;">
						{targetUser.role}
					</div>
				</div>
			</div>
		)
	}

	<table>
		<thead>
			<tr>
				<th style="width: 5%; text-align: center;">No.</th>
				<th style="width: 20%;">Waktu Kejadian</th>
				<th style="width: 18%;">Pengguna</th>
				<th style="width: 14%;">Jenis Aksi</th>
				<th style="width: 28%;">Tabel Target</th>
				<th style="width: 15%;">ID Record</th>
			</tr>
		</thead>
		<tbody>
			{
				rows.length === 0 ? (
					<tr>
						<td
							colspan="6"
							style="text-align: center; padding: 24px; font-size: 11px; opacity: 0.5;"
						>
							Tidak ada data audit log untuk filter yang dipilih.
						</td>
					</tr>
				) : (
					rows.map((row, i) => (
						<tr>
							<td style="text-align: center; font-size: 10px;">{i + 1}</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px;">
								{formatDate(row.time, "DD MMM YYYY HH:mm")}
							</td>
							<td>{row.displayName}</td>
							<td style="font-weight: 700; text-transform: uppercase;">
								{row.action}
							</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px;">
								{row.tableName}
							</td>
							<td style="font-family: 'Courier New', monospace; font-size: 10px; text-align: center;">
								{row.recordId ?? "-"}
							</td>
						</tr>
					))
				)
			}
		</tbody>
	</table>
</ReportLayout>
